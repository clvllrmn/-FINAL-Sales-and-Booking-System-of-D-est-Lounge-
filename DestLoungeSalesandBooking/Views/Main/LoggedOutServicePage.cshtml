@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" class="logo" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <a href="#">
                    <i class="fa-solid fa-bell"></i> Notifications
                </a>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <a href="#" class="bell-icon" title="Notifications">
                <i class="fa-solid fa-bell"></i>
            </a>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="nav-overlay" id="navOverlay"></div>
</header>

<!-- Services Section -->
<div class="services-page-container" ng-controller="DestLoungeSalesandBookingController">

    <!-- Mobile Category Filter (horizontal pills) -->
    <div class="mobile-category-bar">
        <button class="mobile-cat-btn" ng-class="{'mobile-cat-active': selectedCategory === 'all'}" ng-click="filterServices('all')">All</button>
        <button class="mobile-cat-btn" ng-class="{'mobile-cat-active': selectedCategory === 'manicure'}" ng-click="filterServices('manicure')">Manicure</button>
        <button class="mobile-cat-btn" ng-class="{'mobile-cat-active': selectedCategory === 'pedicure'}" ng-click="filterServices('pedicure')">Pedicure</button>
    </div>

    <div class="services-sidebar">
        <h2 class="services-sidebar-title">Services</h2>
        <div class="service-category"
             ng-class="{'active': selectedCategory === 'all'}"
             ng-click="filterServices('all')">
            <h3>All Services</h3>
        </div>
        <div class="service-category"
             ng-class="{'active': selectedCategory === 'manicure'}"
             ng-click="filterServices('manicure')">
            <h3>Manicure</h3>
        </div>
        <div class="service-category"
             ng-class="{'active': selectedCategory === 'pedicure'}"
             ng-click="filterServices('pedicure')">
            <h3>Pedicure</h3>
        </div>
    </div>

    <div class="services-content">
        <div class="service-card"
             ng-repeat="service in services | filter:categoryFilter">
            <div class="service-image">
                <img ng-src="{{service.image}}" alt="{{service.name}}">
            </div>
            <div class="service-name">{{service.name}}</div>
        </div>
    </div>
</div>

<!-- Book Now Button -->
<div class="book-now-container">
    <button class="book-now-button" onclick="window.location.href='@Url.Action("SignUpPage","Main")'">
        Book Now
    </button>
</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i>
                <span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i>
                <span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i>
                <span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    /* ── Nav Overlay ── */
    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Mobile Category Bar (hidden on desktop) ── */
    .mobile-category-bar {
        display: none;
    }

    /* ── Services Layout ── */
    .services-page-container {
        display: flex;
        min-height: calc(100vh - 400px);
    }

    .services-sidebar {
        width: 220px;
        flex-shrink: 0;
        background-color: #e7dfd6;
        border-right: 2px solid #d4c4b0;
        padding: 2rem 1.5rem;
    }

    .services-sidebar-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 1.5rem 0;
        font-family: 'Brush Script MT', cursive;
        font-style: italic;
    }

    .service-category {
        padding: 0.75rem 1rem;
        border-radius: 10px;
        cursor: pointer;
        margin-bottom: 0.5rem;
        transition: background-color 0.2s ease, color 0.2s ease;
    }

        .service-category h3 {
            margin: 0;
            font-size: 0.95rem;
            font-weight: 600;
            color: #5d4037;
            letter-spacing: 0.03em;
        }

        .service-category:hover {
            background-color: #d4c4b0;
        }

        .service-category.active {
            background-color: #6b4423;
        }

            .service-category.active h3 {
                color: white;
            }

    .services-content {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        padding: 2rem;
        align-content: start;
        background-color: #f5f0eb;
    }

    .service-card {
        background-color: white;
        border: 2px solid #d4c4b0;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

        .service-card:hover {
            transform: translateY(-4px);
            box-shadow: 5px 8px 18px rgba(0,0,0,0.15);
        }

    .service-image {
        width: 100%;
        aspect-ratio: 1/1;
        overflow: hidden;
    }

        .service-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s ease;
        }

    .service-card:hover .service-image img {
        transform: scale(1.06);
    }

    .service-name {
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        font-weight: 600;
        color: #4a3428;
        text-align: center;
        background-color: #faf7f4;
        border-top: 1px solid #e7dfd6;
    }

    /* ── Book Now ── */
    .book-now-container {
        display: flex;
        justify-content: center;
        padding: 2.5rem 1rem;
        background-color: #f5f0eb;
    }

    .book-now-button {
        background-color: #6b4423;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 1rem 3.5rem;
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(107,68,35,0.35);
        transition: background-color 0.3s ease, transform 0.2s ease, box-shadow 0.3s ease;
        font-family: inherit;
    }

        .book-now-button:hover {
            background-color: #5a3519;
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(107,68,35,0.45);
        }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-container {
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* =============================================
       DESKTOP (above 1024px)
    ============================================= */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .mobile-category-bar {
            display: none !important;
        }

        .services-sidebar {
            display: block !important;
        }

        .main-nav {
            position: static !important;
            top: auto !important;
            right: auto !important;
            left: auto !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            background-color: transparent !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            justify-content: flex-start !important;
            gap: 2.5rem !important;
            overflow: visible !important;
            transform: none !important;
            transition: none !important;
            z-index: auto !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                letter-spacing: 0.5px !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    /* =============================================
       TABLET + MOBILE (max-width: 1024px)
    ============================================= */
    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            justify-content: flex-start !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
            box-shadow: -4px 0 20px rgba(0,0,0,0.15) !important;
            transform: translateX(100%) !important;
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1) !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            margin: 0 !important;
        }

            .main-nav.open {
                transform: translateX(0) !important;
            }

            .main-nav a {
                width: 100% !important;
                padding: 0.9rem 0 !important;
                font-size: 1rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                letter-spacing: 0.05em !important;
                display: block !important;
                text-decoration: none !important;
                background: none !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 1px solid #e0d5c8 !important;
                }

        .mobile-nav-actions {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #d4c4b0;
            gap: 0;
        }

            .mobile-nav-actions a {
                display: flex !important;
                align-items: center;
                gap: 0.6rem;
                padding: 0.75rem 0 !important;
                font-size: 0.97rem !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                width: 100% !important;
                font-weight: 600 !important;
                text-decoration: none !important;
                background: none !important;
            }

                .mobile-nav-actions a:last-child {
                    border-bottom: none !important;
                }
        /* Hide desktop sidebar, show pill bar */
        .services-sidebar {
            display: none !important;
        }

        .mobile-category-bar {
            display: flex !important;
            gap: 0.6rem;
            padding: 1.2rem 1rem;
            background-color: #e7dfd6;
            border-bottom: 2px solid #d4c4b0;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }

            .mobile-category-bar::-webkit-scrollbar {
                display: none;
            }

        .mobile-cat-btn {
            flex-shrink: 0;
            padding: 0.55rem 1.3rem;
            border-radius: 20px;
            border: 2px solid #c1b2a5;
            background-color: white;
            color: #8b6f47;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            font-family: inherit;
            transition: all 0.25s ease;
        }

            .mobile-cat-btn:hover {
                border-color: #6b4423;
                color: #6b4423;
            }

            .mobile-cat-btn.mobile-cat-active {
                background-color: #6b4423;
                border-color: #6b4423;
                color: white;
            }
        /* Services grid goes full width */
        .services-page-container {
            flex-direction: column;
        }

        .services-content {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.2rem;
            padding: 1.5rem;
        }
    }

    /* =============================================
       MOBILE (max-width: 768px)
    ============================================= */
    @@media (max-width: 768px) {
        .services-content {
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            padding: 1rem;
        }

        .service-name {
            font-size: 0.85rem;
            padding: 0.6rem 0.75rem;
        }

        .book-now-container {
            padding: 2rem 1rem;
        }

        .book-now-button {
            padding: 0.9rem 2.5rem;
            font-size: 1rem;
        }

        footer {
            padding: 1.5rem 1rem;
        }

        .footer-title {
            font-size: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .social-links {
            gap: 1.5rem;
        }

        .social-item i {
            font-size: 1.25rem;
        }

        .social-item span {
            font-size: 0.8rem;
        }
    }

    /* =============================================
       SMALL MOBILE (max-width: 400px)
    ============================================= */
    @@media (max-width: 400px) {
        .mobile-category-bar {
            padding: 1rem 0.75rem;
        }

        .mobile-cat-btn {
            padding: 0.5rem 1rem;
            font-size: 0.82rem;
        }

        .services-content {
            grid-template-columns: 1fr 1fr;
            gap: 0.75rem;
            padding: 0.75rem;
        }

        .service-name {
            font-size: 0.8rem;
        }

        .book-now-button {
            padding: 0.85rem 2rem;
            font-size: 0.95rem;
        }
    }
</style>

@section scripts {
    <script>
        (function () {
            var btn = document.getElementById('hamburgerBtn');
            var nav = document.getElementById('mainNav');
            var overlay = document.getElementById('navOverlay');

            function openMenu() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeMenu() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', function () {
                nav.classList.contains('open') ? closeMenu() : openMenu();
            });

            overlay.addEventListener('click', closeMenu);

            nav.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', closeMenu);
            });
        })();
    </script>
}