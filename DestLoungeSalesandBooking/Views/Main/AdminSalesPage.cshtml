<script src="~/Scripts/chart.js"></script>

<script>
    var salesChartInstance = null;

    function renderSalesChart(points) {
        var labels = points.map(function (p) { return p.label; });
        var values = points.map(function (p) { return p.value; });
        var ctx = document.getElementById('salesChart').getContext('2d');
        if (salesChartInstance) salesChartInstance.destroy();
        salesChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue (₱)',
                    data: values,
                    borderColor: '#6b4423',
                    backgroundColor: 'rgba(107,68,35,0.08)',
                    borderWidth: 2.5,
                    tension: 0.35,
                    fill: true,
                    pointBackgroundColor: '#6b4423',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2,
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        labels: {
                            color: '#5d4037',
                            font: { family: 'Georgia', size: 13 },
                            usePointStyle: true
                        }
                    },
                    tooltip: {
                        backgroundColor: '#3d2817',
                        titleColor: '#e7dfd6',
                        bodyColor: 'white',
                        padding: 10,
                        cornerRadius: 8,
                        callbacks: {
                            label: function (ctx) {
                                return ' ₱' + ctx.parsed.y.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#5d4037', font: { family: 'Georgia', size: 12 } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(90,74,58,0.1)' },
                        ticks: {
                            color: '#5d4037',
                            font: { family: 'Georgia', size: 12 },
                            callback: function (val) { return '₱' + val.toLocaleString(); }
                        }
                    }
                }
            }
        });
    }

    function toggleMobileNav() {
        document.getElementById('mobileDrawer').classList.toggle('open');
        document.getElementById('mobileOverlay').classList.toggle('open');
    }
</script>