@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<!-- Sidebar Navigation -->
<aside class="sidebar">
    <div class="logo-container">
        <a href="@Url.Action("AdminHomepage","Main")">
            <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
        </a>
    </div>
    <nav class="sidebar-nav">
        <a href="@Url.Action("AdminHomepage","Main")" class="nav-item">HOME</a>
        <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
        <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
        <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
        <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item">FAQs</a>
        <a href="@Url.Action("AdminInboxPage","Main")" class="nav-item">INBOX</a>
        <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item active">SALES</a>
        <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item">GALLERY</a>
        <a href="@Url.Action("AdminPaymentSetting","Main")" class="nav-item">PAYMENT</a>

    </nav>
    <div class="sidebar-footer">
        <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
        </a>
    </div>
</aside>

<!-- Main Content Area -->
<div class="main-content" ng-controller="DestLoungeSalesandBookingController">
    <div class="bookings-container">

        <h1 class="bookings-title">Salon's Analytics</h1>
        <p class="page-subtitle">Track revenue and appointment trends</p>

        <!-- Range Tabs -->
        <div class="filter-tabs">
            <button class="tab-btn" ng-class="{'active': salesRange === 'today'}" ng-click="setSalesRange('today')">Today</button>
            <button class="tab-btn" ng-class="{'active': salesRange === 'week'}" ng-click="setSalesRange('week')">This Week</button>
            <button class="tab-btn" ng-class="{'active': salesRange === 'month'}" ng-click="setSalesRange('month')">This Month</button>
        </div>

        <!-- KPI Cards -->
        <div class="sales-kpis">
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-peso-sign"></i></div>
                <div class="kpi-title">Total Revenue</div>
                <div class="kpi-value">₱ {{sales.totalRevenue || 0}}</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-calendar-check"></i></div>
                <div class="kpi-title">Completed Bookings</div>
                <div class="kpi-value">{{sales.totalBookings || 0}}</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-clock"></i></div>
                <div class="kpi-title">Range</div>
                <div class="kpi-value kpi-value-range">{{sales.range || salesRange}}</div>
            </div>
        </div>

        <!-- Chart -->
        <div class="chart-wrap">
            <div class="chart-header">
                <div>
                    <div class="chart-title">Appointments Over Time</div>
                    <div class="chart-sub">Revenue from completed appointments</div>
                </div>
            </div>
            <div class="chart-canvas-wrap">
                <canvas id="salesChart"></canvas>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <h2 class="footer-title">Follow our Socials!</h2>
            <div class="social-links">
                <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                    <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
                </a>
                <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                    <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
                </a>
                <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                    <i class="fa-brands fa-instagram"></i><span>destlounge</span>
                </a>
            </div>
        </div>
    </footer>
</div>



@@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap');
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Georgia', serif;
        background-color: #d4c4b0;
    }

    /* Sidebar */
    .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 10%;
        min-width: 9rem;
        height: 100vh;
        background-color: #e7dfd6;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.25rem 0;
        z-index: 1000;
    }

    .logo-container {
        margin-bottom: 2rem;
    }

    .sidebar-logo {
        width: 3.5rem;
        height: auto;
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        width: 100%;
    }

    .nav-item {
        color: #5a4a3a;
        text-decoration: none;
        padding: 1rem 0.625rem;
        font-size: 1rem;
        font-weight: 500;
        text-align: center;
        transition: background-color 0.3s;
        letter-spacing: 0.0625rem;
        display: block;
    }

        .nav-item:hover {
            background-color: rgba(90,74,58,0.1);
        }

        .nav-item.active {
            background-color: rgba(139,111,71,0.3);
            border-left: 0.25rem solid #8b6f47;
        }

    .sidebar-footer {
        margin-top: auto;
        padding: 1.25rem 0;
    }

    .admin-link {
        color: #5a4a3a;
        text-decoration: none;
        font-size: 0.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3125rem;
    }

        .admin-link i {
            font-size: 1.25rem;
        }

    /* Main */
    .main-content {
        margin-left: 10%;
        min-height: 100vh;
        background-color: #f5f0eb;
        display: flex;
        flex-direction: column;
    }

    .bookings-container {
        padding: 2.5rem 3rem;
        flex: 1;
    }

    .bookings-title {
        font-size: 2rem;
        font-weight: 700;
        color: #5a4a3a;
        margin-bottom: 0.3rem;
        letter-spacing: 0.5px;
    }

    .page-subtitle {
        font-size: 0.95rem;
        color: #8b6f47;
        margin-bottom: 2rem;
        font-style: italic;
    }

    /* Tabs */
    .filter-tabs {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .tab-btn {
        background-color: white;
        border: 2px solid #d4c4b0;
        color: #8b6f47;
        font-size: 0.9rem;
        font-weight: 600;
        padding: 0.55rem 1.4rem;
        cursor: pointer;
        transition: all 0.25s ease;
        border-radius: 25px;
        font-family: 'Georgia', serif;
        letter-spacing: 0.3px;
    }

        .tab-btn:hover {
            border-color: #6b4423;
            color: #6b4423;
            background-color: #f5f0eb;
        }

        .tab-btn.active {
            background-color: #6b4423;
            border-color: #6b4423;
            color: white;
            box-shadow: 0 4px 12px rgba(107,68,35,0.25);
        }

    /* KPI Cards */
    .sales-kpis {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .kpi-card {
        background-color: #e7dfd6;
        border-radius: 16px;
        padding: 1.5rem 1.8rem;
        border: 2px solid #c1b2a5;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .kpi-card:hover {
            transform: translateY(-3px);
            box-shadow: 5px 6px 16px rgba(0,0,0,0.13);
        }

    .kpi-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background-color: rgba(107,68,35,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.5rem;
    }

        .kpi-icon i {
            font-size: 1.1rem;
            color: #6b4423;
        }

    .kpi-title {
        color: #8b6f47;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .kpi-value {
        font-size: 2rem;
        font-weight: 700;
        color: #6b4423;
        line-height: 1.1;
        font-family: 'Montserrat', sans-serif;
    }

    .kpi-value-range {
        font-size: 1.2rem;
        padding-top: 0.3rem;
        font-family: 'Montserrat', sans-serif;
    }

    /* Chart */
    .chart-wrap {
        background-color: white;
        border-radius: 16px;
        border: 2px solid #d4c4b0;
        padding: 2rem;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .chart-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #3d2817;
    }

    .chart-sub {
        font-size: 0.82rem;
        color: #8b6f47;
        margin-top: 0.2rem;
    }

    .chart-canvas-wrap {
        position: relative;
        height: 300px;
    }

    /* Footer */
    /* Footer */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        margin: 0;
        text-align: center;
    }

    .footer-container {
        padding: 0;
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 5rem;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: transform 0.3s;
    }

        .social-item:hover {
            transform: scale(1.1);
            color: #6b4423;
        }

        .social-item i {
            font-size: 2.2rem;
        }

        .social-item span {
            font-size: 1rem;
            font-weight: 500;
        }

    @@media (max-width: 768px) {
        .sidebar {
            width: 6%;
            min-width: 5rem;
        }

        .main-content {
            margin-left: 6%;
        }

        .nav-item {
            font-size: 0.65rem;
            padding: 0.75rem 0.3125rem;
        }

        .bookings-container {
            padding: 1.5rem;
        }

        .sales-kpis {
            grid-template-columns: 1fr;
        }

        .chart-canvas-wrap {
            height: 220px;
        }
    }
</style>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
    // Waits for AngularJS to finish, then wires up the chart.
    // setSalesRange() is called by the tab buttons via ng-click in the controller.
    // The controller calls /Sales/Analytics?range=... and stores the result in $scope.sales.
    // We expose a global function the controller can call after data loads.

    var salesChartInstance = null;

    function renderSalesChart(points) {
        var labels = points.map(function (p) { return p.label; });
        var values = points.map(function (p) { return p.value; });

        var ctx = document.getElementById('salesChart').getContext('2d');

        if (salesChartInstance) {
            salesChartInstance.destroy();
        }

        salesChartInstance = new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Revenue (₱)',
                    data: values,
                    borderColor: '#6b4423',
                    backgroundColor: 'rgba(107,68,35,0.08)',
                    borderWidth: 2.5,
                    tension: 0.35,
                    fill: true,
                    pointBackgroundColor: '#6b4423',
                    pointBorderColor: 'white',
                    pointBorderWidth: 2,
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        labels: {
                            color: '#5d4037',
                            font: { family: 'Georgia', size: 13 },
                            usePointStyle: true
                        }
                    },
                    tooltip: {
                        backgroundColor: '#3d2817',
                        titleColor: '#e7dfd6',
                        bodyColor: 'white',
                        padding: 10,
                        cornerRadius: 8,
                        callbacks: {
                            label: function (ctx) {
                                return ' ₱' + ctx.parsed.y.toLocaleString();
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        grid: { display: false },
                        ticks: { color: '#5d4037', font: { family: 'Georgia', size: 12 } }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(90,74,58,0.1)' },
                        ticks: {
                            color: '#5d4037',
                            font: { family: 'Georgia', size: 12 },
                            callback: function (val) { return '₱' + val.toLocaleString(); }
                        }
                    }
                }
            }
        });
    }
</script>