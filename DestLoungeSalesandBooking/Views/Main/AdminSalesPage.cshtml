@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

 Sidebar Navigation 
<aside class="sidebar">
    <div class="logo-container">
        <a href="@Url.Action("AdminDashboard","Main")">
            <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
        </a>
    </div>
    <nav class="sidebar-nav">
        <a href="@Url.Action("AdminDashboard","Main")" class="nav-item">DASHBOARD</a>
        <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item active">SALES</a>
    </nav>
    <div class="sidebar-footer">
        <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
        </a>
    </div>
</aside>

 Mobile Top Bar 
<div class="mobile-topbar">
    <a href="@Url.Action("AdminDashboard","Main")">
        <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
    </a>
    <button class="mobile-menu-btn" onclick="toggleMobileNav()">
        <i class="fa-solid fa-bars"></i>
    </button>
</div>

 Mobile Nav Overlay 
<div class="mobile-nav-overlay" id="mobileOverlay" onclick="toggleMobileNav()"></div>

 Mobile Nav Drawer 
<div class="mobile-nav-drawer" id="mobileDrawer">
    <nav class="sidebar-nav">
        <a href="@Url.Action("AdminDashboard","Main")" class="nav-item">DASHBOARD</a>
        <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item active">SALES</a>
    </nav>
    <div class="sidebar-footer">
        <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
        </a>
    </div>
</div>

 Main Content Area 
<div class="main-content" ng-controller="DestLoungeSalesandBookingController">
    <div class="bookings-container">

        <h1 class="bookings-title">Salon's Analytics</h1>
        <p class="page-subtitle">Track revenue, appointments, and service performance</p>

         Filter Bar 
        <div class="filter-bar-card">

             Range Tabs 
            <div class="filter-row-top">
                <span class="filter-label">Range:</span>
                <div class="filter-tabs">
                    <button class="tab-btn" ng-class="{'active': salesRange === 'today'}" ng-click="setSalesRange('today')">Today</button>
                    <button class="tab-btn" ng-class="{'active': salesRange === 'month'}" ng-click="setSalesRange('month')">This Month</button>
                    <button class="tab-btn" ng-class="{'active': salesRange === '3months'}" ng-click="setSalesRange('3months')">3 Months</button>
                    <button class="tab-btn" ng-class="{'active': salesRange === '6months'}" ng-click="setSalesRange('6months')">6 Months</button>
                    <button class="tab-btn" ng-class="{'active': salesRange === 'year'}" ng-click="setSalesRange('year')">This Year</button>
                    <button class="tab-btn" ng-class="{'active': salesRange === 'custom'}" ng-click="setSalesRange('custom')">Custom Range</button>
                </div>
            </div>

             Custom Date Range 
            <div class="filter-row-bottom" ng-show="salesRange === 'custom'">
                <span class="filter-label">From:</span>
                <input type="date" class="date-input" ng-model="customFrom" ng-change="applyCustomRange()" />
                <span class="filter-label">To:</span>
                <input type="date" class="date-input" ng-model="customTo" ng-change="applyCustomRange()" />
                <button class="apply-btn" ng-click="applyCustomRange()" ng-disabled="!customFrom || !customTo">
                    <i class="fa-solid fa-magnifying-glass"></i> Apply
                </button>
            </div>

        </div>

         KPI Cards 
        <div class="sales-kpis">
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-peso-sign"></i></div>
                <div class="kpi-title">Total Revenue</div>
                <div class="kpi-value">₱ {{sales.totalRevenue || 0 | number:2}}</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-calendar-check"></i></div>
                <div class="kpi-title">Completed Bookings</div>
                <div class="kpi-value">{{sales.totalBookings || 0}}</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-star"></i></div>
                <div class="kpi-title">Top Service</div>
                <div class="kpi-value kpi-value-range">{{sales.topService || '—'}}</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon"><i class="fa-solid fa-clock"></i></div>
                <div class="kpi-title">Period</div>
                <div class="kpi-value kpi-value-range">{{sales.range || salesRange}}</div>
            </div>
        </div>

         Chart 
        <div class="chart-wrap">
            <div class="chart-header">
                <div>
                    <div class="chart-title">Appointments Over Time</div>
                    <div class="chart-sub">Revenue from completed appointments</div>
                </div>
            </div>
            <div class="chart-canvas-wrap">
                <canvas id="salesChart"></canvas>
            </div>
        </div>

         Service Performance 
        <div class="service-section">
            <div class="section-header-row">
                <div>
                    <div class="section-title">Service Performance</div>
                    <div class="section-sub">Services earning 60%+ of revenue share are marked as Blockbusters</div>
                </div>
            </div>

             Service Filter Pills 
            <div class="service-filter-bar">
                <button class="svc-pill" ng-class="{'active': selectedService === 'all'}" ng-click="filterByService('all')">All Services</button>
                <button class="svc-pill"
                        ng-repeat="svc in servicePerformance"
                        ng-class="{'active': selectedService === svc.name}"
                        ng-click="filterByService(svc.name)">
                    {{svc.name}}
                    <span class="pill-badge" ng-if="svc.isBlockbuster">&#9733;</span>
                </button>
            </div>

             Service Table 
            <div class="service-table-wrap">
                <table class="service-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Service</th>
                            <th>Bookings</th>
                            <th>Revenue</th>
                            <th>Revenue Share</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="svc in filteredServicePerformance track by $index">
                            <td class="cell-num">{{$index + 1}}</td>
                            <td class="cell-name">{{svc.name}}</td>
                            <td>{{svc.bookings}}</td>
                            <td>₱ {{svc.revenue | number:2}}</td>
                            <td>
                                <div class="share-bar-wrap">
                                    <div class="share-bar">
                                        <div class="share-bar-fill" ng-style="{'width': svc.share + '%', 'background': svc.isBlockbuster ? '#6b4423' : '#c1b2a5'}"></div>
                                    </div>
                                    <span class="share-pct">{{svc.share}}%</span>
                                </div>
                            </td>
                            <td>
                                <span class="status-badge" ng-class="svc.isBlockbuster ? 'badge-blockbuster' : (svc.share >= 20 ? 'badge-regular' : 'badge-low')">
                                    <i class="fa-solid" ng-class="svc.isBlockbuster ? 'fa-fire' : (svc.share >= 20 ? 'fa-circle-check' : 'fa-arrow-trend-down')"></i>
                                    {{svc.isBlockbuster ? 'Blockbuster' : (svc.share >= 20 ? 'Regular' : 'Low Demand')}}
                                </span>
                            </td>
                        </tr>
                        <tr ng-if="filteredServicePerformance.length === 0">
                            <td colspan="6" class="empty-row">No service data available.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

         Report Generator 
        <div class="report-section">
            <div class="section-header-row">
                <div>
                    <div class="section-title"><i class="fa-solid fa-file-lines"></i> Generate Report</div>
                    <div class="section-sub">Customize what to include in your summary report</div>
                </div>
            </div>

            <p class="report-hint">Select sections to include:</p>

            <div class="report-options-grid">
                <label class="report-check">
                    <input type="checkbox" ng-model="reportOptions.revenue" /> Revenue Summary
                </label>
                <label class="report-check">
                    <input type="checkbox" ng-model="reportOptions.bookings" /> Booking Counts
                </label>
                <label class="report-check">
                    <input type="checkbox" ng-model="reportOptions.services" /> Service Breakdown
                </label>
                <label class="report-check">
                    <input type="checkbox" ng-model="reportOptions.blockbusters" /> Blockbusters Only
                </label>
                <label class="report-check">
                    <input type="checkbox" ng-model="reportOptions.period" /> Period Details
                </label>
                <label class="report-check">
                    <input type="checkbox" ng-model="reportOptions.top5" /> Top 5 Services
                </label>
            </div>

            <div class="report-btn-row">
                <button class="gen-btn" ng-click="generateReport()">
                    <i class="fa-solid fa-wand-magic-sparkles"></i> Generate Preview
                </button>
                <button class="print-btn" ng-click="printReport()" ng-disabled="!reportGenerated">
                    <i class="fa-solid fa-print"></i> Print / Save PDF
                </button>
            </div>

             Report Preview 
            <div class="report-preview-wrap" ng-show="reportGenerated">
                <div class="report-preview-label">REPORT PREVIEW</div>
                <div class="report-preview-box" id="printableReport">
                    <div class="rpt-header">
                        <div class="rpt-logo-text">D'est Lounge</div>
                        <div class="rpt-title">Sales & Analytics Report</div>
                        <div class="rpt-meta">Generated: {{reportDate}} &nbsp;|&nbsp; Period: {{sales.range || salesRange}}</div>
                    </div>

                    <div class="rpt-section" ng-if="reportOptions.period">
                        <div class="rpt-section-title">Period Details</div>
                        <div class="rpt-row"><span>Range Selected</span><span>{{sales.range || salesRange}}</span></div>
                        <div class="rpt-row" ng-if="salesRange === 'custom'"><span>From</span><span>{{customFrom}}</span></div>
                        <div class="rpt-row" ng-if="salesRange === 'custom'"><span>To</span><span>{{customTo}}</span></div>
                    </div>

                    <div class="rpt-section" ng-if="reportOptions.revenue">
                        <div class="rpt-section-title">Revenue Summary</div>
                        <div class="rpt-row"><span>Total Revenue</span><span class="rpt-highlight">₱ {{sales.totalRevenue || 0 | number:2}}</span></div>
                        <div class="rpt-row"><span>Top Earning Service</span><span>{{sales.topService || '—'}}</span></div>
                    </div>

                    <div class="rpt-section" ng-if="reportOptions.bookings">
                        <div class="rpt-section-title">Booking Counts</div>
                        <div class="rpt-row"><span>Total Completed</span><span class="rpt-highlight">{{sales.totalBookings || 0}}</span></div>
                    </div>

                    <div class="rpt-section" ng-if="reportOptions.services">
                        <div class="rpt-section-title">Service Breakdown</div>
                        <table class="rpt-table">
                            <thead>
                                <tr><th>Service</th><th>Bookings</th><th>Revenue</th><th>Share</th><th>Status</th></tr>
                            </thead>
                            <tbody>
                                <tr ng-repeat="svc in servicePerformance">
                                    <td>{{svc.name}}</td>
                                    <td>{{svc.bookings}}</td>
                                    <td>₱ {{svc.revenue | number:2}}</td>
                                    <td>{{svc.share}}%</td>
                                    <td>{{svc.isBlockbuster ? 'Blockbuster' : (svc.share >= 20 ? 'Regular' : 'Low Demand')}}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="rpt-section" ng-if="reportOptions.blockbusters">
                        <div class="rpt-section-title">Blockbuster Services</div>
                        <div ng-repeat="svc in servicePerformance | filter:{isBlockbuster:true}">
                            <div class="rpt-row">
                                <span>&#9733; {{svc.name}}</span>
                                <span class="rpt-highlight">₱ {{svc.revenue | number:2}} ({{svc.share}}%)</span>
                            </div>
                        </div>
                        <div ng-if="(servicePerformance | filter:{isBlockbuster:true}).length === 0" class="rpt-empty">No blockbuster services in this period.</div>
                    </div>

                    <div class="rpt-section" ng-if="reportOptions.top5">
                        <div class="rpt-section-title">Top 5 Services by Revenue</div>
                        <div ng-repeat="svc in servicePerformance | orderBy:'-revenue' | limitTo:5" class="rpt-row">
                            <span>{{$index + 1}}. {{svc.name}}</span>
                            <span>₱ {{svc.revenue | number:2}}</span>
                        </div>
                    </div>

                    <div class="rpt-footer">D'est Lounge &mdash; Confidential Sales Report</div>
                </div>
            </div>
        </div>

    </div>

     Footer 
    <footer>
        <div class="footer-container">
            <h2 class="footer-title">Follow our Socials!</h2>
            <div class="social-links">
                <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                    <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
                </a>
                <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                    <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
                </a>
                <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                    <i class="fa-brands fa-instagram"></i><span>destlounge</span>
                </a>
            </div>
        </div>
    </footer>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700&display=swap');

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Georgia', serif;
        background-color: #d4c4b0;
    }

    /* ── SIDEBAR ── */
    .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 10%;
        min-width: 9rem;
        height: 100vh;
        background-color: #e7dfd6;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.25rem 0;
        z-index: 1000;
    }

    .logo-container {
        margin-bottom: 2rem;
    }

    .sidebar-logo {
        width: 3.5rem;
        height: auto;
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        width: 100%;
    }

    .nav-item {
        color: #5a4a3a;
        text-decoration: none;
        padding: 1rem 0.625rem;
        font-size: 1rem;
        font-weight: 500;
        text-align: center;
        transition: background-color 0.3s;
        letter-spacing: 0.0625rem;
        display: block;
    }

        .nav-item:hover {
            background-color: rgba(90,74,58,0.1);
        }

        .nav-item.active {
            background-color: rgba(139,111,71,0.3);
            border-left: 0.25rem solid #8b6f47;
        }

    .sidebar-footer {
        margin-top: auto;
        padding: 1.25rem 0;
    }

    .admin-link {
        color: #5a4a3a;
        text-decoration: none;
        font-size: 0.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3125rem;
    }

        .admin-link i {
            font-size: 1.25rem;
        }

    /* ── MAIN ── */
    .main-content {
        margin-left: 10%;
        min-height: 100vh;
        background-color: #f5f0eb;
        display: flex;
        flex-direction: column;
    }

    .bookings-container {
        padding: 2.5rem 3rem;
        flex: 1;
    }

    .bookings-title {
        font-size: 2rem;
        font-weight: 700;
        color: #5a4a3a;
        margin-bottom: 0.3rem;
        letter-spacing: 0.5px;
    }

    .page-subtitle {
        font-size: 0.95rem;
        color: #8b6f47;
        margin-bottom: 2rem;
        font-style: italic;
    }

    /* ── FILTER BAR ── */
    .filter-bar-card {
        background-color: white;
        border-radius: 16px;
        border: 2px solid #d4c4b0;
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
        box-shadow: 2px 4px 10px rgba(0,0,0,0.06);
    }

    .filter-row-top {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .filter-row-bottom {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid #e7dfd6;
    }

    .filter-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: #8b6f47;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .filter-tabs {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .tab-btn {
        background-color: white;
        border: 2px solid #d4c4b0;
        color: #8b6f47;
        font-size: 0.85rem;
        font-weight: 600;
        padding: 0.45rem 1.1rem;
        cursor: pointer;
        transition: all 0.25s ease;
        border-radius: 25px;
        font-family: 'Georgia', serif;
        letter-spacing: 0.3px;
    }

        .tab-btn:hover {
            border-color: #6b4423;
            color: #6b4423;
        }

        .tab-btn.active {
            background-color: #6b4423;
            border-color: #6b4423;
            color: white;
            box-shadow: 0 4px 12px rgba(107,68,35,0.25);
        }

    .date-input {
        padding: 0.45rem 0.9rem;
        border: 2px solid #d4c4b0;
        border-radius: 25px;
        font-size: 0.85rem;
        color: #5a4a3a;
        font-family: 'Georgia', serif;
        background: white;
        outline: none;
        transition: border-color 0.2s;
    }

        .date-input:focus {
            border-color: #6b4423;
        }

    .apply-btn {
        background-color: #6b4423;
        color: white;
        border: none;
        padding: 0.45rem 1.1rem;
        border-radius: 25px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        font-family: 'Georgia', serif;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .apply-btn:hover:not(:disabled) {
            background-color: #5d3a1f;
        }

        .apply-btn:disabled {
            background-color: #c1b2a5;
            cursor: not-allowed;
        }

    /* ── KPI CARDS ── */
    .sales-kpis {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.25rem;
        margin-bottom: 2rem;
    }

    .kpi-card {
        background-color: #e7dfd6;
        border-radius: 16px;
        padding: 1.5rem 1.8rem;
        border: 2px solid #c1b2a5;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .kpi-card:hover {
            transform: translateY(-3px);
            box-shadow: 5px 6px 16px rgba(0,0,0,0.13);
        }

    .kpi-icon {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background-color: rgba(107,68,35,0.15);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.5rem;
    }

        .kpi-icon i {
            font-size: 1.1rem;
            color: #6b4423;
        }

    .kpi-title {
        color: #8b6f47;
        font-weight: 600;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }

    .kpi-value {
        font-size: 2rem;
        font-weight: 700;
        color: #6b4423;
        line-height: 1.1;
        font-family: 'Montserrat', sans-serif;
    }

    .kpi-value-range {
        font-size: 1.1rem;
        padding-top: 0.3rem;
        font-family: 'Montserrat', sans-serif;
    }

    /* ── CHART ── */
    .chart-wrap {
        background-color: white;
        border-radius: 16px;
        border: 2px solid #d4c4b0;
        padding: 2rem;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
        margin-bottom: 2rem;
    }

    .chart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .chart-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #3d2817;
    }

    .chart-sub {
        font-size: 0.82rem;
        color: #8b6f47;
        margin-top: 0.2rem;
    }

    .chart-canvas-wrap {
        position: relative;
        height: 300px;
    }

    /* ── SERVICE SECTION ── */
    .service-section {
        background-color: white;
        border-radius: 16px;
        border: 2px solid #d4c4b0;
        padding: 2rem;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
        margin-bottom: 2rem;
    }

    .section-header-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1.25rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e7dfd6;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #3d2817;
    }

    .section-sub {
        font-size: 0.82rem;
        color: #8b6f47;
        margin-top: 0.25rem;
    }

    /* ── SERVICE FILTER PILLS ── */
    .service-filter-bar {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1.25rem;
    }

    .svc-pill {
        background-color: white;
        border: 2px solid #d4c4b0;
        color: #8b6f47;
        font-size: 0.82rem;
        font-weight: 600;
        padding: 0.35rem 0.9rem;
        border-radius: 20px;
        cursor: pointer;
        font-family: 'Georgia', serif;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
    }

        .svc-pill:hover {
            border-color: #6b4423;
            color: #6b4423;
        }

        .svc-pill.active {
            background-color: #6b4423;
            border-color: #6b4423;
            color: white;
        }

    .pill-badge {
        font-size: 0.65rem;
        color: #d4a843;
    }

    .svc-pill.active .pill-badge {
        color: #ffe082;
    }

    /* ── SERVICE TABLE ── */
    .service-table-wrap {
        overflow-x: auto;
        border-radius: 10px;
        border: 1px solid #e7dfd6;
    }

    .service-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.88rem;
    }

        .service-table thead tr {
            background-color: #6b4423;
        }

        .service-table th {
            padding: 0.75rem 1rem;
            text-align: left;
            color: #fce8d5;
            font-weight: 600;
            font-size: 0.78rem;
            letter-spacing: 0.04em;
            white-space: nowrap;
