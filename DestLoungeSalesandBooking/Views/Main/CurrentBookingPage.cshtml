@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <a href="#" ng-click="toggleNotif()">
                    <i class="fa-solid fa-bell"></i> Notifications
                    <span ng-if="notifications.length > 0" class="mobile-notif-badge">{{notifications.length}}</span>
                </a>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <div class="bell-icon" ng-click="toggleNotif()" style="position: relative;">
                <i class="fa-solid fa-bell"></i>
                <span ng-if="notifications.length > 0"
                      style="position:absolute;top:-5px;right:-5px;background:red;color:white;border-radius:50%;padding:2px 6px;font-size:12px;">
                    {{notifications.length}}
                </span>
                <div ng-show="showNotif" class="notif-dropdown">
                    <h3>Notifications</h3>
                    <div ng-if="notifications.length === 0"><p>No notifications</p></div>
                    <div ng-repeat="n in notifications"
                         ng-click="goToBooking()"
                         style="cursor:pointer;padding:5px;border-bottom:1px solid #ccc;">
                        <p>{{n.Message}}</p>
                        <small>{{n.CreatedAt}}</small>
                    </div>
                </div>
            </div>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span><span></span><span></span>
        </button>
    </div>
    <div class="nav-overlay" id="navOverlay"></div>
</header>


<div class="profile-container">
    <aside class="sidebar">
        <nav class="profile-nav">
            <div class="nav-top">
                <a href="@Url.Action("ProfilePage","Main")" class="nav-item">Profile</a>
                <a href="@Url.Action("CurrentBookingPage","Main")" class="nav-item active">Current booking</a>
                <a href="@Url.Action("ReviewPage","Main")" class="nav-item">To Review</a>
            </div>
            <div class="nav-bottom">
                <a href="@Url.Action("Logout","Account")" class="nav-item nav-logout">
                    <i class="fa-solid fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </nav>
    </aside>

    <main class="profile-content"
          ng-controller="DestLoungeSalesandBookingController">

        <div class="booking-wrapper">
            <h2 class="booking-heading">My Bookings</h2>

            <!-- Loading state -->
            <div ng-if="bookingsLoading" class="loading-state">
                <p>Loading your bookings...</p>
            </div>

            <!-- Bookings list -->
            <div class="booking-grid" ng-if="!bookingsLoading && userBookings.length > 0">
                <div class="booking-item" ng-repeat="b in userBookings">

                    <div class="booking-top">
                        <span class="booking-date">{{formatBookingDate(b.BookingDate)}}</span>
                        <span class="booking-status" ng-class="b.Status.toLowerCase().trim()">
                            {{b.Status}}
                        </span>
                    </div>

                    <div class="booking-body">
                        <p><strong>Time:</strong> {{formatTime(b.StartTime)}} - {{formatTime(b.EndTime)}}</p>
                        <p><strong>Service:</strong> {{getService(b.Notes)}}</p>
                        <p ng-if="getNailTech(b.Notes)"><strong>Nail Tech:</strong> {{getNailTech(b.Notes)}}</p>
                        <p ng-if="getDownpayment(b.Notes)"><strong>Downpayment Paid:</strong> ₱{{getDownpayment(b.Notes)}}</p>
                        <p ng-if="getCancelReason(b.Notes)" class="cancel-reason">
                            <strong>Cancel Reason:</strong> {{getCancelReason(b.Notes)}}
                        </p>
                    </div>

                    <!-- Cancel button: only show if Pending or Approved AND more than 24hrs away -->
                    <div class="booking-actions" ng-if="b.Status.trim() == 'Pending' || b.Status.trim() == 'Approved'">
                        <div ng-if="canCancel(b)">
                            <button class="btn-cancel-booking"
                                    ng-click="cancelUserBooking(b.BookingId)">
                                <i class="fa-solid fa-xmark"></i> Cancel Booking
                            </button>
                        </div>
                        <div ng-if="!canCancel(b)" class="cancel-locked">
                            <i class="fa-solid fa-lock"></i> Cannot cancel — within 24 hours of appointment
                        </div>
                    </div>

                    <!-- Review button for completed bookings -->
                    <div class="booking-actions" ng-if="b.Status.trim() == 'Completed'">
                        <button class="btn-review" ng-click="goToReview(b.BookingId)">
                            <i class="fa-solid fa-star"></i> Leave a Review
                        </button>
                    </div>

                </div>
            </div>

            <!-- Empty state -->
            <div class="empty-state" ng-if="!bookingsLoading && userBookings.length === 0">
                <img src="https://cdn-icons-png.flaticon.com/512/4076/4076549.png"
                     alt="No bookings" class="empty-img" />
                <h3>No bookings yet</h3>
                <p>Looks like you haven't booked any service.</p>
                <a href="@Url.Action("ServicePage","Main")" class="btn-book-now">Book Now</a>
            </div>
        </div>

    </main>
</div>

<script>
    window.loggedInUserId = '@Session["UserID"]';
</script>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i><span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease,opacity 0.3s ease,width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    .mobile-notif-badge {
        background: red;
        color: white;
        border-radius: 50%;
        padding: 1px 6px;
        font-size: 11px;
        margin-left: 4px;
        vertical-align: middle;
    }

    /* ── Layout ── */
    .profile-container {
        display: flex;
        min-height: calc(100vh - 200px);
        background-color: #f5f0eb;
    }

    .sidebar {
        width: 280px;
        background-color: #d4c4b5;
        min-height: 100%;
    }

    .profile-nav {
        display: flex;
        flex-direction: column;
        padding-top: 40px;
        min-height: calc(90vh - 100px);
        justify-content: space-between;
    }

        .profile-nav .nav-item {
            padding: 20px 35px;
            color: #5a4a3a;
            text-decoration: none;
            font-size: 18px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            display: block;
        }

            .profile-nav .nav-item:hover, .profile-nav .nav-item.active {
                background-color: #c9b5a3;
                border-left-color: #6b5544;
            }

    .nav-logout {
        color: #a04040;
    }

    .profile-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 80px 40px;
    }

    /* ── Booking wrapper ── */
    .booking-wrapper {
        width: 100%;
        max-width: 900px;
    }

    .booking-heading {
        color: #6b5544;
        font-size: 32px;
        font-weight: 600;
        margin-bottom: 40px;
    }

    .booking-grid {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .loading-state {
        text-align: center;
        padding: 40px;
        color: #8a7060;
        font-size: 16px;
    }

    /* ── Booking card ── */
    .booking-item {
        background: #e8ddd1;
        padding: 24px;
        border-radius: 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        transition: transform 0.3s ease,box-shadow 0.3s ease;
    }

        .booking-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

    .booking-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 12px;
        border-bottom: 1px solid #c9b5a3;
    }

    .booking-date {
        font-weight: 600;
        color: #6b5544;
        font-size: 16px;
    }

    /* ── Status badges ── */
    .booking-status {
        padding: 5px 14px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .booking-status.pending {
            background: #c9b5a3;
            color: #5a4a3a;
        }

        .booking-status.approved {
            background: #8b6f47;
            color: white;
        }

        .booking-status.completed {
            background: #4a7c59;
            color: white;
        }

        .booking-status.cancelled {
            background: #b8423e;
            color: white;
        }

    /* ── Booking body ── */
    .booking-body {
        margin: 15px 0;
    }

        .booking-body p {
            margin: 8px 0;
            color: #5a4a3a;
            font-size: 14px;
            line-height: 1.6;
        }

        .booking-body strong {
            color: #6b5544;
            font-weight: 600;
        }

    .cancel-reason {
        color: #a04040 !important;
        font-style: italic;
    }

    /* ── Actions ── */
    .booking-actions {
        margin-top: 16px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-cancel-booking {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 10px 22px;
        background: #b8423e;
        color: white;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .btn-cancel-booking:hover {
            background: #9a3531;
            transform: translateY(-2px);
        }

    .cancel-locked {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 10px 16px;
        background: #ece4db;
        color: #8a7060;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        border: 1px dashed #c9b5a3;
    }

    .btn-review {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 10px 22px;
        background: #6b5544;
        color: white;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .btn-review:hover {
            background: #5a4635;
            transform: translateY(-2px);
        }

    /* ── Empty state ── */
    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: #e8ddd1;
        border-radius: 20px;
    }

    .empty-img {
        width: 120px;
        margin-bottom: 20px;
        opacity: 0.7;
    }

    .empty-state h3 {
        color: #6b5544;
        margin-bottom: 10px;
        font-size: 24px;
    }

    .empty-state p {
        color: #8b7b6b;
        margin-bottom: 20px;
        font-size: 16px;
    }

    .btn-book-now {
        display: inline-block;
        padding: 12px 30px;
        background-color: #6b5544;
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-book-now:hover {
            background-color: #5a4635;
            transform: translateY(-2px);
        }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* ── Responsive ── */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            gap: 2.5rem !important;
            transform: none !important;
            transition: none !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
            box-shadow: -4px 0 20px rgba(0,0,0,0.15) !important;
            transform: translateX(100%) !important;
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1) !important;
            overflow-y: auto !important;
        }

            .main-nav.open {
                transform: translateX(0) !important;
            }

            .main-nav a {
                width: 100% !important;
                padding: 0.9rem 0 !important;
                font-size: 1rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                display: block !important;
            }

        .mobile-nav-actions {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #d4c4b0;
        }

            .mobile-nav-actions a {
                display: flex !important;
                align-items: center;
                gap: 0.6rem;
                padding: 0.75rem 0 !important;
                font-size: 0.97rem !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                width: 100% !important;
                font-weight: 600 !important;
            }

        .profile-container {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            min-height: unset;
        }

        .profile-nav {
            flex-direction: row;
            min-height: unset;
            padding-top: 0;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            justify-content: flex-start;
        }

            .profile-nav .nav-top, .profile-nav .nav-bottom {
                display: flex;
                flex-direction: row;
            }

            .profile-nav .nav-item {
                white-space: nowrap;
                padding: 16px 24px;
                font-size: 15px;
                border-left: none;
                border-bottom: 4px solid transparent;
            }

                .profile-nav .nav-item:hover, .profile-nav .nav-item.active {
                    border-left-color: transparent;
                    border-bottom-color: #6b5544;
                }

        .profile-content {
            padding: 40px 24px;
        }
    }

    @@media (max-width: 768px) {
        .profile-content {
            padding: 28px 16px;
        }

        .booking-heading {
            font-size: 22px;
            margin-bottom: 20px;
        }

        .booking-item {
            padding: 16px;
            border-radius: 14px;
        }

        .booking-top {
            flex-direction: column;
            align-items: flex-start;
            gap: 8px;
        }

        .booking-actions {
            flex-direction: column;
        }

        .btn-cancel-booking, .btn-review {
            width: 100%;
            justify-content: center;
        }

        footer {
            padding: 1.5rem 1rem;
        }

        .footer-title {
            font-size: 1.5rem;
        }

        .social-links {
            gap: 1.5rem;
        }
    }
</style>

@section scripts {
    <script>
        (function () {
            var btn = document.getElementById('hamburgerBtn');
            var nav = document.getElementById('mainNav');
            var overlay = document.getElementById('navOverlay');
            function openMenu() { btn.classList.add('open'); nav.classList.add('open'); overlay.classList.add('active'); document.body.style.overflow = 'hidden'; }
            function closeMenu() { btn.classList.remove('open'); nav.classList.remove('open'); overlay.classList.remove('active'); document.body.style.overflow = ''; }
            btn.addEventListener('click', function () { nav.classList.contains('open') ? closeMenu() : openMenu(); });
            overlay.addEventListener('click', closeMenu);
            nav.querySelectorAll('a').forEach(function (l) { l.addEventListener('click', closeMenu); });
        })();
    </script>
}