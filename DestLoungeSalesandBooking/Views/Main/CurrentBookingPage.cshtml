            }

            .profile-nav .nav-item {
                white-space: nowrap;
                padding: 16px 24px;
                font-size: 15px;
                border-left: none;
                border-bottom: 4px solid transparent;
            }

                .profile-nav .nav-item:hover {
                    border-left-color: transparent;
                    border-bottom-color: #6b5544;
                }

                .profile-nav .nav-item.active {
                    border-left-color: transparent;
                    border-bottom-color: #6b5544;
                }

        .profile-content {
            padding: 40px 24px;
        }

        .booking-heading {
            font-size: 26px;
            margin-bottom: 28px;
        }
    }

    /* =============================================
       MOBILE (max-width: 768px)
    ============================================= */
    @@media (max-width: 768px) {
        .profile-nav .nav-item {
            padding: 14px 18px;
            font-size: 14px;
        }

        .profile-content {
            padding: 28px 16px;
        }

        .booking-wrapper {
            max-width: 100%;
        }

        .booking-heading {
            font-size: 22px;
            margin-bottom: 20px;
        }

        .booking-item {
