@section scripts {
    <script>
        (function () {
            var btn = document.getElementById('hamburgerBtn');
            var nav = document.getElementById('mainNav');
            var overlay = document.getElementById('navOverlay');

            function openMenu() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeMenu() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', function () {
                nav.classList.contains('open') ? closeMenu() : openMenu();
            });

            overlay.addEventListener('click', closeMenu);

            nav.querySelectorAll('a').forEach(function (l) {
                l.addEventListener('click', closeMenu);
            });
        })();

        // ✅ Add receipt modal functions to Angular scope
        document.addEventListener('DOMContentLoaded', function () {
            var rootScope = angular.element(document.querySelector('[ng-controller="DestLoungeSalesandBookingController"]')).scope();
            if (rootScope) {
                rootScope.receiptModal = { show: false, imageUrl: '' };

                rootScope.openReceiptModal = function (imageUrl) {
                    rootScope.receiptModal = { show: true, imageUrl: imageUrl };
                    rootScope.$apply();
                };

                rootScope.closeReceiptModal = function ($event) {
                    if (!$event || $event.target === $event.currentTarget) {
                        rootScope.receiptModal = { show: false, imageUrl: '' };
                        rootScope.$apply();
                    }
                };

                rootScope.extractReceiptUrl = function (notes) {
                    if (!notes) return null;
                    var match = notes.match(/Receipt:\s*([^\|]+)/i);
                    return match ? match[1].trim() : null;
                };
            }
        });
    </script>
}