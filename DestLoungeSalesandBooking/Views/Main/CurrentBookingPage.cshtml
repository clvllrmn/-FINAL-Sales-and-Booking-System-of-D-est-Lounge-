@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header ng-controller="DestLoungeSalesandBookingController"
        ng-init="loadNotifications()">
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }

                <button type="button"
                        ng-click="toggleNotif($event)"
                        style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                    <i class="fa-solid fa-bell"></i>

                    <span ng-if="notifications.length > 0"
                          style="position:absolute; top:-8px; right:-10px; background:red; color:white; border-radius:50%; padding:2px 6px; font-size:11px;">
                        {{notifications.length}}
                    </span>
                </button>

                <div ng-show="showNotif"
                     style="position:absolute; right:0; top:35px; width:260px; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999;">
                    <div style="padding:10px; font-weight:bold; border-bottom:1px solid #eee;">
                        Notifications
                    </div>

                    <div ng-if="!notifications.length" style="padding:10px;">
                        No notifications
                    </div>

                    <div ng-repeat="n in notifications"
                         style="padding:10px; border-bottom:1px solid #eee; cursor:pointer;"
                         ng-click="goToBooking()">
                        {{n.Message || n.message}}
                    </div>
                </div>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }

            <button type="button"
                    ng-click="toggleNotif($event)"
                    style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                <i class="fa-solid fa-bell"></i>

                <span ng-if="notifications.length > 0"
                      style="position:absolute; top:-8px; right:-10px; background:red; color:white; border-radius:50%; padding:2px 6px; font-size:11px;">
                    {{notifications.length}}
                </span>
            </button>

            <div ng-show="showNotif"
                 style="position:absolute; right:0; top:35px; width:260px; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999;">
                <div style="padding:10px; font-weight:bold; border-bottom:1px solid #eee;">
                    Notifications
                </div>

                <div ng-if="!notifications.length" style="padding:10px;">
                    No notifications
                </div>

                <div ng-repeat="n in notifications"
                     style="padding:10px; border-bottom:1px solid #eee; cursor:pointer;"
                     ng-click="goToBooking()">
                    {{n.Message || n.message}}
                </div>
            </div>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div class="profile-container">
    <aside class="sidebar">
        <nav class="profile-nav">
            <div class="nav-top">
                <a href="@Url.Action("ProfilePage","Main")" class="nav-item">Profile</a>
                <a href="@Url.Action("CurrentBookingPage","Main")" class="nav-item active">Current booking</a>
                <a href="@Url.Action("ReviewPage","Main")" class="nav-item">To Review</a>
            </div>
        </nav>
    </aside>

    <main class="profile-content"
          ng-controller="DestLoungeSalesandBookingController">

        <div class="booking-wrapper">
            <h2 class="booking-heading">My Bookings</h2>

            <div ng-if="bookingsLoading" class="loading-state">
                <p>Loading your bookings...</p>
            </div>

            <!-- CURRENT BOOKINGS -->
            <div class="booking-section" ng-if="!bookingsLoading">
                <h3 class="booking-section-title">Current Bookings</h3>

                <div class="booking-grid" ng-if="currentBookings.length > 0">
                    <div class="booking-item" ng-repeat="b in currentBookings">

                        <!-- ✅ REFERENCE NUMBER - TOP OF CARD -->
                        <div class="booking-ref-header">
                            <i class="fa-solid fa-ticket"></i>
                            <strong>Ref No:</strong> {{b.referenceNo || 'REF-' + b.bookingId}}
                        </div>

                        <div class="booking-top">
                            <span class="booking-date">{{formatBookingDate(b.bookingDate)}}</span>
                            <span class="booking-status" ng-class="(b.status || '').toLowerCase().trim()">
                                {{b.status}}
                            </span>
                        </div>

                        <div class="booking-body">
                            <p><strong>Time:</strong> {{ formatTime(b.startTime) }} - {{ formatTime(b.endTime) }}</p>
                            <p><strong>Service:</strong> {{extractServices(b.notes)}}</p>
                            <p><strong>Nail Tech:</strong> {{b.nailTech || 'Not assigned'}}</p>

                            <!-- ✅ TOTAL BILL WITH 2 DECIMAL PLACES -->
                            <p><strong>Total Bill:</strong> ₱{{(b.totalBill || 0) | number:2}}</p>

                            <!-- ✅ DOWNPAYMENT WITH 2 DECIMAL PLACES -->
                            <p><strong>Downpayment Paid:</strong> ₱{{((b.totalBill || 0) * 0.4) | number:2}}</p>

                            <!-- ✅ PROOF OF PAYMENT / RECEIPT -->
                            <div ng-if="b.receiptUrl" class="receipt-section">
                                <strong>Proof of Payment:</strong><br>
                                <img ng-src="{{b.receiptUrl}}" class="receipt-thumb"
                                     alt="Payment Receipt"
                                     ng-click="openReceiptModal(b.receiptUrl)" />
                            </div>

                            <!-- Fallback: Check notes for receipt path -->
                            <div ng-if="!b.receiptUrl && extractReceiptUrl(b.notes)" class="receipt-section">
                                <strong>Proof of Payment:</strong><br>
                                <img ng-src="{{extractReceiptUrl(b.notes)}}" class="receipt-thumb"
                                     alt="Payment Receipt"
                                     ng-click="openReceiptModal(extractReceiptUrl(b.notes))" />
                            </div>
                        </div>

                        <div class="booking-actions" ng-if="b.status.trim() == 'Pending' || b.status.trim() == 'Approved'">
                            <div ng-if="canCancelBookingByValues(b.bookingDate, b.startTime)">
                                <button class="btn-cancel-booking"
                                        ng-click="cancelUserBooking(b.bookingId, b.referenceNo)">
                                    <i class="fa-solid fa-xmark"></i> Cancel Booking
                                </button>
                            </div>
                            <div ng-if="!canCancelBookingByValues(b.bookingDate, b.startTime)" class="cancel-locked">
                                <i class="fa-solid fa-lock"></i> Cannot cancel — within 24 hours of appointment
                            </div>
                        </div>

                    </div>
                </div>

                <div class="empty-state small-empty" ng-if="currentBookings.length === 0">
                    <h3>No current bookings</h3>
                    <p>You do not have any upcoming bookings right now.</p>
                </div>
            </div>

            <!-- BOOKING HISTORY -->
            <div class="booking-section history-section" ng-if="!bookingsLoading">
                <h3 class="booking-section-title">Booking History</h3>

                <div class="booking-grid" ng-if="bookingHistory.length > 0">
                    <div class="booking-item" ng-repeat="b in bookingHistory">

                        <!-- ✅ REFERENCE NUMBER - TOP OF CARD -->
                        <div class="booking-ref-header">
                            <i class="fa-solid fa-ticket"></i>
                            <strong>Ref No:</strong> {{b.referenceNo || 'REF-' + b.bookingId}}
                        </div>

                        <div class="booking-top">
                            <span class="booking-date">{{formatBookingDate(b.bookingDate)}}</span>
                            <span class="booking-status" ng-class="(b.status || '').toLowerCase().trim()">
                                {{b.status}}
                            </span>
                        </div>

                        <div class="booking-body">
                            <p><strong>Time:</strong> {{formatTime(b.startTime)}} - {{formatTime(b.endTime)}}</p>
                            <p><strong>Service:</strong> {{extractServices(b.notes)}}</p>
                            <p><strong>Nail Tech:</strong> {{b.nailTech || 'Not assigned'}}</p>

                            <!-- ✅ TOTAL BILL WITH 2 DECIMAL PLACES -->
                            <p><strong>Total Bill:</strong> ₱{{(b.totalBill || 0) | number:2}}</p>

                            <!-- ✅ DOWNPAYMENT WITH 2 DECIMAL PLACES -->
                            <p><strong>Downpayment Paid:</strong> ₱{{((b.totalBill || 0) * 0.4) | number:2}}</p>

                            <!-- ✅ PROOF OF PAYMENT / RECEIPT -->
                            <div ng-if="b.receiptUrl" class="receipt-section">
                                <strong>Proof of Payment:</strong><br>
                                <img ng-src="{{b.receiptUrl}}" class="receipt-thumb"
                                     alt="Payment Receipt"
                                     ng-click="openReceiptModal(b.receiptUrl)" />
                            </div>

                            <!-- Fallback: Check notes for receipt path -->
                            <div ng-if="!b.receiptUrl && extractReceiptUrl(b.notes)" class="receipt-section">
                                <strong>Proof of Payment:</strong><br>
                                <img ng-src="{{extractReceiptUrl(b.notes)}}" class="receipt-thumb"
                                     alt="Payment Receipt"
                                     ng-click="openReceiptModal(extractReceiptUrl(b.notes))" />
                            </div>
                        </div>

                    </div>
                </div>

                <div class="empty-state small-empty" ng-if="bookingHistory.length === 0">
                    <h3>No booking history yet</h3>
                    <p>Your past bookings will appear here.</p>
                </div>
            </div>
        </div>

    </main>
</div>

<!-- ✅ RECEIPT MODAL (Lightbox for viewing receipt) -->
<div class="receipt-modal" ng-if="receiptModal.show" ng-click="closeReceiptModal($event)">
    <div class="receipt-modal-content">
        <span class="receipt-modal-close" ng-click="closeReceiptModal()">&times;</span>
        <img ng-src="{{receiptModal.imageUrl}}" alt="Receipt Full Size" class="receipt-full" />
    </div>
</div>

<script>
    window.loggedInUserId = '@Session["UserID"]';
</script>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i><span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ✅ REFERENCE NUMBER HEADER STYLES */
    .booking-ref-header {
        background: #f0e8e0;
        padding: 8px 12px;
        border-radius: 8px;
        margin-bottom: 12px;
        font-size: 14px;
        color: #6b5544;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .booking-ref-header i {
            color: #8b6f47;
        }

    /* ✅ RECEIPT THUMBNAIL STYLES */
    .receipt-section {
        margin-top: 12px;
        padding-top: 8px;
        border-top: 1px dashed #c9b5a3;
    }

    .receipt-thumb {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.2s ease;
        border: 1px solid #c9b5a3;
        margin-top: 5px;
    }

        .receipt-thumb:hover {
            transform: scale(1.05);
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }

    /* ✅ RECEIPT MODAL STYLES */
    .receipt-modal {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.9);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    .receipt-modal-content {
        position: relative;
        max-width: 90%;
        max-height: 90%;
        cursor: default;
    }

    .receipt-modal-close {
        position: absolute;
        top: -40px;
        right: 0;
        color: white;
        font-size: 35px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

        .receipt-modal-close:hover {
            color: #bbb;
        }

    .receipt-full {
        max-width: 100%;
        max-height: 90vh;
        object-fit: contain;
        border-radius: 8px;
    }

    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    .mobile-notif-badge {
        background: red;
        color: white;
        border-radius: 50%;
        padding: 1px 6px;
        font-size: 11px;
        margin-left: 4px;
        vertical-align: middle;
    }

    .profile-container {
        display: flex;
        min-height: calc(100vh - 200px);
        background-color: #f5f0eb;
    }

    .sidebar {
        width: 280px;
        background-color: #d4c4b5;
        display: flex;
        flex-direction: column;
    }

    .profile-nav {
        display: flex;
        flex-direction: column;
        padding-top: 40px;
        flex: 1;
        justify-content: space-between;
    }

        .profile-nav .nav-item {
            padding: 20px 35px;
            color: #5a4a3a;
            text-decoration: none;
            font-size: 18px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            display: block;
        }

            .profile-nav .nav-item:hover,
            .profile-nav .nav-item.active {
                background-color: #c9b5a3;
                border-left-color: #6b5544;
            }

    .nav-logout {
        color: #a04040;
    }

    .profile-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 80px 40px;
    }

    .booking-wrapper {
        width: 100%;
        max-width: 900px;
    }

    .booking-heading {
        color: #6b5544;
        font-size: 32px;
        font-weight: 600;
        margin-bottom: 40px;
    }

    .booking-grid {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .loading-state {
        text-align: center;
        padding: 40px;
        color: #8a7060;
        font-size: 16px;
    }

    .booking-item {
        background: #e8ddd1;
        padding: 24px;
        border-radius: 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .booking-item:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        }

    .booking-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 12px;
        border-bottom: 1px solid #c9b5a3;
    }

    .booking-date {
        font-weight: 600;
        color: #6b5544;
        font-size: 16px;
    }

    .booking-section {
        margin-bottom: 40px;
    }

    .booking-section-title {
        color: #6b5544;
        font-size: 24px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .history-section {
        margin-top: 10px;
    }

    .small-empty {
        padding: 35px 20px;
    }

    .booking-status {
        padding: 5px 14px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

        .booking-status.pending {
            background: #c9b5a3;
            color: #5a4a3a;
        }

        .booking-status.approved {
            background: #8b6f47;
            color: white;
        }

        .booking-status.completed {
            background: #4a7c59;
            color: white;
        }

        .booking-status.cancelled {
            background: #b8423e;
            color: white;
        }

    .booking-body {
        margin: 15px 0;
    }

        .booking-body p {
            margin: 8px 0;
            color: #5a4a3a;
            font-size: 14px;
            line-height: 1.6;
        }

        .booking-body strong {
            color: #6b5544;
            font-weight: 600;
        }

    .cancel-reason {
        color: #a04040 !important;
        font-style: italic;
    }

    .booking-actions {
        margin-top: 16px;
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .btn-cancel-booking {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 10px 22px;
        background: #b8423e;
        color: white;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .btn-cancel-booking:hover {
            background: #9a3531;
            transform: translateY(-2px);
        }

    .cancel-locked {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 10px 16px;
        background: #ece4db;
        color: #8a7060;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        border: 1px dashed #c9b5a3;
    }

    .btn-review {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 10px 22px;
        background: #6b5544;
        color: white;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.3s ease;
    }

        .btn-review:hover {
            background: #5a4635;
            transform: translateY(-2px);
        }

        .btn-review:disabled {
            background: #b7a99a;
            cursor: not-allowed;
            opacity: 0.8;
            transform: none;
        }

            .btn-review:disabled:hover {
                background: #b7a99a;
                transform: none;
            }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
        background: #e8ddd1;
        border-radius: 20px;
    }

    .empty-img {
        width: 120px;
        margin-bottom: 20px;
        opacity: 0.7;
    }

    .empty-state h3 {
        color: #6b5544;
        margin-bottom: 10px;
        font-size: 24px;
    }

    .empty-state p {
        color: #8b7b6b;
        margin-bottom: 20px;
        font-size: 16px;
    }

    .btn-book-now {
        display: inline-block;
        padding: 12px 30px;
        background-color: #6b5544;
        color: white;
        text-decoration: none;
        border-radius: 25px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-book-now:hover {
            background-color: #5a4635;
            transform: translateY(-2px);
        }

    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
