                }
        /* Sidebar becomes horizontal tab bar on tablet */
        .profile-container {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            min-height: unset;
        }

        .profile-nav {
            flex-direction: row;
            min-height: unset;
            padding-top: 0;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            justify-content: flex-start;
            white-space: nowrap;
        }

            .profile-nav .nav-top,
            .profile-nav .nav-bottom {
