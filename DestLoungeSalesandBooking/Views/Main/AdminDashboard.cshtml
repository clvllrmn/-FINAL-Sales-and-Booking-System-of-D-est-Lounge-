@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@Html.AntiForgeryToken()

<div ng-app="DestLoungeSalesandBooking" ng-controller="DestLoungeSalesandBookingController">

    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="logo-container">
            <a href="@Url.Action("AdminHomepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminDashboard","Main")" class="nav-item active">DASHBOARD</a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Mobile Top Bar -->
    <div class="mobile-topbar">
        <a href="@Url.Action("AdminDashboard","Main")">
            <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
        </a>
        <button class="mobile-menu-btn" onclick="toggleMobileNav()">
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>

    <div class="mobile-nav-overlay" id="mobileOverlay" onclick="toggleMobileNav()"></div>

    <div class="mobile-nav-drawer" id="mobileDrawer">
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminDashboard","Main")" class="nav-item active">DASHBOARD</a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <script>
        window.isAdminPage = true;
    </script>

    <!-- Main Content -->
    <div class="main-content">

        <!-- Dashboard Header -->
        <div class="dashboard-header">
            <h1 class="dashboard-title">DASHBOARD</h1>
        </div>

        <!-- Top Tabs -->
        <div class="tab-bar">
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'analytics'}" ng-click="dashTab = 'analytics'">Analytics</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'bookings'}" ng-click="dashTab = 'bookings'; loadBookings()">Manage Booking</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'staffs'}" ng-click="dashTab = 'staffs'; loadTechs()">Manage Staffs</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'gallery'}" ng-click="dashTab = 'gallery'; loadGalleryPhotos(); loadReviews(); loadArchivedReviews()">Gallery</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'services'}" ng-click="dashTab = 'services'; loadServices()">Services</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'faqs'}" ng-click="dashTab = 'faqs'; loadFAQs()">FAQs</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'contact'}" ng-click="dashTab = 'contact'; loadContactInfo()">Contact</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'homepage'}" ng-click="dashTab = 'homepage'">Homepage</button>
            <button class="tab-btn" ng-class="{'tab-active': dashTab === 'payment'}" ng-click="dashTab = 'payment'; loadPaymentInfo()">Payment</button>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: ANALYTICS -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'analytics'">
            <h2 class="section-title">Salon's Analytics</h2>

            <div class="analytics-top-row">
                <!-- Chart Card -->
                <div class="analytics-chart-card">
                    <div class="chart-header">
                        <span class="chart-title">Bookings Overview</span>
                        <select class="admin-select" ng-model="analyticsFilter" ng-change="loadAnalytics()">
                            <option value="week">This Week</option>
                            <option value="month">This Month</option>
                            <option value="year">This Year</option>
                        </select>
                    </div>
                    <canvas id="analyticsChart" height="180"></canvas>
                    <button class="admin-btn admin-btn-primary" style="margin-top:1rem;" ng-click="generateReport()">
                        <i class="fa-solid fa-file-export"></i> Generate Report
                    </button>
                </div>

                <!-- Stat Cards -->
                <div class="analytics-stats-col">
                    <div class="stat-card">
                        <div class="stat-icon"><i class="fa-solid fa-calendar-check"></i></div>
                        <div class="stat-info">
                            <span class="stat-label">Active Pending Approvals</span>
                            <span class="stat-num">{{pendingBookingsCount || 0}}</span>
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-icon stat-icon-star"><i class="fa-solid fa-star"></i></div>
                        <div class="stat-info">
                            <span class="stat-label">Active Reviews</span>
                            <span class="stat-num">{{reviews.length || 0}}</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="analytics-section-card" ng-if="flaggedCount() > 0">
                <div class="analytics-section-header" style="color:#e67e22;">
                    <span><i class="fa-solid fa-flag"></i> Flagged Reviews Need Attention</span>
                    <a href="#" ng-click="dashTab = 'gallery'; adminTab = 'reviews'"
                       class="admin-btn admin-btn-flag admin-btn-sm">
                        Review Now
                    </a>
                </div>
                <div class="mini-review-list">
                    <div class="mini-review-row flagged-row"
                         ng-repeat="review in reviews | filter:{flagged: true} | limitTo:3">
                        <span class="mini-review-text">{{review.reviewText | limitTo:60}}...</span>
                        <span style="font-size:0.75rem; color:#e67e22;">{{review.flagReason}}</span>
                    </div>
                </div>
            </div>
            <!-- Manage Active Reviews (inline) -->
            <div class="analytics-section-card">
                <div class="analytics-section-header">
                    <span>Manage Active Reviews</span>
                </div>
                <div class="mini-review-list">
                    <div class="mini-review-row" ng-repeat="review in reviews | limitTo:5" ng-class="{'flagged-row': review.flagged}">
                        <span class="mini-review-text">{{review.reviewText | limitTo:40}}...</span>
                        <div class="mini-review-actions">
                            <button class="mini-btn mini-btn-flag" ng-show="!review.flagged" ng-click="openFlagModal(review)">Flag</button>
                            <button class="mini-btn mini-btn-unflag" ng-show="review.flagged" ng-click="unflagReview(review)">Unflag</button>
                            <button class="mini-btn mini-btn-archive" ng-click="archiveReview(review.reviewId)">Archive</button>
                        </div>
                    </div>
                    <div ng-if="reviews.length === 0" class="empty-mini">No active reviews.</div>
                </div>
            </div>

            <div class="analytics-section-card">
                <div class="analytics-section-header">
                    <span>Recent Bookings</span>
                    <a href="#" ng-click="dashTab = 'bookings'; loadBookings()"
                       class="admin-btn admin-btn-primary admin-btn-sm">
                        View All
                    </a>
                </div>
                <div ng-repeat="booking in bookings | limitTo:5" class="mini-booking-card">
                    <div class="mini-booking-row">
                        <i class="fa-solid fa-user"></i>
                        <span><strong>{{booking.clientName}}</strong> — {{booking.service}}</span>
                    </div>
                    <div class="mini-booking-row">
                        <i class="fa-solid fa-calendar"></i>
                        <span>{{booking.dateTime}}</span>
                        <span class="bk-pill" ng-class="{
                'bk-pill-pending': booking.status === 'Pending',
                'bk-pill-approved': booking.status === 'Approved',
                'bk-pill-completed': booking.status === 'Completed',
                'bk-pill-cancelled': booking.status === 'Cancelled'
            }">{{booking.status}}</span>
                    </div>
                </div>
                <div ng-if="bookings.length === 0" class="empty-mini">No bookings yet.</div>
            </div>
        </div>
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: MANAGE BOOKINGS -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'bookings'">
            <h2 class="section-title">Manage Bookings</h2>

            <div class="filter-tabs">
                <button class="tab-btn" ng-class="{'active': selectedFilter === 'all'}" ng-click="filterBookings('all')">All Bookings</button>
                <button class="tab-btn" ng-class="{'active': selectedFilter === 'today'}" ng-click="filterBookings('today')">Today</button>
                <button class="tab-btn" ng-class="{'active': selectedFilter === 'upcoming'}" ng-click="filterBookings('upcoming')">Upcoming</button>
                <button class="tab-btn" ng-class="{'active': selectedFilter === 'pending'}" ng-click="filterBookings('pending')">For Approval</button>
                <button class="tab-btn" ng-class="{'active': selectedFilter === 'completed'}" ng-click="filterBookings('completed')">Completed</button>
                <button class="tab-btn" ng-class="{'active': selectedFilter === 'cancelled'}" ng-click="filterBookings('cancelled')">Cancelled</button>
            </div>

            <div class="bookings-table-wrap">
                <table class="bookings-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Client</th>
                            <th>Service</th>
                            <th>Date / Time</th>
                            <th>Nail Tech</th>
                            <th>Total Bill</th>
                            <th>Downpayment</th>
                            <th>Ref No.</th>
                            <th>Status</th>
                            <th>Receipt</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr ng-repeat="booking in pagedBookings track by booking.bookingId">
                            <td class="cell-num">{{(bookingsCurrentPage - 1) * bookingsPageSize + $index + 1}}</td>
                            <td><strong class="cell-client">{{booking.clientName}}</strong></td>
                            <td>{{booking.service}}</td>
                            <td class="cell-date">{{booking.dateTime}}</td>
                            <td class="cell-sm" ng-init="n = parseNotes(booking.notes)">{{n.nailtech || 'N/A'}}</td>
                            <td>₱{{booking.totalBill | number:2}}</td>
                            <td class="cell-down">₱{{booking.downpayment | number:2}}</td>
                            <td class="cell-sm">{{booking.referenceNo || '—'}}</td>
                            <td>
                                <span class="bk-pill"
                                      ng-class="{
                                'bk-pill-pending':   booking.status === 'Pending',
                                'bk-pill-approved':  booking.status === 'Approved',
                                'bk-pill-completed': booking.status === 'Completed',
                                'bk-pill-cancelled': booking.status === 'Cancelled'
                              }">
                                    {{booking.status}}
                                </span>
                                <span class="bk-cancel-reason"
                                      ng-if="booking.status === 'Cancelled' && booking.cancelReason">
                                    {{booking.cancelReason}}
                                </span>
                            </td>
                            <td>
                                <img ng-if="booking.receiptPath"
                                     ng-src="{{booking.receiptPath}}"
                                     class="bk-receipt-thumb clickable-review-image"
                                     ng-click="openReviewLightbox(booking.receiptPath); $event.stopPropagation();"
                                     alt="Receipt" />
                                <span ng-if="!booking.receiptPath" class="cell-muted">—</span>
                            </td>
                            <td>
                                <div ng-if="booking.status === 'Pending'" class="bk-action-group">
                                    <button class="bk-btn bk-btn-approve"
                                            ng-click="updateBookingStatus(booking.bookingId, 'Approved')">
                                        Approve
                                    </button>
                                    <button class="bk-btn bk-btn-cancel"
                                            ng-click="cancelBooking(booking.bookingId, $event)">
                                        Cancel
                                    </button>
                                </div>
                                <div ng-if="booking.status === 'Approved'" class="bk-action-group">
                                    <button class="bk-btn bk-btn-complete"
                                            ng-click="updateBookingStatus(booking.bookingId, 'Completed')">
                                        Complete
                                    </button>
                                    <button class="bk-btn bk-btn-cancel"
                                            ng-click="cancelBooking(booking.bookingId, $event)">
                                        Cancel
                                    </button>
                                </div>
                                <span ng-if="booking.status === 'Completed' || booking.status === 'Cancelled'"
                                      class="cell-muted">—</span>
                            </td>
                        </tr>
                        <tr ng-if="pagedBookings.length === 0">
                            <td colspan="11" class="bk-empty">No bookings found.</td>
                        </tr>
                    </tbody>
                </table>

                <!-- Pagination -->
                <div class="bk-pagination" ng-if="filteredBookings.length > 0">
                    <span class="bk-pg-info">
                        Showing {{(bookingsCurrentPage - 1) * bookingsPageSize + 1}}–{{bookingsCurrentPage * bookingsPageSize > filteredBookings.length ? filteredBookings.length : bookingsCurrentPage * bookingsPageSize}} of {{filteredBookings.length}}
                    </span>
                    <div class="bk-pg-btns">
                        <button class="bk-pg-btn"
                                ng-click="bookingsGoPage(bookingsCurrentPage - 1)"
                                ng-disabled="bookingsCurrentPage === 1">
                            &#8249;
                        </button>
                        <button class="bk-pg-btn"
                                ng-repeat="p in bookingsPageNumbers"
                                ng-class="{'bk-pg-active': p === bookingsCurrentPage}"
                                ng-click="bookingsGoPage(p)">
                            {{p}}
                        </button>
                        <button class="bk-pg-btn"
                                ng-click="bookingsGoPage(bookingsCurrentPage + 1)"
                                ng-disabled="bookingsCurrentPage === bookingsTotalPages">
                            &#8250;
                        </button>
                    </div>
                    <select class="bk-pg-size admin-select"
                            ng-model="bookingsPageSize"
                            ng-change="bookingsOnPageSizeChange()">
                        <option value="8">8 / page</option>
                        <option value="15">15 / page</option>
                        <option value="25">25 / page</option>
                        <option value="50">50 / page</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: MANAGE STAFFS -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'staffs'" ng-controller="NailTechController">
            <div class="page-header-row">
                <h2 class="section-title">Nail Techs</h2>
                <button class="add-btn" ng-click="openModal()"><i class="fa-solid fa-plus"></i> Add Nail Tech</button>
            </div>
            <div class="stats-bar-row">
                <div class="stat-pill stat-pill-active"><i class="fa-solid fa-users"></i> <strong>{{activeTechs.length}}</strong> Active</div>
                <div class="stat-pill stat-pill-inactive"><i class="fa-solid fa-user-slash"></i> <strong>{{inactiveTechs.length}}</strong> Inactive</div>
            </div>
            <div class="section-label-small" ng-if="activeTechs.length > 0"><i class="fa-solid fa-circle-check"></i> Active Staff</div>
            <div class="nailtech-grid">
                <div class="nailtech-card" ng-repeat="tech in activeTechs">
                    <div class="card-avatar">
                        <div class="avatar-initials">{{getInitials(tech.name)}}</div>
                        <div class="status-dot status-dot-active"></div>
                    </div>
                    <div class="card-info">
                        <h3 class="card-name">{{tech.name}}</h3>
                        <span class="card-role">{{tech.specialization || 'Nail Technician'}}</span>
                        <div class="card-meta" ng-if="tech.contact"><i class="fa-solid fa-phone"></i> {{tech.contact}}</div>
                    </div>
                    <div class="card-actions-row">
                        <button class="card-btn card-btn-edit" ng-click="openEditModal(tech)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                        <button class="card-btn card-btn-deactivate" ng-click="deactivateTech(tech)" title="Deactivate"><i class="fa-solid fa-user-slash"></i></button>
                        <button class="card-btn card-btn-delete" ng-click="deleteTech(tech)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                    </div>
                </div>
                <div ng-if="activeTechs.length === 0" class="nailtech-empty"><i class="fa-solid fa-scissors"></i><p>No active nail techs yet.</p></div>
            </div>
            <div class="inactive-section" ng-if="inactiveTechs.length > 0">
                <button class="inactive-toggle-btn" ng-click="showInactive = !showInactive">
                    <i class="fa-solid fa-user-slash"></i>
                    {{ showInactive ? 'Hide Inactive Staff' : 'View Inactive Staff' }}
                    <span class="inactive-count">{{inactiveTechs.length}}</span>
                </button>
                <div class="inactive-panel" ng-show="showInactive">
                    <h3 class="inactive-panel-title">Inactive / Former Nail Techs</h3>
                    <div class="inactive-card" ng-repeat="tech in inactiveTechs">
                        <div class="inactive-avatar">
                            <div class="avatar-initials avatar-initials-sm">{{getInitials(tech.name)}}</div>
                            <div class="status-dot status-dot-inactive"></div>
                        </div>
                        <div class="inactive-info">
                            <h3>{{tech.name}}</h3>
                            <p>{{tech.specialization || 'Nail Technician'}} <span ng-if="tech.contact"> &bull; {{tech.contact}}</span></p>
                        </div>
                        <div class="inactive-actions">
                            <button class="restore-btn" ng-click="reactivateTech(tech)"><i class="fa-solid fa-rotate-left"></i> Reactivate</button>
                            <button class="perm-delete-btn" ng-click="permanentDeleteTech(tech)"><i class="fa-solid fa-trash"></i> Remove</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Nail Tech Add/Edit Modal -->
            <div class="modal-backdrop" ng-show="showModal" ng-click="closeModalBackdrop($event)">
                <div class="modal-box" ng-click="$event.stopPropagation()">
                    <div class="modal-hdr">
                        <div class="modal-hdr-left">
                            <div class="modal-ico"><i class="fa-solid fa-scissors"></i></div>
                            <div>
                                <span class="modal-ttl">{{ editingTech ? 'Edit Nail Tech' : 'Add New Nail Tech' }}</span>
                                <div class="modal-sub">Manage your nail technician roster</div>
                            </div>
                        </div>
                        <button class="modal-cls" ng-click="closeModal()">&#10005;</button>
                    </div>
                    <div class="modal-bdy">
                        <div class="field-row">
                            <div class="field-grp field-grp-full">
                                <label class="field-lbl">Full Name <span class="required">*</span></label>
                                <input class="field-inp" type="text" ng-model="techForm.name" placeholder="e.g. Maria Santos" />
                            </div>
                        </div>
                        <div class="field-row">
                            <div class="field-grp">
                                <label class="field-lbl">Specialization</label>
                                <input class="field-inp" type="text" ng-model="techForm.specialization" placeholder="e.g. Gel Nails" />
                            </div>
                            <div class="field-grp">
                                <label class="field-lbl">Contact Number</label>
                                <input class="field-inp" type="text" ng-model="techForm.contact" placeholder="e.g. 09XX XXX XXXX" />
                            </div>
                        </div>
                        <div class="field-row">
                            <div class="field-grp">
                                <label class="field-lbl">Status</label>
                                <select class="field-inp field-sel" ng-model="techForm.status">
                                    <option value="active">Active</option>
                                    <option value="inactive">Inactive</option>
                                </select>
                            </div>
                        </div>
                        <div class="field-grp field-grp-full">
                            <label class="field-lbl">Notes</label>
                            <textarea class="field-inp field-ta" ng-model="techForm.notes" placeholder="Additional notes..." rows="3"></textarea>
                        </div>
                        <div class="modal-preview-box" ng-if="techForm.name">
                            <div class="preview-lbl">Preview</div>
                            <div class="preview-card-inner">
                                <div class="preview-avatar"><div class="avatar-initials">{{getInitials(techForm.name)}}</div></div>
                                <div class="preview-info"><strong>{{techForm.name}}</strong><span>{{techForm.specialization || 'Nail Technician'}}</span></div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-ftr">
                        <button class="btn-cancel" ng-click="closeModal()">Cancel</button>
                        <button class="btn-save" ng-click="saveTech()" ng-disabled="!techForm.name">{{ editingTech ? 'Save Changes' : 'Add Nail Tech' }}</button>
                    </div>
                </div>
            </div>

            <!-- Confirm Modal -->
            <div class="modal-backdrop modal-backdrop-confirm" ng-show="showConfirmModal" ng-click="closeConfirmModal()">
                <div class="confirm-modal-box" ng-click="$event.stopPropagation()">
                    <div class="confirm-ico"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    <h3 class="confirm-ttl">{{confirmTitle}}</h3>
                    <p class="confirm-msg">{{confirmMessage}}</p>
                    <div class="confirm-actions">
                        <button class="btn-cancel" ng-click="closeConfirmModal()">Cancel</button>
                        <button class="btn-confirm-delete" ng-click="confirmAction()">{{confirmBtnText}}</button>
                    </div>
                </div>
            </div>
        </div>
        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: GALLERY -->
        <!-- ═══════════════════════════════════════════════════ -->

        <div class="tab-content" ng-show="dashTab === 'gallery'">

            <!-- Sub-Tab Bar -->
            <div class="sub-tab-bar">
                <button class="tab-btn" ng-class="{'tab-active': adminTab === 'gallery'}" ng-click="adminTab = 'gallery'">
                    <i class="fa-solid fa-images"></i> Gallery
                    <span class="tab-count">{{galleryPhotos.length}}</span>
                </button>
                <button class="tab-btn" ng-class="{'tab-active': adminTab === 'archivedGallery'}"
                        ng-click="adminTab = 'archivedGallery'; loadArchivedGallery()">
                    <i class="fa-solid fa-box-archive"></i> Archived Photos
                    <span class="tab-count tab-count-warn">{{archivedGalleryPhotos.length}}</span>
                </button>
                <button class="tab-btn" ng-class="{'tab-active': adminTab === 'reviews'}" ng-click="adminTab = 'reviews'">
                    <i class="fa-solid fa-star"></i> Reviews
                    <span class="tab-count">{{reviews.length}}</span>
                </button>
                <button class="tab-btn" ng-class="{'tab-active': adminTab === 'archived'}" ng-click="adminTab = 'archived'">
                    <i class="fa-solid fa-box-archive"></i> Archived Reviews
                    <span class="tab-count tab-count-warn">{{archivedReviews.length}}</span>
                </button>
            </div>

            <!-- SUB-TAB: Gallery -->
            <div ng-show="adminTab === 'gallery'" class="sub-tab-content">
                <a href="@Url.Action("GalleryPage","Main")" class="view-public-btn" target="_blank">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> Show Public View
                </a>
                <div class="upload-card">
                    <h3><i class="fa-solid fa-cloud-arrow-up"></i> Upload New Photo</h3>
                    <div class="upload-form">
                        <div class="upload-dropzone" onclick="document.getElementById('photoFileInput').click()">
                            <i class="fa-solid fa-image"></i>
                            <p>Click to select a photo</p>
                            <span>JPG, PNG, WEBP supported</span>
                            <input type="file" id="photoFileInput" accept="image/*"
                                   onchange="angularFileChange(this)" style="display:none">
                        </div>
                        <div class="upload-fields">
                            <div class="field-grp">
                                <label>Caption</label>
                                <input type="text" class="admin-input" ng-model="newPhoto.caption"
                                       placeholder="e.g. Gel Manicure - Nude Pink">
                            </div>
                            <div class="field-grp">
                                <label>Description</label>
                                <textarea class="admin-input" ng-model="newPhoto.description"
                                          placeholder="Description..." rows="3" style="resize:vertical;"></textarea>
                            </div>
                            <div class="upload-preview-wrap" ng-show="newPhoto.previewUrl">
                                <img ng-src="{{newPhoto.previewUrl}}" class="upload-preview-img" alt="Preview">
                            </div>
                            <button class="admin-btn admin-btn-primary" ng-click="uploadPhoto()"
                                    ng-disabled="!newPhoto.file || !newPhoto.caption">
                                <i class="fa-solid fa-plus"></i> Add to Gallery
                            </button>
                        </div>
                    </div>
                </div>
                <div class="gallery-grid" ng-show="galleryPhotos.length > 0">
                    <div class="gallery-item" ng-repeat="photo in galleryPhotos">
                        <img ng-src="{{photo.imageUrl}}" alt="{{photo.caption}}">
                        <div class="gallery-overlay">
                            <span class="gallery-caption">{{photo.caption}}</span>
                            <div class="gallery-item-actions">
                                <button class="item-action-btn item-edit"
                                        ng-click="startEditPhoto(photo); $event.stopPropagation()" title="Edit">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="item-action-btn item-archive"
                                        ng-click="confirmDeletePhoto(photo); $event.stopPropagation()" title="Archive">
                                    <i class="fa-solid fa-box-archive"></i>
                                </button>
                            </div>
                        </div>
                        <div class="inline-edit-overlay" ng-show="photo.editing" ng-click="$event.stopPropagation()">
                            <input type="text" class="admin-input" ng-model="photo.editCaption" placeholder="Caption">
                            <textarea class="admin-input" ng-model="photo.editDescription"
                                      placeholder="Description" rows="2" style="resize:none; margin-top:0.5rem;"></textarea>
                            <div class="inline-edit-actions">
                                <button class="admin-btn admin-btn-primary" ng-click="saveEditPhoto(photo)">
                                    <i class="fa-solid fa-check"></i> Save
                                </button>
                                <button class="admin-btn admin-btn-secondary" ng-click="cancelEditPhoto(photo)">Cancel</button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="empty-state" ng-show="galleryPhotos.length === 0">
                    <i class="fa-regular fa-image"></i>
                    <p>No photos yet. Upload one above.</p>
                </div>
            </div>

            <!-- SUB-TAB: Archived Photos -->
            <div ng-show="adminTab === 'archivedGallery'" class="sub-tab-content">
                <div class="gallery-grid" ng-show="archivedGalleryPhotos.length > 0">
                    <div class="gallery-item" ng-repeat="photo in archivedGalleryPhotos">
                        <img ng-src="{{photo.imageUrl}}" alt="{{photo.caption}}">
                        <div class="gallery-overlay" style="opacity:1; background:rgba(61,40,23,0.85);">
                            <span class="gallery-caption">{{photo.caption}}</span>
                            <div class="gallery-item-actions">
                                <button class="item-action-btn item-edit"
                                        ng-click="restoreGalleryPhoto(photo); $event.stopPropagation()" title="Restore">
                                    <i class="fa-solid fa-rotate-left"></i>
                                </button>
                                <button class="item-action-btn item-delete"
                                        ng-click="confirmPermanentDelete(photo); $event.stopPropagation()"
                                        title="Delete permanently">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="empty-state" ng-show="archivedGalleryPhotos.length === 0">
                    <i class="fa-solid fa-box-archive"></i>
                    <p>No archived photos.</p>
                </div>
            </div>

            <!-- SUB-TAB: Reviews -->
            <div ng-show="adminTab === 'reviews'" class="sub-tab-content">
                <a href="@Url.Action("GalleryPage","Main")" class="view-public-btn" target="_blank">
                    <i class="fa-solid fa-arrow-up-right-from-square"></i> Show Public View
                </a>
                <div class="stats-bar-row">
                    <div class="stat-card-sm"><span class="stat-num-sm">{{reviews.length}}</span><span class="stat-lbl-sm">Active</span></div>
                    <div class="stat-card-sm"><span class="stat-num-sm">{{averageRating()}}</span><span class="stat-lbl-sm">Avg Rating</span></div>
                    <div class="stat-card-sm stat-warn-sm"><span class="stat-num-sm">{{flaggedCount()}}</span><span class="stat-lbl-sm">Flagged</span></div>
                    <div class="stat-card-sm stat-muted-sm"><span class="stat-num-sm">{{archivedReviews.length}}</span><span class="stat-lbl-sm">Archived</span></div>
                </div>
                <div class="filter-row">
                    <select class="admin-select" ng-model="reviewStarFilter"
                            ng-change="reviewsPage = 1; updatePagedReviews()">
                        <option value="">All Ratings</option>
                        <option value="5">★★★★★ 5 Stars</option>
                        <option value="4">★★★★☆ 4 Stars</option>
                        <option value="3">★★★☆☆ 3 Stars</option>
                        <option value="2">★★☆☆☆ 2 Stars</option>
                        <option value="1">★☆☆☆☆ 1 Star</option>
                    </select>
                    <input type="text" class="admin-search" ng-model="reviewSearch"
                           ng-change="reviewsPage = 1; updatePagedReviews()" placeholder="Search reviews...">
                </div>
                <div class="reviews-list">
                    <div class="review-admin-card" ng-repeat="review in reviews | filter:reviewSearchFilter"
                         ng-class="{'flagged-card': review.flagged}">
                        <div class="rac-top">
                            <div class="rac-stars">
                                <i ng-repeat="s in [1,2,3,4,5]" class="fa-star"
                                   ng-class="s <= review.rating ? 'fa-solid' : 'fa-regular'"></i>
                            </div>
                            <span class="rac-service"><i class="fa-solid fa-spa"></i> {{review.serviceAvailed}}</span>
                            <span class="rac-date">{{review.date | date:'MMM d, yyyy'}}</span>
                            <span class="flag-badge" ng-show="review.flagged"><i class="fa-solid fa-flag"></i> Flagged</span>
                        </div>
                        <p class="rac-text">&ldquo;{{review.reviewText}}&rdquo;</p>
                        <div class="rac-images" ng-if="review.images && review.images.length > 0">
                            <img ng-repeat="img in review.images" ng-src="{{img}}"
                                 class="rac-image clickable-review-image"
                                 ng-click="openReviewLightbox(img); $event.stopPropagation();" />
                        </div>
                        <div class="rac-actions">
                            <button class="admin-btn admin-btn-flag" ng-show="!review.flagged"
                                    ng-click="openFlagModal(review)">
                                <i class="fa-solid fa-flag"></i> Flag
                            </button>
                            <button class="admin-btn admin-btn-unflag" ng-show="review.flagged"
                                    ng-click="unflagReview(review)">
                                <i class="fa-solid fa-flag-checkered"></i> Unflag
                            </button>
                            <button class="admin-btn admin-btn-archive" ng-click="archiveReview(review.reviewId)">
                                <i class="fa-solid fa-box-archive"></i> Archive
                            </button>
                        </div>
                    </div>
                    <div class="empty-state" ng-show="(reviews | filter:reviewSearchFilter).length === 0">
                        <i class="fa-regular fa-star"></i>
                        <p>No reviews match your filter.</p>
                    </div>
                </div>
            </div>

            <!-- SUB-TAB: Archived Reviews -->
            <div class="reviews-list">
                <div class="review-admin-card archived-card"
                     ng-repeat="review in archivedReviews | filter:archivedSearch">
                    <div class="rac-top">
                        <div class="rac-stars">
                            <i ng-repeat="s in [1,2,3,4,5]" class="fa-star"
                               ng-class="s <= review.rating ? 'fa-solid' : 'fa-regular'"></i>
                        </div>
                        <span class="rac-service"><i class="fa-solid fa-spa"></i> {{review.serviceAvailed}}</span>
                        <span class="rac-date">{{review.date | date:'MMM d, yyyy'}}</span>
                        <span class="archived-badge"><i class="fa-solid fa-box-archive"></i> Archived</span>
                    </div>
                    <p class="rac-text">&ldquo;{{review.reviewText}}&rdquo;</p>
                    <div class="rac-actions">
                        <button class="admin-btn admin-btn-restore" ng-click="restoreReview(review.reviewId)">
                            <i class="fa-solid fa-rotate-left"></i> Restore
                        </button>
                    </div>
                </div>
                <div class="empty-state" ng-show="archivedReviews.length === 0">
                    <i class="fa-solid fa-box-archive"></i>
                    <p>No archived reviews.</p>
                </div>
            </div>
        </div>


        <!-- MODAL: Flag Review -->
        <div class="modal-overlay" ng-show="flagModal.show === true" ng-click="closeFlagModal()">
            <div class="modal-card" ng-click="$event.stopPropagation()" style="max-width:500px;">
                <div class="modal-icon-plain" style="color:#f39c12;"><i class="fa-solid fa-flag"></i></div>
                <h3>Flag Review</h3>
                <p style="margin:10px 0 18px; color:#6b4423;">Select the reason why this review is being flagged.</p>
                <div class="field-grp" style="margin-bottom:14px;">
                    <label>Reason</label>
                    <select class="admin-input" ng-model="flagModal.reason">
                        <option value="">-- Select a reason --</option>
                        <option value="Inappropriate language">Inappropriate language</option>
                        <option value="Spam or irrelevant content">Spam or irrelevant content</option>
                        <option value="Offensive or abusive content">Offensive or abusive content</option>
                        <option value="False or misleading review">False or misleading review</option>
                        <option value="Contains sensitive/private information">Contains sensitive/private information</option>
                    </select>
                </div>
                <div class="field-grp">
                    <label>Additional note (optional)</label>
                    <textarea class="admin-input" rows="3" ng-model="flagModal.note"
                              placeholder="Add more details if needed..."></textarea>
                </div>
                <div class="modal-actions" style="margin-top:18px;">
                    <button class="admin-btn admin-btn-secondary" ng-click="closeFlagModal()">Cancel</button>
                    <button class="admin-btn admin-btn-flag" ng-click="submitFlagReview()"
                            ng-disabled="!flagModal.reason">
                        <i class="fa-solid fa-flag"></i> Confirm Flag
                    </button>
                </div>
            </div>
        </div>

        <!-- MODAL: Edit Photo -->
        <div class="modal-overlay" ng-show="editModal.show">
            <div class="modal-card" style="max-width:500px;" ng-click="$event.stopPropagation()">
                <div class="modal-icon-plain" style="font-size:2rem; color:#6b4423;"><i class="fa-solid fa-pen"></i></div>
                <h3 style="margin-bottom:1.5rem;">Edit Photo Details</h3>
                <div style="margin-bottom:0.8rem; border-radius:10px; overflow:hidden; border:2px solid #d4c4b0; max-height:180px;">
                    <img ng-src="{{editModal.newImagePreview || editModal.photo.imageUrl}}"
                         style="width:100%; max-height:180px; object-fit:cover; display:block;">
                </div>
                <button type="button" class="admin-btn admin-btn-secondary"
                        style="width:100%; justify-content:center; margin-bottom:1rem;"
                        onclick="document.getElementById('editImageInput').click()">
                    <i class="fa-solid fa-image"></i> Replace Image
                </button>
                <input type="file" id="editImageInput" accept="image/*"
                       onchange="angularFileChange(this)" style="display:none">
                <span ng-show="editModal.newImagePreview"
                      style="font-size:0.78rem; color:#27ae60; margin-bottom:1rem; display:block;">
                    <i class="fa-solid fa-circle-check"></i> New image selected — save to apply
                </span>
                <div class="field-grp" style="margin-bottom:1rem; text-align:left;">
                    <label>Caption</label>
                    <input type="text" class="admin-input" ng-model="editModal.caption"
                           placeholder="e.g. Gel Manicure">
                </div>
                <div class="field-grp" style="text-align:left;">
                    <label>Description</label>
                    <textarea class="admin-input" ng-model="editModal.description"
                              placeholder="No description yet..." rows="4" style="resize:vertical;"></textarea>
                </div>
                <div class="modal-actions" style="margin-top:1.8rem;">
                    <button class="admin-btn admin-btn-secondary" ng-click="editModal.show = false">Cancel</button>
                    <button class="admin-btn admin-btn-primary" ng-click="saveEditPhoto(editModal.photo)">
                        <i class="fa-solid fa-check"></i> Save Changes
                    </button>
                </div>
            </div>
        </div>

        <!-- MODAL: Archive Photo -->
        <div class="modal-overlay" ng-show="deleteModal.show">
            <div class="modal-card">
                <div class="modal-icon-plain"><i class="fa-solid fa-box-archive"></i></div>
                <h3>Archive Photo?</h3>
                <p>&ldquo;{{deleteModal.photo.caption}}&rdquo; will be moved to Archived Photos. You can restore it later.</p>
                <div class="modal-actions">
                    <button class="admin-btn admin-btn-secondary" ng-click="deleteModal.show = false">Cancel</button>
                    <button class="admin-btn admin-btn-archive" ng-click="deletePhoto()">
                        <i class="fa-solid fa-box-archive"></i> Archive
                    </button>
                </div>
            </div>
        </div>

        <!-- MODAL: Permanent Delete -->
        <div class="modal-overlay" ng-show="permanentDeleteModal.show">
            <div class="modal-card">
                <div class="modal-icon-plain"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <h3>Permanently Delete?</h3>
                <p>
                    This will <strong>permanently remove</strong>
                    &ldquo;{{permanentDeleteModal.photo.caption}}&rdquo;
                    from the server. This <strong>cannot be undone</strong>.
                </p>
                <div class="modal-actions">
                    <button class="admin-btn admin-btn-secondary" ng-click="permanentDeleteModal.show = false">Cancel</button>
                    <button class="admin-btn admin-btn-danger" ng-click="permanentDeletePhoto()">
                        <i class="fa-solid fa-trash"></i> Delete Forever
                    </button>
                </div>
            </div>
        </div>

        <!-- LIGHTBOX: Review Image -->
        <div class="lightbox-overlay" ng-show="lightboxPhoto" ng-click="closeLightbox()">
            <div class="lightbox-card" ng-click="$event.stopPropagation()">
                <button class="lightbox-close" ng-click="closeLightbox()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
                <img ng-src="{{lightboxPhoto}}" class="lightbox-img" alt="Review photo">
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: SERVICES -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'services'">
            <a href="@Url.Action("ServicePage","Main")" class="view-public-btn" target="_blank">
                <i class="fa-solid fa-arrow-up-right-from-square"></i> View Public Page
            </a>

            <div class="services-layout">
                <div class="services-sidebar-mini">
                    <h3>Services</h3>
                    <div class="service-cat" ng-class="{'active': selectedCategory === 'all'}" ng-click="filterServices('all')">All Services</div>
                    <div class="service-cat" ng-class="{'active': selectedCategory === 'manicure'}" ng-click="filterServices('manicure')">Manicure</div>
                    <div class="service-cat" ng-class="{'active': selectedCategory === 'pedicure'}" ng-click="filterServices('pedicure')">Pedicure</div>
                </div>
                <div class="services-main">
                    <div class="page-header-row">
                        <h2 class="section-title">Manage Services</h2>
                        <button class="add-btn" ng-click="openAddServiceModal()"><i class="fa-solid fa-plus"></i> Add Service</button>
                    </div>
                    <div class="services-content-grid">
                        <div class="service-card" ng-repeat="service in services | filter:categoryFilter">
                            <div class="admin-controls-abs">
                                <button class="edit-btn-sm" ng-click="editService(service)"><i class="fa-solid fa-pen-to-square"></i></button>
                                <button class="delete-btn-sm" ng-click="deleteService(service)"><i class="fa-solid fa-trash-can"></i></button>
                            </div>
                            <div class="service-image"><img ng-src="{{service.image}}" alt="{{service.name}}"></div>
                            <div class="service-name">{{service.name}}</div>
                            <div class="service-description" ng-if="service.description">{{service.description}}</div>
                            <div class="service-price">₱{{service.price}}</div>
                        </div>
                    </div>
                    <div class="trash-container-mini">
                        <button class="trash-toggle-btn" ng-click="showServiceTrash = !showServiceTrash; loadDeletedServices()">
                            <i class="fa-solid fa-trash-can-arrow-up"></i>
                            {{ showServiceTrash ? 'Hide Deleted Services' : 'View Deleted Services' }}
                            <span class="trash-count" ng-if="deletedServices.length > 0">{{deletedServices.length}}</span>
                        </button>
                        <div class="trash-panel" ng-show="showServiceTrash">
                            <h3 class="trash-title">Deleted Services</h3>
                            <p class="trash-empty" ng-if="deletedServices.length === 0">No deleted services found.</p>
                            <div class="deleted-faq-card" ng-repeat="s in deletedServices">
                                <div class="deleted-faq-info">
                                    <h3>{{s.name}}</h3>
                                    <p>{{s.category | capitalize}} &bull; ₱{{s.price}}</p>
                                    <p ng-if="s.description" style="margin-top:0.2rem;">{{s.description}}</p>
                                </div>
                                <div class="deleted-faq-actions">
                                    <button class="restore-btn" ng-click="restoreService(s.serviceId)">
                                        <i class="fa-solid fa-rotate-left"></i> Restore
                                    </button>
                                    <button class="perm-delete-btn" ng-click="permanentDeleteService(s.serviceId)">
                                        <i class="fa-solid fa-trash"></i> Delete Forever
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Service Modal -->
            <div class="modal-overlay" ng-show="showServiceModal" ng-click="closeServiceModal()">
                <div class="service-modal-box" ng-click="$event.stopPropagation()">
                    <h2 class="modal-title-center">{{isEditMode ? 'Edit Service' : 'Add New Service'}}</h2>
                    <form name="serviceForm" novalidate>
                        <div class="form-grp">
                            <label>Service Name</label>
                            <input type="text" class="form-inp" ng-model="currentService.name" placeholder="Enter service name" required>
                        </div>
                        <div class="form-grp">
                            <label>Category</label>
                            <select class="form-inp" ng-model="currentService.category" required>
                                <option value="">Select Category</option>
                                <option value="manicure">Manicure</option>
                                <option value="pedicure">Pedicure</option>
                            </select>
                        </div>
                        <div class="form-grp">
                            <label>Price (₱)</label>
                            <input type="number" class="form-inp" ng-model="currentService.price" min="0" step="0.01" placeholder="Enter price" required onkeydown="return event.key !== 'e' && event.key !== 'E' && event.key !== '+' && event.key !== '-'">
                        </div>
                        <div class="form-grp">
                            <label>Description</label>
                            <textarea class="form-inp form-ta" ng-model="currentService.description" placeholder="Enter a short description..." maxlength="300" rows="3" required></textarea>
                        </div>
                        <div class="form-grp">
                            <label>Service Image</label>
                            <input type="file" class="form-inp-file" accept="image/*" onchange="angular.element(this).scope().handleImageUpload(this.files[0])">
                            <div class="image-preview-box" ng-show="currentService.image"><img ng-src="{{currentService.image}}" alt="Service Preview"></div>
                        </div>
                        <div class="modal-actions-row">
                            <button type="button" class="btn-cancel" ng-click="closeServiceModal()">Cancel</button>
                            <button type="button" class="btn-save" ng-click="saveService()" ng-disabled="serviceForm.$invalid">{{isEditMode ? 'Update Service' : 'Add Service'}}</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: FAQs -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'faqs'">
            <div class="page-header-row">
                <h2 class="section-title">FAQs</h2>
                <button class="add-btn" ng-click="openFaqModal()"><i class="fa-solid fa-plus"></i> Add FAQ</button>
            </div>
            <div class="faqs-grid">
                <div class="faq-card" ng-repeat="faq in faqs" ng-class="{'active': faq.isOpen}">
                    <div class="admin-controls-abs">
                        <button class="edit-btn-sm" ng-click="openEditFaqModal(faq, $index); $event.stopPropagation();"><i class="fa-solid fa-pen"></i></button>
                        <button class="delete-btn-sm" ng-click="deleteFaq($index); $event.stopPropagation();"><i class="fa-solid fa-trash"></i></button>
                    </div>
                    <div class="faq-question" ng-click="toggleFaq($index)">
                        <h3>{{faq.question}}</h3>
                        <i class="fa-solid" ng-class="faq.isOpen ? 'fa-chevron-up' : 'fa-chevron-down'"></i>
                    </div>
                    <div class="faq-answer" ng-show="faq.isOpen"><p>{{faq.answer}}</p></div>
                </div>
                <div ng-if="faqs.length === 0" class="faqs-empty"><i class="fa-solid fa-circle-question"></i><p>No FAQs yet.</p></div>
            </div>
            <div class="trash-container-mini">
                <button class="trash-toggle-btn" ng-click="toggleFaqTrash()">
                    <i class="fa-solid fa-trash-can-arrow-up"></i>
                    {{ showFaqTrash ? 'Hide Deleted FAQs' : 'View Deleted FAQs' }}
                    <span class="trash-count" ng-if="deletedFaqs.length > 0">{{deletedFaqs.length}}</span>
                </button>
                <div class="trash-panel" ng-show="showFaqTrash">
                    <h3 class="trash-title">Deleted FAQs</h3>
                    <p class="trash-empty" ng-if="deletedFaqs.length === 0">No deleted FAQs found.</p>
                    <div class="deleted-faq-card" ng-repeat="faq in deletedFaqs">
                        <div class="deleted-faq-info"><h3>{{faq.question}}</h3><p>{{faq.answer}}</p></div>
                        <div class="deleted-faq-actions">
                            <button class="restore-btn" ng-click="restoreFaq(faq.faqId)"><i class="fa-solid fa-rotate-left"></i> Restore</button>
                            <button class="perm-delete-btn" ng-click="permanentDeleteFaq(faq.faqId)"><i class="fa-solid fa-trash"></i> Delete Forever</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FAQ Modal -->
            <div class="faq-modal-backdrop" ng-show="showFaqModal" ng-click="closeFaqModalBackdrop($event)">
                <div class="faq-modal-box" ng-click="$event.stopPropagation()">
                    <div class="modal-hdr">
                        <div class="modal-hdr-left">
                            <div class="modal-ico"><i class="fa-solid fa-circle-question"></i></div>
                            <div>
                                <span class="modal-ttl">{{ faqEditingIndex !== null ? 'Edit FAQ' : 'Add New FAQ' }}</span>
                                <div class="modal-sub">This will appear on your public FAQ page</div>
                            </div>
                        </div>
                        <button class="modal-cls" ng-click="closeFaqModal()">&#10005;</button>
                    </div>
                    <div class="modal-bdy">
                        <div class="field-grp">
                            <label class="field-lbl">Question</label>
                            <input class="field-inp" type="text" ng-model="faqForm.question" placeholder="e.g. What services do you offer?" />
                        </div>
                        <div class="field-grp">
                            <label class="field-lbl">Answer</label>
                            <textarea class="field-inp field-ta" ng-model="faqForm.answer" placeholder="Provide a helpful and detailed answer..." rows="4"></textarea>
                        </div>
                    </div>
                    <div class="modal-ftr">
                        <button class="btn-cancel" ng-click="closeFaqModal()">Cancel</button>
                        <button class="btn-save" ng-click="saveFaqModal()" ng-disabled="!faqForm.question || !faqForm.answer">{{ faqEditingIndex !== null ? 'Save Changes' : 'Add FAQ' }}</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: CONTACT -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'contact'">
            <div class="page-header-row">
                <h2 class="section-title">Contact Information Management</h2>
                <button class="add-btn" ng-click="addNewContact()"><i class="fa-solid fa-plus"></i> Add Contact Info</button>
            </div>
            <div class="contact-layout">
                <div class="map-wrapper">
                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3860.3958514777332!2d121.09269817603956!3d14.633456876269488!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3397b8336d0f8f21%3A0x727b2bab93034843!2s35%20M.%20Cruz%20St%2C%20Marikina%2C%201800%20Metro%20Manila!5e0!3m2!1sen!2sph!4v1767855448965!5m2!1sen!2sph"
                            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
                <div class="contact-list-wrapper">
                    <div class="list-header">
                        <h2>D'est Lounge</h2>
                        <p class="subtitle">Manage contact information below</p>
                    </div>
                    <div class="contact-list">
                        <div class="contact-card" ng-repeat="contact in contactInfo">
                            <div class="card-icon"><i ng-class="contact.icon"></i></div>
                            <div class="card-content">
                                <h3>{{ contact.label }}</h3>
                                <p ng-if="contact.infoType === 'phone'"><a href="tel:{{ contact.rawValue }}">{{ contact.rawValue }}</a></p>
                                <p ng-if="contact.infoType === 'email'"><a href="mailto:{{ contact.rawValue }}">{{ contact.rawValue }}</a></p>
                                <div ng-if="contact.infoType !== 'phone' && contact.infoType !== 'email'" ng-bind="contact.rawValue"></div>
                            </div>
                            <div class="card-actions">
                                <button class="btn-edit" ng-click="editContact($index)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                                <button class="btn-delete" ng-click="deleteContact($index)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                            </div>
                        </div>
                        <div ng-if="contactInfo.length === 0" class="empty-state"><i class="fa-solid fa-inbox"></i><p>No contact information yet</p></div>
                    </div>
                </div>
            </div>
            <div class="contact-trash-container">
                <div class="trash-section">
                    <div class="trash-header">
                        <div class="trash-header-left">
                            <i class="fa-solid fa-trash-can" style="color:#6b4423; font-size:15px;"></i>
                            <span class="trash-label">Deleted Contacts</span>
                            <span class="trash-badge" ng-if="deletedContacts.length > 0">{{deletedContacts.length}}</span>
                        </div>
                        <button class="trash-toggle" ng-click="toggleContactTrash()">{{ showContactTrash ? 'Hide' : 'Show Deleted' }}</button>
                    </div>
                    <div class="trash-list" ng-show="showContactTrash">
                        <p class="trash-empty-state" ng-if="deletedContacts.length === 0">No deleted contacts found.</p>
                        <div class="deleted-card" ng-repeat="contact in deletedContacts">
                            <div class="deleted-avatar"><i ng-class="contact.icon"></i></div>
                            <div class="deleted-info">
                                <span class="deleted-type-pill">{{contact.infoType}}</span>
                                <h4>{{ contact.label }}</h4>
                                <p>{{ contact.value }}</p>
                            </div>
                            <div class="deleted-actions">
                                <button class="btn-restore" ng-click="restoreContact(contact.contactID)"><i class="fa-solid fa-rotate-left"></i> Restore</button>
                                <button class="btn-perm-delete" ng-click="permanentDeleteContact(contact.contactID)"><i class="fa-solid fa-trash"></i> Delete</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Add/Edit Modal -->
            <div class="modal-backdrop" ng-show="showModal" ng-click="closeModalBackdrop($event)">
                <div class="modal-box" ng-click="$event.stopPropagation()">
                    <div class="modal-hdr">
                        <div class="modal-hdr-left">
                            <div class="modal-ico"><i class="fa-solid fa-pen"></i></div>
                            <div>
                                <span class="modal-ttl">{{ editingIndex !== null ? 'Edit Contact' : 'Add Contact Info' }}</span>
                                <div class="modal-sub">This will appear on your public contact page</div>
                            </div>
                        </div>
                        <button class="modal-cls" ng-click="closeModal()">&#10005;</button>
                    </div>
                    <div class="modal-bdy">
                        <div class="field-grp">
                            <label class="field-lbl">What type of contact is this?</label>
                            <div class="type-picker">
                                <div class="type-option" ng-class="{'type-option-active': formData.infoType === 'phone', 'type-option-disabled': editingIndex !== null}" ng-click="editingIndex === null ? setContactType('phone') : null">
                                    <i class="fa-solid fa-phone type-icon"></i><span>Phone</span>
                                </div>
                                <div class="type-option" ng-class="{'type-option-active': formData.infoType === 'email', 'type-option-disabled': editingIndex !== null}" ng-click="editingIndex === null ? setContactType('email') : null">
                                    <i class="fa-solid fa-envelope type-icon"></i><span>Email</span>
                                </div>
                                <div class="type-option" ng-class="{'type-option-active': formData.infoType === 'address', 'type-option-disabled': editingIndex !== null}" ng-click="editingIndex === null ? setContactType('address') : null">
                                    <i class="fa-solid fa-location-dot type-icon"></i><span>Address</span>
                                </div>
                                <div class="type-option" ng-class="{'type-option-active': formData.infoType === 'hours', 'type-option-disabled': editingIndex !== null}" ng-click="editingIndex === null ? setContactType('hours') : null">
                                    <i class="fa-solid fa-clock type-icon"></i><span>Hours</span>
                                </div>
                            </div>
                        </div>
                        <div class="modal-preview" ng-if="formData.label || formData.value">
                            <div class="preview-label">Preview</div>
                            <div class="preview-card">
                                <div class="preview-icon"><i ng-class="formData.icon"></i></div>
                                <div class="preview-content">
                                    <div class="preview-title">{{ formData.label || 'Label not set' }}</div>
                                    <div class="preview-value">{{ formData.value || 'Details not set' }}</div>
                                </div>
                            </div>
                        </div>
                        <div class="field-grp">
                            <label class="field-lbl">Display Label</label>
                            <input class="field-inp" type="text" ng-model="formData.label" placeholder="e.g. Customer Hotline" />
                            <span class="field-hint">Shown as the card title</span>
                        </div>
                        <div class="field-grp">
                            <label class="field-lbl">Contact Details</label>
                            <input type="text" ng-model="formData.value" ng-keypress="formData.infoType === 'phone' && numbersOnly($event)" ng-attr-maxlength="{{formData.infoType === 'phone' ? 11 : undefined}}" placeholder="{{contactPlaceholder}}" class="field-inp" />
                            <span class="field-hint">{{ contactHint }}</span>
                        </div>
                    </div>
                    <div class="modal-ftr">
                        <button class="btn-cancel" ng-click="closeModal()">Cancel</button>
                        <button class="btn-save" ng-click="saveContact()">Save Contact</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: HOMEPAGE -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'homepage'">
            <h2 class="section-title">Homepage Content</h2>

            <!-- Edit Modal (vanilla JS) -->
            <div class="edit-modal-overlay" id="editModal" style="display:none;">
                <div class="edit-modal-inner">
                    <div class="modal-header-plain">
                        <h3 id="modalTitle">Edit Text</h3>
                        <button class="modal-close-plain" onclick="closeEditModal()"><i class="fa-solid fa-xmark"></i></button>
                    </div>
                    <div class="modal-body-plain">
                        <textarea id="modalInput" class="modal-input-plain" rows="4" oninput="checkCharLimit()"></textarea>
                        <div id="charCounter" style="text-align:right; font-size:0.8rem; color:#888; margin-top:0.3rem;"></div>
                    </div>
                    <div class="modal-footer-plain">
                        <button class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                        <button class="btn-save" onclick="saveEdit()"><i class="fa-solid fa-floppy-disk"></i> Save</button>
                    </div>
                </div>
            </div>

            <!-- Banner Preview -->
            <div class="homepage-section-card">
                <h3 class="homepage-section-label">Banner Text</h3>
                <div class="banner-preview">
                    <div class="editable-block">
                        <h1 class="hello">{{bannerText.hello}}</h1>
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_hello', bannerText.hello, 'Banner — Hello')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                    <div class="editable-block">
                        <h2 class="youre-looking">{{bannerText.youre_looking}}</h2>
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_looking', bannerText.youre_looking, 'Banner — You\'re Looking')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                    <div class="editable-block">
                        <h2 class="gorgeous">{{bannerText.gorgeous}}</h2>
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_gorgeous', bannerText.gorgeous, 'Banner — Gorgeous')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                    <div class="editable-block">
                        <h2 class="today">{{bannerText.today}}</h2>
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_today', bannerText.today, 'Banner — Today')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
            </div>

            <!-- Service Intro -->
            <div class="homepage-section-card">
                <h3 class="homepage-section-label">Services Intro</h3>
                <div class="editable-block">
                    <p class="hp-service-title">{{serviceInfo.title}}</p>
                    <button class="inline-edit-btn" ng-click="openEditModal('service_title', serviceInfo.title, 'Service — Title')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                </div>
                <div class="editable-block" style="margin-top:0.5rem;">
                    <p class="hp-service-tagline">{{serviceInfo.tagline}}</p>
                    <button class="inline-edit-btn" ng-click="openEditModal('service_tagline', serviceInfo.tagline, 'Service — Tagline')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                </div>
            </div>

            <!-- Polaroid Images -->
            <div class="homepage-section-card">
                <h3 class="homepage-section-label">Polaroid Images</h3>
                <div class="polaroid-section-mini">
                    <div class="polaroid-card-mini" ng-repeat="slot in [1,2,3]">
                        <div class="admin-controls-abs">
                            <button class="edit-btn-sm" ng-click="updatePolaroidImage(slot)" title="Change Photo"><i class="fa-solid fa-pen"></i></button>
                            <button class="delete-btn-sm" ng-click="deletePolaroidImage(slot)" title="Delete Photo"><i class="fa-solid fa-trash"></i></button>
                        </div>
                        <div class="polaroid-image-mini"><img ng-src="{{polaroidImages[slot]}}" alt="Nail Design {{slot}}"></div>
                        <div class="polaroid-caption-mini"><i class="fa-regular fa-heart"></i></div>
                    </div>
                </div>
            </div>

            <!-- D'est Description -->
            <div class="homepage-section-card">
                <h3 class="homepage-section-label">D'est Description</h3>
                <div class="dest-desc-preview">
                    <div class="editable-block">
                        <p class="dest-title-prev">{{destInfo.title}}</p>
                        <button class="inline-edit-btn" ng-click="openEditModal('dest_title', destInfo.title, 'D\'est — Title')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                    <div class="editable-block" style="margin-top:0.5rem;">
                        <p class="dest-text-prev">{{destInfo.text}}</p>
                        <button class="inline-edit-btn" ng-click="openEditModal('dest_text', destInfo.text, 'D\'est — Description')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- TAB: PAYMENT -->
        <!-- ═══════════════════════════════════════════════════ -->
        <div class="tab-content" ng-show="dashTab === 'payment'" ng-init="dashTab === 'payment' && loadPaymentInfo()">
            <h2 class="section-title">Payment Settings</h2>

            <div class="payment-content">
                <div class="settings-card">

                    <!-- GCash Number -->
                    <div class="form-group">
                        <label>GCash Number</label>
                        <input type="text"
                               name="gcashNumber"
                               ng-model="payment.gcash"
                               maxlength="11"
                               inputmode="numeric"
                               pattern="[0-9]*"
                               oninput="this.value = this.value.replace(/[^0-9]/g, '')"
                               placeholder="09XXXXXXXXX"
                               class="form-input" />
                    </div>

                    <!-- QR Upload -->
                    <div class="form-group">
                        <label>Upload QR Code</label>
                        <input type="file" id="qrUpload" accept="image/png, image/jpeg, image/jpg" />
                        <small class="help-text">Upload QR code for GCash payments (PNG, JPG, JPEG)</small>
                    </div>

                    <!-- Current QR Preview -->
                    <div class="qr-preview" ng-if="paymentInfo.qr">
                        <label>Current QR Code:</label>
                        <img ng-src="{{paymentInfo.qr}}" alt="QR Code" class="qr-image" />
                    </div>

                    <button class="btn-save" ng-click="savePayment()">
                        Save Settings
                    </button>

                </div>
            </div>
        </div>
    </div>
    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <h2 class="footer-title">Follow our Socials!</h2>
            <div class="social-links">
                <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank"><i class="fa-brands fa-tiktok"></i><span>destlounge</span></a>
                <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank"><i class="fa-brands fa-facebook"></i><span>D'est Lounge</span></a>
                <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank"><i class="fa-brands fa-instagram"></i><span>destlounge</span></a>
            </div>
        </div>
    </footer>
</div>

