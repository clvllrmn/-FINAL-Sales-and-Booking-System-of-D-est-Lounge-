<script>
    /* ── Homepage edit modal helpers (vanilla JS, used in homepage tab) ── */
    var _currentContentType = null;
    var _charLimit = null;

    function checkCharLimit() {
        var input = document.getElementById('modalInput');
        var counter = document.getElementById('charCounter');
        if (!input) return;
        if (_charLimit) {
            var remaining = _charLimit - input.value.length;
            counter.textContent = remaining + ' characters remaining';
            counter.style.color = remaining < 20 ? '#c84b4b' : '#888';
            if (input.value.length > _charLimit) input.value = input.value.substring(0, _charLimit);
        } else { counter.textContent = ''; }
    }

    function openEditModal(contentType, currentValue, title) {
        _currentContentType = contentType;
        _charLimit = (contentType === 'dest_text') ? 500 : null;
        document.getElementById('modalTitle').textContent = title;
        document.getElementById('modalInput').value = currentValue;
        document.getElementById('editModal').style.display = 'flex';
        document.getElementById('charCounter').textContent = '';
        checkCharLimit();
    }

    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        _currentContentType = null; _charLimit = null;
        document.getElementById('charCounter').textContent = '';
    }

    function saveEdit() {
        var newValue = document.getElementById('modalInput').value.trim();
        if (!newValue) { alert('Value cannot be empty.'); return; }
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        fetch('/HomePageContent/UpdateContent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'contentType=' + encodeURIComponent(_currentContentType) +
                  '&contentValue=' + encodeURIComponent(newValue) +
                  '&__RequestVerificationToken=' + encodeURIComponent(token)
        }).then(function(r) { return r.json(); })
          .then(function(data) {
              if (data.success) {
                  closeEditModal();
                  var scope = angular.element(document.querySelector('[ng-controller]')).scope();
                  if (scope) { scope.loadHomepageContent(); scope.$apply(); }
              } else { alert('Save failed: ' + data.message); }
          }).catch(function() { alert('Network error. Please try again.'); });
    }

    function toggleMobileNav() {
        var drawer = document.getElementById('mobileDrawer');
        var overlay = document.getElementById('mobileOverlay');
        drawer.classList.toggle('open');
        overlay.classList.toggle('open');
    }

    function angularFileChange(input) {
        var scope = angular.element(document.querySelector('.main-content')).scope();
        if (!scope) return;
        var fn = input.id === 'editImageInput' ? 'onEditImageSelected' : 'onFileSelected';
        if (scope[fn]) scope.$apply(function() { scope[fn](input); });
    }

    document.addEventListener('click', function(e) {
        if (e.target.id === 'editModal') closeEditModal();
    });
</script>

@section scripts {
    <script>
        angular.element(document).ready(function () {
            var scope = angular.element(document.querySelector('[ng-controller]')).scope();
            if (scope && !scope.dashTab) {
                scope.$apply(function () {
                    scope.dashTab = 'analytics';
                    scope.adminTab = 'gallery';
                    scope.filterBookings('all');
                    scope.loadReviews();
                    scope.loadArchivedReviews();
                    scope.loadServices();
                    scope.loadDeletedServices();
                    scope.loadGalleryPhotos();
                    scope.loadFAQs();
                    scope.loadContactInfo();
                    scope.loadTechs && scope.loadTechs();
                });

                // Load reviews with admin URL directly (bypasses the path check)
                scope.$apply(function () {
                    scope.$http = scope.$http || angular.element(document.querySelector('[ng-controller]')).injector().get('$http');
                });

                // Use $http directly to force admin reviews endpoint
                var injector = angular.element(document.querySelector('[ng-app]')).injector();
                var $http = injector.get('$http');
                $http.get('/Main/GetAdminReviews').then(function (res) {
                    scope.$apply(function () {
                        scope.reviews = (res.data || []).map(function (r) {
                            return {
                                reviewId: r.ReviewId || r.reviewId,
                                rating: Number(r.Rating || r.rating || 0),
                                reviewText: r.ReviewText || r.reviewText || 'No comment provided.',
                                serviceAvailed: r.ServiceAvailed || r.serviceAvailed || 'Nail Service',
                                date: r.date ? new Date(r.date) : (r.CreatedAt ? new Date(r.CreatedAt) : new Date()),
                                images: r.images || [],
                                flagged: r.Flagged || r.flagged || false,
                                flagReason: r.FlagReason || r.flagReason || '',
                                flagNote: r.FlagNote || r.flagNote || ''
                            };
                        });
                    });
                });

                scope.loadBookings().then(function () {
                    // Delay to ensure DOM (canvas) is rendered before drawing chart
                    setTimeout(function () {
                        scope.$applyAsync(function () {
                            scope.loadAnalytics();
                        });

                        // Load nail techs from child scope
                        var techEl = document.querySelector('[ng-controller="NailTechController"]');
                        if (techEl) {
                            var techScope = angular.element(techEl).scope();
                            if (techScope && techScope.loadTechs) techScope.loadTechs();
                        }
                    }, 300);
                });
            }
        });

        angular.module('DestLoungeSalesandBooking')
            .filter('capitalize', function () {
                return function (input) {
                    if (!input) return '';
                    return input.charAt(0).toUpperCase() + input.slice(1).toLowerCase();
                };
            });

        /* NailTech sub-controller wired into dashboard staffs tab */
        angular.module('DestLoungeSalesandBooking')
            .controller('NailTechController', ['$scope', '$http', function($scope, $http) {
                $scope.activeTechs = [];
                $scope.inactiveTechs = [];
                $scope.showModal = false;
                $scope.showConfirmModal = false;
                $scope.showInactive = false;
                $scope.editingTech = null;
                $scope.techForm = { name: '', specialization: '', contact: '', status: 'active', notes: '' };

                $scope.loadTechs = function() {
                    $http.get('/Main/GetNailTechs').then(function(res) {
                        $scope.activeTechs = res.data.filter(function(t) { return t.status !== 'inactive'; });
                        $scope.inactiveTechs = res.data.filter(function (t) { return t.status === 'inactive'; });
                        $scope.$parent.activeTechs = $scope.activeTechs;
                        $scope.$parent.inactiveTechs = $scope.inactiveTechs;
                    });
                };
                $scope.loadTechs();

                $scope.getInitials = function(name) {
                    if (!name) return '?';
                    return name.split(' ').map(function(w) { return w[0]; }).slice(0, 2).join('').toUpperCase();
                };

                $scope.openModal = function() {
                    $scope.editingTech = null;
                    $scope.techForm = { name: '', specialization: '', contact: '', status: 'active', notes: '' };
                    $scope.showModal = true;
                };
                $scope.openEditModal = function(tech) {
                    $scope.editingTech = tech;
                    $scope.techForm = { name: tech.name || '', specialization: tech.specialization || '', contact: tech.contact || '', status: tech.status || 'active', notes: tech.notes || '' };
                    $scope.showModal = true;
                };
                $scope.closeModal = function() { $scope.showModal = false; $scope.editingTech = null; };
                $scope.closeModalBackdrop = function($event) { if ($event.target === $event.currentTarget) $scope.closeModal(); };

                $scope.saveTech = function() {
                    if (!$scope.techForm.name) return;
                    var payload = angular.copy($scope.techForm);
                    if ($scope.editingTech) {
                        payload.nailTechId = $scope.editingTech.nailTechId;
                        $http.post('/Main/UpdateNailTech', payload).then(function() { $scope.loadTechs(); $scope.closeModal(); });
                    } else {
                        $http.post('/Main/AddNailTech', payload).then(function() { $scope.loadTechs(); $scope.closeModal(); });
                    }
                };
                $scope.deactivateTech = function(tech) {
                    $scope.pendingAction = function() { $http.post('/Main/DeactivateNailTech', { nailTechId: tech.nailTechId }).then(function() { $scope.loadTechs(); }); };
                    $scope.confirmTitle = 'Deactivate Nail Tech';
                    $scope.confirmMessage = 'Mark ' + tech.name + ' as inactive?';
                    $scope.confirmBtnText = 'Deactivate';
                    $scope.showConfirmModal = true;
                };
                $scope.reactivateTech = function(tech) { $http.post('/Main/ReactivateNailTech', { nailTechId: tech.nailTechId }).then(function() { $scope.loadTechs(); }); };
                $scope.deleteTech = function(tech) {
                    $scope.pendingAction = function() { $http.post('/Main/DeleteNailTech', { nailTechId: tech.nailTechId }).then(function() { $scope.loadTechs(); }); };
                    $scope.confirmTitle = 'Remove Nail Tech';
                    $scope.confirmMessage = 'Remove ' + tech.name + '?';
                    $scope.confirmBtnText = 'Remove';
                    $scope.showConfirmModal = true;
                };
                $scope.permanentDeleteTech = function(tech) {
                    $scope.pendingAction = function() { $http.post('/Main/PermanentDeleteNailTech', { nailTechId: tech.nailTechId }).then(function() { $scope.loadTechs(); }); };
                    $scope.confirmTitle = 'Permanently Remove';
                    $scope.confirmMessage = 'Completely remove ' + tech.name + ' from the system?';
                    $scope.confirmBtnText = 'Delete Forever';
                    $scope.showConfirmModal = true;
                };
                $scope.confirmAction = function() { if ($scope.pendingAction) $scope.pendingAction(); $scope.showConfirmModal = false; $scope.pendingAction = null; };
                $scope.closeConfirmModal = function() { $scope.showConfirmModal = false; $scope.pendingAction = null; };
            }]);
    </script>
}