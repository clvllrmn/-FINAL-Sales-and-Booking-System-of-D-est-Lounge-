@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
            <div ng-controller="DestLoungeSalesandBookingController"
                 ng-init="loadNotifications()"
                 style="position:relative; margin-left:15px;">

                <button type="button"
                        ng-click="toggleNotif($event)"
                        style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                    <i class="fa-solid fa-bell"></i>

                    <span ng-if="getUnreadCount() > 0"
                          class="notif-badge">!</span>
                </button>

                <div ng-show="showNotif"
                     ng-click="$event.stopPropagation()"
                     style="position:absolute; right:0; top:35px; width:280px; max-height:350px; overflow-y:auto; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999; box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                    <div style="padding:10px 12px; font-weight:bold; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
                        <span style="color:#333;">Notifications</span>
                        <button ng-if="notifications.length > 0"
                                ng-click="clearAllNotifications($event)"
                                style="font-size:11px; color:#e74c3c; background:none; border:none; cursor:pointer; padding:0;">
                            Clear all
                        </button>
                    </div>
                    <div ng-if="!notifications.length" style="padding:12px; color:gray; font-size:13px; text-align:center;">
                        No notifications yet.
                    </div>
                    <div ng-repeat="n in notifications"
                         class="notif-item"
                         ng-class="(n.IsRead || n.isRead) ? 'read' : 'unread'"
                         style="padding:10px 12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                        <span ng-click="markAsReadAndGo(n, $event)"
                              style="cursor:pointer; flex:1; line-height:1.4;"
                              ng-style="(n.IsRead || n.isRead) ? {'font-size':'13px','color':'#999','font-weight':'normal'} : {'font-size':'13px','color':'#333','font-weight':'600'}">
                            <span ng-if="!(n.IsRead || n.isRead)" class="notif-unread-dot"></span>
                            {{n.Message || n.message}}
                        </span>
                        <button ng-click="deleteNotification(n.NotificationId || n.notificationId, $event)"
                                style="background:none; border:none; cursor:pointer; color:#aaa; font-size:16px; padding:0 0 0 6px; flex-shrink:0; line-height:1;">
                            &times;
                        </button>
                    </div>
                </div>
            </div>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
        <div ng-controller="DestLoungeSalesandBookingController"
             ng-init="loadNotifications()"
             style="position:relative; margin-left:15px;">

            <button type="button"
                    ng-click="toggleNotif($event)"
                    style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                <i class="fa-solid fa-bell"></i>

                <span ng-if="getUnreadCount() > 0"
                      class="notif-badge">!</span>
            </button>

            <div ng-show="showNotif"
                 ng-click="$event.stopPropagation()"
                 style="position:absolute; right:0; top:35px; width:280px; max-height:350px; overflow-y:auto; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999; box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                <div style="padding:10px 12px; font-weight:bold; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
                    <span style="color:#333;">Notifications</span>
                    <button ng-if="notifications.length > 0"
                            ng-click="clearAllNotifications($event)"
                            style="font-size:11px; color:#e74c3c; background:none; border:none; cursor:pointer; padding:0;">
                        Clear all
                    </button>
                </div>
                <div ng-if="!notifications.length" style="padding:12px; color:gray; font-size:13px; text-align:center;">
                    No notifications yet.
                </div>
                <div ng-repeat="n in notifications"
                     class="notif-item"
                     ng-class="(n.IsRead || n.isRead) ? 'read' : 'unread'"
                     style="padding:10px 12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                    <span ng-click="markAsReadAndGo(n, $event)"
                          style="cursor:pointer; flex:1; line-height:1.4;"
                          ng-style="(n.IsRead || n.isRead) ? {'font-size':'13px','color':'#999','font-weight':'normal'} : {'font-size':'13px','color':'#333','font-weight':'600'}">
                        <span ng-if="!(n.IsRead || n.isRead)" class="notif-unread-dot"></span>
                        {{n.Message || n.message}}
                    </span>
                    <button ng-click="deleteNotification(n.NotificationId || n.notificationId, $event)"
                            style="background:none; border:none; cursor:pointer; color:#aaa; font-size:16px; padding:0 0 0 6px; flex-shrink:0; line-height:1;">
                        &times;
                    </button>
                </div>
            </div>
        </div>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div class="profile-container">
    <aside class="sidebar">
        <nav class="profile-nav">
            <div class="nav-top">
                <a href="@Url.Action("ProfilePage","Main")" class="nav-item">Profile</a>
                <a href="@Url.Action("CurrentBookingPage","Main")" class="nav-item">Current booking</a>
                <a href="@Url.Action("ReviewPage", "Main")" class="nav-item active">To Review</a>
            </div>

        </nav>
    </aside>
    <div class="review-list-wrapper"
         ng-controller="DestLoungeSalesandBookingController"
         ng-init="loadMyReviews()">

        <h2 class="review-service-name">My Reviews</h2>

        <div ng-if="myReviews.length === 0" class="empty-state">
            <h3>No reviews yet</h3>
            <p>Your submitted reviews will appear here.</p>
        </div>

        <div class="booking-item" ng-repeat="r in myReviews">

            <div class="booking-top">
                <span><strong>Ref No:</strong> {{r.booking.ReferenceNo || ('REF-' + r.bookingId)}}</span>
            </div>

            <div class="booking-body">
                <p><strong>Rating:</strong> {{r.rating}} / 5</p>
                <p><strong>Review:</strong> {{r.reviewText}}</p>
                <p><strong>Date:</strong> {{r.createdAt | date:'MMMM d, yyyy'}}</p>
                <p><strong>Service:</strong> {{extractServices(r.booking.Notes)}}</p>
                <p><strong>Nail Tech:</strong> {{r.booking.NailTech}}</p>

                <div ng-if="r.flagged" style="color:#a04040;">
                    ⚠ Flagged: {{r.flagReason}}
                </div>
            </div>

        </div>
    </div>

</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i><span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Welcome Text Fix ── */
    .welcome-text {
        color: #5d4037;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 0.3s ease;
    }

        .welcome-text:hover {
            color: #6b4423;
        }

        .welcome-text i {
            font-size: 1.1rem;
        }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .bell-icon {
        color: #5d4037;
        font-size: 1.2rem;
        text-decoration: none;
        transition: color 0.3s ease;
    }

        .bell-icon:hover {
            color: #6b4423;
        }

    /* ── Layout ── */
    .profile-container {
        display: flex;
        min-height: 100vh; /* ← was calc(100vh - 200px) */
        background-color: #f5f0eb;
        align-items: stretch;
    }

    /* ── Sidebar + Logout Fix ── */
    .sidebar {
        width: 280px;
        flex-shrink: 0;
        background-color: #d4c4b5;
        display: flex;
        flex-direction: column;
        align-self: stretch; /* ← stretches to match the container height */
    }

    .profile-nav {
        display: flex;
        flex-direction: column;
        padding-top: 40px;
        flex: 1;
        justify-content: space-between;
        height: 100%; /* ← fills the full sidebar */
    }

        .profile-nav .nav-item {
            padding: 20px 35px;
            color: #5a4a3a;
            text-decoration: none;
            font-size: 18px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            display: block;
        }

            .profile-nav .nav-item:hover,
            .profile-nav .nav-item.active {
                background-color: #c9b5a3;
                border-left-color: #6b5544;
            }

    .nav-logout {
        color: #a04040;
    }

    .profile-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 80px 40px;
    }

    /* ── Review Card ── */
    .review-card {
        background-color: #e8ddd1;
        border-radius: 30px;
        padding: 50px 60px;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .review-service-name {
        color: #6b5544;
        font-size: 32px;
        font-weight: 600;
        margin-bottom: 30px;
    }

    .rating-section {
        margin-bottom: 30px;
    }

    .rating-label {
        color: #6b5544;
        font-size: 18px;
        font-weight: 500;
        margin-bottom: 15px;
        text-align: center;
    }

    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 50px;
            color: #d4c4b5;
            cursor: pointer;
            transition: color 0.2s ease;
        }

            .star-rating label:hover,
            .star-rating label:hover ~ label,
            .star-rating input:checked ~ label {
                color: #f5a623;
            }

    .review-text-section {
        margin-bottom: 25px;
    }

    .review-label {
        color: #6b5544;
        font-size: 18px;
        font-weight: 500;
        display: block;
        margin-bottom: 10px;
    }

    .review-textarea {
        width: 100%;
        padding: 15px;
        border: none;
        border-radius: 15px;
        background-color: #f8f4ef;
        color: #5a4a3a;
        font-size: 16px;
        font-family: inherit;
        resize: vertical;
        min-height: 120px;
        box-sizing: border-box;
    }

        .review-textarea:focus {
            outline: 2px solid #c9b5a3;
        }

        .review-textarea::placeholder {
            color: #a89585;
        }

    .review-list-wrapper {
        flex: 1;
        padding: 80px 40px;
        max-width: 900px;
    }

    .booking-item {
        background: #e8ddd1;
        padding: 24px;
        border-radius: 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .booking-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 12px;
        border-bottom: 1px solid #c9b5a3;
        color: #6b5544;
        font-size: 16px;
        font-weight: 600;
    }

    .booking-body {
        margin: 15px 0;
    }

        .booking-body p {
            margin: 8px 0;
            color: #5a4a3a;
            font-size: 14px;
            line-height: 1.6;
        }

        .booking-body strong {
            color: #6b5544;
            font-weight: 600;
        }

    .empty-state {
        text-align: center;
        padding: 50px 20px;
        background: #e8ddd1;
        border-radius: 20px;
        margin-top: 20px;
    }

        .empty-state h3 {
            color: #6b5544;
            margin-bottom: 10px;
            font-size: 24px;
        }

        .empty-state p {
            color: #8b7b6b;
            font-size: 16px;
        }

    /* ── Photo Upload ── */
    .photo-upload-section {
        margin-bottom: 35px;
    }

    .photo-upload-box {
        background-color: #f8f4ef;
        border-radius: 15px;
        padding: 20px;
        min-height: 150px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-start;
        gap: 8px;
        position: relative;
        transition: background-color 0.3s ease;
    }

        .photo-upload-box:hover {
            background-color: #f0e8dd;
        }

    .upload-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        position: absolute;
        inset: 0;
        border-radius: 15px;
    }

    .camera-icon {
        font-size: 60px;
        color: #6b5544;
        margin-bottom: 10px;
    }

    .upload-text {
        color: #6b5544;
        font-size: 16px;
        margin: 0;
    }

    /* ── Actions ── */
    .review-actions {
        display: flex;
        gap: 20px;
        justify-content: center;
        margin-top: 40px;
    }

    .btn-cancel, .btn-upload {
        padding: 15px 45px;
        border: none;
        border-radius: 25px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        background-color: #6b5544;
        color: white;
    }

        .btn-cancel:hover, .btn-upload:hover {
            background-color: #5a4635;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* ── Desktop ── */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            gap: 2.5rem !important;
            transform: none !important;
            transition: none !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    /* ── Tablet/Mobile ── */
    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
            box-shadow: -4px 0 20px rgba(0,0,0,0.15) !important;
            transform: translateX(100%) !important;
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1) !important;
            overflow-y: auto !important;
        }

            .main-nav.open {
                transform: translateX(0) !important;
            }

            .main-nav a {
                width: 100% !important;
                padding: 0.9rem 0 !important;
                font-size: 1rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                display: block !important;
                text-decoration: none !important;
                background: none !important;
            }

        .mobile-nav-actions {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #d4c4b0;
        }

            .mobile-nav-actions a {
                display: flex !important;
                align-items: center;
                gap: 0.6rem;
                padding: 0.75rem 0 !important;
                font-size: 0.97rem !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                width: 100% !important;
                font-weight: 600 !important;
                text-decoration: none !important;
                background: none !important;
            }

                .mobile-nav-actions a:last-child {
                    border-bottom: none !important;
                }

        .profile-container {
            flex-direction: column;
        }

        .sidebar {
            width: 100%;
            min-height: unset;
            position: static;
            height: auto;
        }

        .profile-nav {
            flex-direction: row;
            min-height: unset;
            padding-top: 0;
            justify-content: flex-start;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }

            .profile-nav::-webkit-scrollbar {
                display: none;
            }

        .nav-top {
            display: flex;
            flex-direction: row;
            flex: 1;
        }

        .nav-bottom {
            display: flex;
            flex-direction: row;
            flex-shrink: 0;
        }

        .profile-nav .nav-item {
            white-space: nowrap;
            padding: 16px 22px;
            font-size: 15px;
            border-left: none;
            border-bottom: 4px solid transparent;
        }

            .profile-nav .nav-item:hover, .profile-nav .nav-item.active {
                background-color: #c9b5a3;
                border-left-color: transparent;
                border-bottom-color: #6b5544;
            }

        .profile-content {
            padding: 2rem 1.5rem;
