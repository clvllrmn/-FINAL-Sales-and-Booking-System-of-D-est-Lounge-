@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
    int? bookingId = ViewBag.BookingId as int?;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <div ng-controller="DestLoungeSalesandBookingController"
                     ng-init="loadNotifications()"
                     style="position:relative; margin-left:15px;">

                    <button type="button"
                            ng-click="toggleNotif($event)"
                            style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                        <i class="fa-solid fa-bell"></i>

                        <span ng-if="getUnreadCount() > 0"
                              class="notif-badge">!</span>
                    </button>

                    <div ng-show="showNotif"
                         ng-click="$event.stopPropagation()"
                         style="position:absolute; right:0; top:35px; width:280px; max-height:350px; overflow-y:auto; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999; box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                        <div style="padding:10px 12px; font-weight:bold; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
                            <span style="color:#333;">Notifications</span>
                            <button ng-if="notifications.length > 0"
                                    ng-click="clearAllNotifications($event)"
                                    style="font-size:11px; color:#e74c3c; background:none; border:none; cursor:pointer; padding:0;">
                                Clear all
                            </button>
                        </div>
                        <div ng-if="!notifications.length" style="padding:12px; color:gray; font-size:13px; text-align:center;">
                            No notifications yet.
                        </div>
                        <div ng-repeat="n in notifications"
                             class="notif-item"
                             ng-class="(n.IsRead || n.isRead) ? 'read' : 'unread'"
                             style="padding:10px 12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                            <span ng-click="markAsReadAndGo(n, $event)"
                                  style="cursor:pointer; flex:1; line-height:1.4;"
                                  ng-style="(n.IsRead || n.isRead) ? {'font-size':'13px','color':'#999','font-weight':'normal'} : {'font-size':'13px','color':'#333','font-weight':'600'}">
                                <span ng-if="!(n.IsRead || n.isRead)" class="notif-unread-dot"></span>
                                {{n.Message || n.message}}
                            </span>
                            <button ng-click="deleteNotification(n.NotificationId || n.notificationId, $event)"
                                    style="background:none; border:none; cursor:pointer; color:#aaa; font-size:16px; padding:0 0 0 6px; flex-shrink:0; line-height:1;">
                                &times;
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <div ng-controller="DestLoungeSalesandBookingController"
                 ng-init="loadNotifications()"
                 style="position:relative; margin-left:15px;">

                <button type="button"
                        ng-click="toggleNotif($event)"
                        style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                    <i class="fa-solid fa-bell"></i>

                    <span ng-if="getUnreadCount() > 0"
                          class="notif-badge">!</span>
                </button>

                <div ng-show="showNotif"
                     ng-click="$event.stopPropagation()"
                     style="position:absolute; right:0; top:35px; width:280px; max-height:350px; overflow-y:auto; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999; box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                    <div style="padding:10px 12px; font-weight:bold; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
                        <span style="color:#333;">Notifications</span>
                        <button ng-if="notifications.length > 0"
                                ng-click="clearAllNotifications($event)"
                                style="font-size:11px; color:#e74c3c; background:none; border:none; cursor:pointer; padding:0;">
                            Clear all
                        </button>
                    </div>
                    <div ng-if="!notifications.length" style="padding:12px; color:gray; font-size:13px; text-align:center;">
                        No notifications yet.
                    </div>
                    <div ng-repeat="n in notifications"
                         class="notif-item"
                         ng-class="(n.IsRead || n.isRead) ? 'read' : 'unread'"
                         style="padding:10px 12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                        <span ng-click="markAsReadAndGo(n, $event)"
                              style="cursor:pointer; flex:1; line-height:1.4;"
                              ng-style="(n.IsRead || n.isRead) ? {'font-size':'13px','color':'#999','font-weight':'normal'} : {'font-size':'13px','color':'#333','font-weight':'600'}">
                            <span ng-if="!(n.IsRead || n.isRead)" class="notif-unread-dot"></span>
                            {{n.Message || n.message}}
                        </span>
                        <button ng-click="deleteNotification(n.NotificationId || n.notificationId, $event)"
                                style="background:none; border:none; cursor:pointer; color:#aaa; font-size:16px; padding:0 0 0 6px; flex-shrink:0; line-height:1;">
                            &times;
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div class="profile-container">
    <aside class="sidebar">
        <nav class="profile-nav">
            <div class="nav-top">
                <a href="@Url.Action("ProfilePage","Main")" class="nav-item">Profile</a>
                <a href="@Url.Action("CurrentBookingPage","Main")" class="nav-item">Current booking</a>
                <a href="@Url.Action("ReviewPage","Main")" class="nav-item active">To Review</a>
            </div>
        </nav>
    </aside>

    <!-- Review Form (shown when bookingId is provided) -->
    @if (bookingId.HasValue && bookingId.Value > 0)
    {
        using (Html.BeginForm("SubmitReview", "Main", FormMethod.Post, new { enctype = "multipart/form-data", id = "reviewForm" }))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="BookingId" value="@bookingId.Value" />

            <div class="profile-content">
                <div class="review-card">
                    <h2 class="review-service-name">Write a Review</h2>

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-error">@TempData["ErrorMessage"]</div>
                    }

                    <!-- Rating Section - REQUIRED -->
                    <div class="rating-section">
                        <div class="rating-label">Your Rating <span style="color: red;">*</span></div>
                        <div class="star-rating">
                            <input type="radio" name="Rating" value="5" id="star5" /><label for="star5" title="5 stars">★</label>
                            <input type="radio" name="Rating" value="4" id="star4" /><label for="star4" title="4 stars">★</label>
                            <input type="radio" name="Rating" value="3" id="star3" /><label for="star3" title="3 stars">★</label>
                            <input type="radio" name="Rating" value="2" id="star2" /><label for="star2" title="2 stars">★</label>
                            <input type="radio" name="Rating" value="1" id="star1" /><label for="star1" title="1 star">★</label>
                        </div>
                        <div id="ratingError" style="color: red; font-size: 12px; text-align: center; display: none;">Please select a rating</div>
                    </div>

                    <!-- Review Text Section - OPTIONAL -->
                    <div class="review-text-section">
                        <label for="ReviewText" class="review-label">Your Review (Optional)</label>
                        <textarea name="ReviewText" id="ReviewText" class="review-textarea" placeholder="Share your experience with us... (optional)"></textarea>
                    </div>

                    <!-- Photo Upload Section - OPTIONAL -->
                    <div class="photo-upload-section">
                        <label class="review-label">Upload Photos (Optional - Max 5 photos)</label>
                        <div class="photo-upload-box" id="photoUploadBox">
                            <div class="upload-placeholder" onclick="document.getElementById('photoInput').click();">
                                <i class="fa-solid fa-camera camera-icon"></i>
                                <p class="upload-text">Click to upload photos</p>
                                <small style="color: #8b7b6b;">Max 5 images | 5MB per image (JPG, PNG, GIF)</small>
                                <small style="color: #8b7b6b; display: block;">Current: <span id="photoCount">0</span>/5 photos</small>
                            </div>
                            <input type="file" name="PhotoUpload" id="photoInput" multiple accept="image/jpeg,image/png,image/gif" style="display: none;" onchange="previewImages(this)" />
                            <div id="imagePreviewContainer" style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px;"></div>
                        </div>
                    </div>

                    <div class="review-actions">
                        <button type="button" class="btn-cancel" onclick="window.location.href='/Main/CurrentBookingPage'">Cancel</button>
                        <button type="submit" class="btn-upload">Submit Review</button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <!-- My Reviews List (shown when no BookingId) -->
        <div class="review-list-wrapper"
             ng-controller="DestLoungeSalesandBookingController"
             ng-init="loadMyReviews()">

            <h2 class="review-service-name">My Reviews</h2>

            <div ng-if="myReviews.length === 0" class="empty-state">
                <h3>No reviews yet</h3>
                <p>Your submitted reviews will appear here.</p>
            </div>

            <div class="booking-item" ng-repeat="r in myReviews">
                <div class="booking-top">
                    <span><strong>Ref No:</strong> {{r.booking.ReferenceNo || ('REF-' + r.bookingId)}}</span>
                </div>
                <div class="booking-body">
                    <div class="review-stars-display">
                        <i ng-repeat="s in [1,2,3,4,5]" class="fa-star" ng-class="s <= r.rating ? 'fa-solid' : 'fa-regular'" style="color: #f5a623;"></i>
                    </div>
                    <p><strong>Review:</strong> {{r.reviewText || 'No comment provided.'}}</p>
                    <p><strong>Date:</strong> {{r.createdAt | date:'MMMM d, yyyy'}}</p>
                    <p><strong>Service:</strong> {{extractServices(r.booking.Notes)}}</p>
                    <p><strong>Nail Tech:</strong> {{r.booking.NailTech}}</p>

                    <!-- Display uploaded images -->
                    <div ng-if="r.images && r.images.length > 0" class="review-images-wrap">
                        <strong>Attached Photos:</strong><br />
                        <img ng-repeat="img in r.images"
                             ng-src="{{img}}"
                             alt="Review Image"
                             class="review-image clickable-review-image"
                             ng-click="openReviewLightbox(img); $event.stopPropagation();" />
                    </div>

                    <div ng-if="r.flagged" style="color:#a04040; margin-top: 10px;">
                        ⚠ Flagged: {{r.flagReason}}
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i><span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    .alert {
        padding: 12px 20px;
        border-radius: 8px;
        margin-bottom: 20px;
        text-align: center;
    }

    .alert-error {
        background-color: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
    }

    .alert-success {
        background-color: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
    }

    .review-stars-display {
        margin-bottom: 10px;
    }

        .review-stars-display i {
            font-size: 18px;
            margin-right: 2px;
        }

    .review-images-wrap {
        margin-top: 15px;
        padding-top: 10px;
        border-top: 1px solid #c9b5a3;
    }

    .review-image {
        width: 80px;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
        cursor: pointer;
        transition: transform 0.2s;
        margin-right: 8px;
        margin-top: 5px;
    }

        .review-image:hover {
            transform: scale(1.05);
        }

    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    .welcome-text {
        color: #5d4037;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 0.3s ease;
    }

        .welcome-text:hover {
            color: #6b4423;
        }

        .welcome-text i {
            font-size: 1.1rem;
        }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .profile-container {
        display: flex;
        min-height: 100vh;
        background-color: #f5f0eb;
        align-items: stretch;
    }

    .sidebar {
        width: 280px;
        flex-shrink: 0;
        background-color: #d4c4b5;
        display: flex;
        flex-direction: column;
        align-self: stretch;
    }

    .profile-nav {
        display: flex;
        flex-direction: column;
        padding-top: 40px;
        flex: 1;
        justify-content: space-between;
        height: 100%;
    }

        .profile-nav .nav-item {
            padding: 20px 35px;
            color: #5a4a3a;
            text-decoration: none;
            font-size: 18px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            display: block;
        }

            .profile-nav .nav-item:hover,
            .profile-nav .nav-item.active {
                background-color: #c9b5a3;
                border-left-color: #6b5544;
            }

    .profile-content {
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 80px 40px;
    }

    .review-card {
        background-color: #e8ddd1;
        border-radius: 30px;
        padding: 50px 60px;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .review-service-name {
        color: #6b5544;
        font-size: 32px;
        font-weight: 600;
        margin-bottom: 30px;
    }

    .rating-section {
        margin-bottom: 30px;
    }

    .rating-label {
        color: #6b5544;
        font-size: 18px;
        font-weight: 500;
        margin-bottom: 15px;
        text-align: center;
    }

    .star-rating {
        display: flex;
        flex-direction: row-reverse;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
    }

        .star-rating input {
            display: none;
        }

        .star-rating label {
            font-size: 50px;
            color: #d4c4b5;
            cursor: pointer;
            transition: color 0.2s ease;
        }

            .star-rating label:hover,
            .star-rating label:hover ~ label,
            .star-rating input:checked ~ label {
                color: #f5a623;
            }

    .review-text-section {
        margin-bottom: 25px;
    }

    .review-label {
        color: #6b5544;
        font-size: 18px;
        font-weight: 500;
        display: block;
        margin-bottom: 10px;
    }

    .review-textarea {
        width: 100%;
        padding: 15px;
        border: none;
        border-radius: 15px;
        background-color: #f8f4ef;
        color: #5a4a3a;
        font-size: 16px;
        font-family: inherit;
        resize: vertical;
        min-height: 120px;
        box-sizing: border-box;
    }

        .review-textarea:focus {
            outline: 2px solid #c9b5a3;
        }

        .review-textarea::placeholder {
            color: #a89585;
        }

    .photo-upload-section {
        margin-bottom: 35px;
    }

    .photo-upload-box {
        background-color: #f8f4ef;
        border-radius: 15px;
        padding: 20px;
        min-height: 150px;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: center;
        gap: 10px;
        position: relative;
        transition: background-color 0.3s ease;
        cursor: pointer;
    }

        .photo-upload-box:hover {
            background-color: #f0e8dd;
        }

    .upload-placeholder {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
    }

    .camera-icon {
        font-size: 60px;
        color: #6b5544;
        margin-bottom: 10px;
    }

    .upload-text {
        color: #6b5544;
        font-size: 16px;
        margin: 0;
    }

    .review-actions {
        display: flex;
        gap: 20px;
        justify-content: center;
        margin-top: 40px;
    }

    .btn-cancel, .btn-upload {
        padding: 15px 45px;
        border: none;
        border-radius: 25px;
        font-size: 16px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        background-color: #6b5544;
        color: white;
    }

        .btn-cancel:hover, .btn-upload:hover {
            background-color: #5a4635;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

    .review-list-wrapper {
        flex: 1;
        padding: 80px 40px;
        max-width: 900px;
    }

    .booking-item {
        background: #e8ddd1;
        padding: 24px;
        border-radius: 20px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        margin-bottom: 20px;
    }

    .booking-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        padding-bottom: 12px;
        border-bottom: 1px solid #c9b5a3;
        color: #6b5544;
        font-size: 16px;
        font-weight: 600;
    }

    .booking-body {
        margin: 15px 0;
    }

        .booking-body p {
            margin: 8px 0;
            color: #5a4a3a;
            font-size: 14px;
            line-height: 1.6;
        }

        .booking-body strong {
            color: #6b5544;
            font-weight: 600;
        }

    .empty-state {
        text-align: center;
        padding: 50px 20px;
        background: #e8ddd1;
        border-radius: 20px;
        margin-top: 20px;
    }

        .empty-state h3 {
            color: #6b5544;
            margin-bottom: 10px;
            font-size: 24px;
        }

        .empty-state p {
            color: #8b7b6b;
            font-size: 16px;
        }

    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
