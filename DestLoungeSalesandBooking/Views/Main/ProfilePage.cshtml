@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <div ng-controller="DestLoungeSalesandBookingController"
                     ng-init="loadNotifications()"
                     style="position:relative; margin-left:15px;">

                    <button type="button"
                            ng-click="toggleNotif($event)"
                            style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                        <i class="fa-solid fa-bell"></i>

                        <span ng-if="getUnreadCount() > 0"
                              class="notif-badge">!</span>
                    </button>

                    <div ng-show="showNotif"
                         ng-click="$event.stopPropagation()"
                         style="position:absolute; right:0; top:35px; width:280px; max-height:350px; overflow-y:auto; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999; box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                        <div style="padding:10px 12px; font-weight:bold; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
                            <span style="color:#333;">Notifications</span>
                            <button ng-if="notifications.length > 0"
                                    ng-click="clearAllNotifications($event)"
                                    style="font-size:11px; color:#e74c3c; background:none; border:none; cursor:pointer; padding:0;">
                                Clear all
                            </button>
                        </div>
                        <div ng-if="!notifications.length" style="padding:12px; color:gray; font-size:13px; text-align:center;">
                            No notifications yet.
                        </div>
                        <<div ng-repeat="n in notifications"
                         class="notif-item"
                         ng-class="(n.IsRead || n.isRead) ? 'read' : 'unread'"
                         style="padding:10px 12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                            <span ng-click="markAsReadAndGo(n, $event)"
                                  style="cursor:pointer; flex:1; line-height:1.4;"
                                  ng-style="(n.IsRead || n.isRead) ? {'font-size':'13px','color':'#999','font-weight':'normal'} : {'font-size':'13px','color':'#333','font-weight':'600'}">
                                <span ng-if="!(n.IsRead || n.isRead)" class="notif-unread-dot"></span>
                                {{n.Message || n.message}}
                            </span>
                            <button ng-click="deleteNotification(n.NotificationId || n.notificationId, $event)"
                                    style="background:none; border:none; cursor:pointer; color:#aaa; font-size:16px; padding:0 0 0 6px; flex-shrink:0; line-height:1;">
                                &times;
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <div ng-controller="DestLoungeSalesandBookingController"
                 ng-init="loadNotifications()"
                 style="position:relative; margin-left:15px;">

                <button type="button"
                        ng-click="toggleNotif($event)"
                        style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037; z-index:9999;">
                    <i class="fa-solid fa-bell"></i>

                    <span ng-if="getUnreadCount() > 0"
                          class="notif-badge">!</span>
                </button>

                <div ng-show="showNotif"
                     ng-click="$event.stopPropagation()"
                     style="position:absolute; right:0; top:35px; width:280px; max-height:350px; overflow-y:auto; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999; box-shadow:0 4px 10px rgba(0,0,0,0.2);">
                    <div style="padding:10px 12px; font-weight:bold; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center;">
                        <span style="color:#333;">Notifications</span>
                        <button ng-if="notifications.length > 0"
                                ng-click="clearAllNotifications($event)"
                                style="font-size:11px; color:#e74c3c; background:none; border:none; cursor:pointer; padding:0;">
                            Clear all
                        </button>
                    </div>
                    <div ng-if="!notifications.length" style="padding:12px; color:gray; font-size:13px; text-align:center;">
                        No notifications yet.
                    </div>
                    <div ng-repeat="n in notifications"
                         class="notif-item"
                         ng-class="(n.IsRead || n.isRead) ? 'read' : 'unread'"
                         style="padding:10px 12px; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:flex-start; gap:8px;">
                        <span ng-click="markAsReadAndGo(n, $event)"
                              style="cursor:pointer; flex:1; line-height:1.4;"
                              ng-style="(n.IsRead || n.isRead) ? {'font-size':'13px','color':'#999','font-weight':'normal'} : {'font-size':'13px','color':'#333','font-weight':'600'}">
                            <span ng-if="!(n.IsRead || n.isRead)" class="notif-unread-dot"></span>
                            {{n.Message || n.message}}
                        </span>
                        <button ng-click="deleteNotification(n.NotificationId || n.notificationId, $event)"
                                style="background:none; border:none; cursor:pointer; color:#aaa; font-size:16px; padding:0 0 0 6px; flex-shrink:0; line-height:1;">
                            &times;
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div class="profile-container">
    <aside class="sidebar">
        <nav class="profile-nav">
            <div class="nav-top">
                <a href="@Url.Action("ProfilePage","Main")" class="nav-item active">Profile</a>
                <a href="@Url.Action("CurrentBookingPage","Main")" class="nav-item">My Bookings</a>
                <a href="@Url.Action("ReviewPage","Main")" class="nav-item">My Reviews</a>
            </div>
        </nav>
    </aside>

    <main class="profile-content">

        @* ── Alert messages ── *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">
                <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
            </div>
        }

        @* ── View Mode ── *@
        <div class="profile-card" id="viewCard">
            <div class="profile-card-header">
                <h2 class="profile-heading">Profile</h2>
                <div class="profile-card-header-actions">
                    <button class="btn-edit" onclick="showEditMode()">
                        <i class="fa-solid fa-pen"></i> Edit
                    </button>
                    
                </div>
            </div>

            <div class="profile-info">
                <p class="profile-name">@ViewBag.UserName</p>
                <p class="profile-email">@ViewBag.UserEmail</p>

                <p class="profile-label">Contact Number</p>
                <p class="profile-value">
                    @(string.IsNullOrWhiteSpace(ViewBag.ContactNumber as string) ? "Not set" : ViewBag.ContactNumber)
                </p>

                <p class="profile-label">Address</p>
                <p class="profile-value">
                    @(string.IsNullOrWhiteSpace(ViewBag.Address as string) ? "Not set" : ViewBag.Address)
                </p>              

                <!-- ADD logout here -->
                <a href="@Url.Action("Logout","Account")" class="btn-logout" style="margin-top: 20px; align-self: flex-end;">
                    <i class="fa-solid fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>

        @* ── Edit Mode ── *@
        <div class="profile-card" id="editCard" style="display:none;">
            <div class="profile-card-header">
                <h2 class="profile-heading">Edit Profile</h2>
            </div>

            @using (Html.BeginForm("UpdateProfile", "Main", FormMethod.Post, new { @class = "edit-form" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <input type="text" class="form-input form-input-readonly" value="@ViewBag.UserName" readonly />
                </div>
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" class="form-input form-input-readonly" value="@ViewBag.UserEmail" readonly />
                </div>

                <div class="form-group">
                    <label class="form-label" for="coNum">Contact Number <span class="required">*</span></label>
                    <input type="tel"
                           id="coNum"
                           name="coNum"
                           class="form-input"
                           value="@ViewBag.ContactNumber"
                           placeholder="e.g. 09123456789"
                           maxlength="11"
                           pattern="\d{11}"
                           required />
                    <small class="form-hint">11-digit Philippine mobile number</small>
                </div>

                <div class="form-group">
                    <label class="form-label" for="address">Address <span class="required">*</span></label>
                    <textarea id="address"
                              name="address"
                              class="form-input form-textarea"
                              placeholder="e.g. 123 Main St, Dasmariñas, Cavite"
                              rows="3"
                              required>@ViewBag.Address</textarea>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="fa-solid fa-floppy-disk"></i> Save Changes
                    </button>
                    <button type="button" class="btn-cancel-outline" onclick="showViewMode()">
                        Cancel
                    </button>
                </div>
            }
        </div>

    </main>
</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i>
                <span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i>
                <span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i>
                <span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ── Alerts ── */
    .alert {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.9rem 1.2rem;
        border-radius: 10px;
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 1.2rem;
        max-width: 600px;
        width: 100%;
    }

    .alert-success {
        background-color: #d4edda;
        color: #2d6a3f;
        border: 1px solid #b8ddc5;
    }

    .alert-error {
        background-color: #fde8e8;
        color: #a04040;
        border: 1px solid #f5c6c6;
    }

    /* ── Profile Card Header ── */
    .profile-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .profile-card-header-actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .profile-heading {
        color: #6b5544;
        font-size: 32px;
        font-weight: 600;
        margin: 0;
        text-align: left;
    }

    /* ── Buttons ── */
    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: #6b5544;
        color: white;
        border: none;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s ease;
        text-decoration: none;
    }

        .btn-edit:hover {
            background-color: #5a4a3a;
        }

    .btn-logout {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: transparent;
        color: #a04040;
        border: 1.5px solid #a04040;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
    }

        .btn-logout:hover {
            background-color: #a04040;
            color: white;
        }

    .btn-cancel {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: #c9b5a3;
        color: #5a4a3a;
        border: none;
        padding: 0.5rem 1.2rem;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

        .btn-cancel:hover {
            background-color: #b9a593;
        }

    /* ── Edit Form ── */
    .edit-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .form-label {
        color: #6b5544;
        font-size: 15px;
        font-weight: 600;
    }

    .required {
        color: #a04040;
    }

    .form-input {
        padding: 0.65rem 0.9rem;
        border: 1.5px solid #c9b5a3;
        border-radius: 8px;
        font-size: 15px;
        color: #5a4a3a;
        background-color: #f5f0eb;
        transition: border-color 0.2s ease;
        width: 100%;
        box-sizing: border-box;
        font-family: inherit;
    }

        .form-input:focus {
            outline: none;
            border-color: #6b5544;
            background-color: #fff;
        }

    .form-input-readonly {
        background-color: #ece4db;
        color: #8a7060;
        cursor: not-allowed;
    }

    .form-textarea {
        resize: vertical;
        min-height: 80px;
    }

    .form-hint {
        color: #8a7060;
        font-size: 12px;
    }

    .form-actions {
        display: flex;
        gap: 0.8rem;
        margin-top: 0.5rem;
        flex-wrap: wrap;
    }

    .btn-save {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        background-color: #6b5544;
        color: white;
        border: none;
        padding: 0.65rem 1.6rem;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

        .btn-save:hover {
            background-color: #5a4a3a;
        }

    .btn-cancel-outline {
        display: inline-flex;
        align-items: center;
        background-color: transparent;
        color: #6b5544;
        border: 1.5px solid #6b5544;
        padding: 0.65rem 1.4rem;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

        .btn-cancel-outline:hover {
            background-color: #6b5544;
            color: white;
        }

    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    /* ── Nav Overlay ── */
    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Profile Layout ── */
    .profile-container {
        display: flex;
        min-height: calc(100vh - 200px);
        background-color: #f5f0eb;
    }

    .sidebar {
        width: 280px;
        flex-shrink: 0;
        background-color: #d4c4b5;
        min-height: 100%;
    }

    .profile-nav {
        display: flex;
        flex-direction: column;
        padding-top: 40px;
        min-height: calc(90vh - 100px);
        justify-content: space-between;
    }

        .profile-nav .nav-item {
            padding: 20px 35px;
            color: #5a4a3a;
            text-decoration: none;
            font-size: 18px;
            font-weight: 500;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
            display: block;
        }

            .profile-nav .nav-item:hover,
            .profile-nav .nav-item.active {
                background-color: #c9b5a3;
                border-left-color: #6b5544;
            }

    .profile-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 60px 40px;
    }

    /* ── Profile Card ── */
    .profile-card {
        background-color: #e8ddd1;
        border-radius: 30px;
        padding: 50px 60px;
        max-width: 600px;
        width: 100%;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .profile-info {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .profile-name {
        color: #5a4a3a;
        font-size: 24px;
        font-weight: 600;
        margin: 0;
    }

    .profile-email {
        color: #5a4a3a;
        font-size: 18px;
        margin: 0 0 10px 0;
    }

    .profile-label {
        color: #6b5544;
        font-size: 16px;
        font-weight: 600;
        margin: 14px 0 2px;
    }

    .profile-value {
        color: #5a4a3a;
        font-size: 15px;
        margin: 0;
    }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* =============================================
       DESKTOP (above 1024px)
    ============================================= */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            background-color: transparent !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            gap: 2.5rem !important;
            overflow: visible !important;
            transform: none !important;
            transition: none !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                letter-spacing: 0.5px !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    /* =============================================
       TABLET + MOBILE (max-width: 1024px)
    ============================================= */
    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            justify-content: flex-start !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
