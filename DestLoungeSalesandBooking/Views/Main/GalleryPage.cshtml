@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>
        <nav class="main-nav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>
        </nav>
        <div class="header-actions">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <a href="#" class="bell-icon" title="Notifications">
                <i class="fa-solid fa-bell"></i>
            </a>
        </div>
    </div>
</header>

<div class="gallery-page-container" ng-controller="DestLoungeSalesandBookingController">

    <div class="gallery-hero">
        <h1 class="gallery-hero-title">Our Work &amp; Your Words</h1>
        <p class="gallery-hero-sub">Browse our nail art gallery and read what our clients have to say</p>
    </div>

    <div class="tab-bar">
        <button class="tab-btn" ng-class="{'tab-active': activeTab === 'gallery'}" ng-click="setTab('gallery')">
            <i class="fa-solid fa-images"></i> Gallery
        </button>
        <button class="tab-btn" ng-class="{'tab-active': activeTab === 'reviews'}" ng-click="setTab('reviews')">
            <i class="fa-solid fa-star"></i> Reviews
        </button>
    </div>

    <!-- GALLERY TAB -->
    <div ng-show="activeTab === 'gallery'">
        <div class="gallery-grid" ng-show="pagedGallery.length > 0">
            <div class="gallery-item" ng-repeat="photo in pagedGallery" ng-click="openLightbox(photo)">
                <img ng-src="{{photo.imageUrl}}" alt="{{photo.caption}}">
                <div class="gallery-overlay">
                    <span class="gallery-caption">{{photo.caption}}</span>
                    <i class="fa-solid fa-magnifying-glass-plus"></i>
                </div>
            </div>
        </div>
        <div class="empty-state" ng-show="pagedGallery.length === 0">
            <i class="fa-regular fa-image"></i>
            <p>No photos available yet.</p>
        </div>
        <div class="pagination-bar" ng-show="galleryTotalPages > 1">
            <button class="page-btn" ng-click="galleryPrev()" ng-disabled="galleryPage === 1">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <span class="page-indicator">{{galleryPage}} / {{galleryTotalPages}}</span>
            <button class="page-btn" ng-click="galleryNext()" ng-disabled="galleryPage === galleryTotalPages">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- REVIEWS TAB -->
    <div ng-show="activeTab === 'reviews'">
        <div class="reviews-summary" ng-show="reviews.length > 0">
            <div class="avg-rating">
                <span class="avg-number">{{averageRating()}}</span>
                <div class="avg-stars">
                    <i ng-repeat="s in [1,2,3,4,5]" class="fa-star" ng-class="s <= roundedAvg() ? 'fa-solid' : 'fa-regular'"></i>
                </div>
                <span class="avg-label">out of 5 &bull; {{reviews.length}} review{{reviews.length !== 1 ? 's' : ''}}</span>
            </div>
        </div>

        <!-- FILTERS -->
        <div class="reviews-filter-bar">
            <div class="star-filters">
                <button class="star-filter-btn" ng-class="{'star-filter-active': reviewStarFilter === ''}" ng-click="reviewStarFilter = ''">All</button>
                <button class="star-filter-btn" ng-repeat="s in [5,4,3,2,1]" ng-class="{'star-filter-active': reviewStarFilter === s}" ng-click="reviewStarFilter = s">
                    <i class="fa-solid fa-star"></i> {{s}}
                </button>
            </div>
            <input type="text" class="review-search-input" ng-model="reviewSearch" placeholder="Search reviews...">
        </div>

        <div class="reviews-grid" ng-show="pagedReviews.length > 0">
            <div class="review-card" ng-repeat="review in pagedReviews | filter:customerReviewFilter">
                <div class="review-header">
                    <div class="review-stars">
                        <i ng-repeat="s in [1,2,3,4,5]" class="fa-star" ng-class="s <= review.rating ? 'fa-solid' : 'fa-regular'"></i>
                    </div>
                    <span class="review-date">{{review.date | date:'MMMM d, yyyy'}}</span>
                </div>
                <p class="review-text">&ldquo;{{review.reviewText}}&rdquo;</p>
                <div class="review-footer">
                    <span class="review-service"><i class="fa-solid fa-spa"></i> {{review.serviceAvailed}}</span>
                </div>
            </div>
        </div>
        <div class="empty-state" ng-show="pagedReviews.length === 0 || (pagedReviews | filter:customerReviewFilter).length === 0">
            <i class="fa-regular fa-star"></i>
            <p>No reviews match your filter.</p>
        </div>
        <div class="pagination-bar" ng-show="reviewsTotalPages > 1">
            <button class="page-btn" ng-click="reviewsPrev()" ng-disabled="reviewsPage === 1">
                <i class="fa-solid fa-chevron-left"></i>
            </button>
            <span class="page-indicator">{{reviewsPage}} / {{reviewsTotalPages}}</span>
            <button class="page-btn" ng-click="reviewsNext()" ng-disabled="reviewsPage === reviewsTotalPages">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <!-- LIGHTBOX -->
    <div class="lightbox-overlay" ng-show="lightboxPhoto" ng-click="closeLightbox()">
        <div class="lightbox-card" ng-click="$event.stopPropagation()">
            <button class="lightbox-close" ng-click="closeLightbox()"><i class="fa-solid fa-xmark"></i></button>
            <img ng-src="{{lightboxPhoto.imageUrl}}" alt="{{lightboxPhoto.caption}}" class="lightbox-img">
            <p class="lightbox-caption">{{lightboxPhoto.caption}}</p>
        </div>
    </div>

</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank"><i class="fa-brands fa-tiktok"></i><span>destlounge</span></a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank"><i class="fa-brands fa-facebook"></i><span>D'est Lounge</span></a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank"><i class="fa-brands fa-instagram"></i><span>destlounge</span></a>
        </div>
    </div>
</footer>

<style>
    .gallery-page-container {
        min-height: calc(120vh - 400px);
        background-color: #f5f0eb;
        padding-bottom: 3rem;
    }

    .gallery-hero {
        background-color: #e7dfd6;
        border-bottom: 3px solid #c1b2a5;
        text-align: center;
        padding: 3rem 2rem 2.5rem;
    }

    .gallery-hero-title {
        font-size: 3.5rem;
        font-weight: 400;
        color: #6b4423;
        margin: 0 0 0.5rem 0;
        font-family: Georgia, 'Times New Roman', serif;
        font-style: italic;
    }

    .gallery-hero-sub {
        font-size: 1rem;
        color: #8b6f47;
        font-weight: 500;
        letter-spacing: 0.5px;
        margin: 0;
    }

    .tab-bar {
        display: flex;
        justify-content: center;
        gap: 1rem;
        padding: 2rem 2rem 0;
    }

    .tab-btn {
        padding: 0.8rem 2.5rem;
        font-size: 1rem;
        font-weight: 600;
        border: 2.5px solid #c1b2a5;
        border-radius: 25px;
        background-color: white;
        color: #8b6f47;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        letter-spacing: 0.5px;
    }

        .tab-btn:hover {
            border-color: #6b4423;
            color: #6b4423;
            background-color: #f5f0eb;
        }

        .tab-btn.tab-active {
            background-color: #6b4423;
            border-color: #6b4423;
            color: white;
            box-shadow: 0 4px 12px rgba(107,68,35,0.3);
        }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        padding: 2rem;
        max-width: 1300px;
        margin: 0 auto;
    }

    .gallery-item {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        border: 3px solid #d4c4b0;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.12);
        cursor: pointer;
        aspect-ratio: 1/1;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .gallery-item:hover {
            transform: translateY(-4px);
            box-shadow: 6px 8px 20px rgba(0,0,0,0.2);
        }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s ease;
        }

        .gallery-item:hover img {
            transform: scale(1.06);
        }

    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(61,40,23,0.85));
        padding: 1.5rem 1rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .gallery-item:hover .gallery-overlay {
        opacity: 1;
    }

    .gallery-caption {
        color: white;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .gallery-overlay i {
        color: white;
        font-size: 1.3rem;
    }

    .reviews-summary {
        display: flex;
        justify-content: center;
        padding: 2rem 2rem 0;
    }

    .avg-rating {
        background-color: #e7dfd6;
        border: 2px solid #c1b2a5;
        border-radius: 16px;
        padding: 1.2rem 3rem;
        display: flex;
        align-items: center;
        gap: 1.2rem;
        box-shadow: 2px 2px 8px rgba(0,0,0,0.1);
    }

    .avg-number {
        font-size: 2.8rem;
        font-weight: 700;
        color: #6b4423;
        line-height: 1;
    }

    .avg-stars i {
        color: #d4a843;
        font-size: 1.3rem;
    }

    .avg-label {
        font-size: 0.9rem;
        color: #8b6f47;
        font-weight: 500;
    }

    .reviews-filter-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem 0;
        max-width: 1300px;
        margin: 0 auto;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .star-filters {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .star-filter-btn {
        padding: 0.5rem 1.1rem;
        font-size: 0.88rem;
        font-weight: 600;
        border: 2px solid #c1b2a5;
        border-radius: 20px;
        background-color: white;
        color: #8b6f47;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        gap: 0.3rem;
        font-family: 'Georgia', serif;
    }

        .star-filter-btn i {
            color: #d4a843;
        }

        .star-filter-btn:hover {
            border-color: #6b4423;
            color: #6b4423;
        }

        .star-filter-btn.star-filter-active {
            background-color: #6b4423;
            border-color: #6b4423;
            color: white;
        }

            .star-filter-btn.star-filter-active i {
                color: white;
            }

    .review-search-input {
        padding: 0.6rem 1.2rem;
        border: 2px solid #c1b2a5;
        border-radius: 20px;
        font-size: 0.9rem;
        color: #3d2817;
        font-family: 'Georgia', serif;
        outline: none;
        min-width: 220px;
        transition: border-color 0.3s;
        background-color: white;
    }

        .review-search-input:focus {
            border-color: #6b4423;
        }

    .reviews-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        padding: 2rem;
        max-width: 1300px;
        margin: 0 auto;
    }

    .review-card {
        background-color: white;
        border: 2px solid #d4c4b0;
        border-radius: 16px;
        padding: 1.8rem;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.08);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .review-card:hover {
            transform: translateY(-4px);
            box-shadow: 5px 8px 18px rgba(0,0,0,0.15);
        }

    .review-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .review-stars i {
        color: #d4a843;
        font-size: 1rem;
    }

    .review-date {
        font-size: 0.82rem;
        color: #a08060;
        font-style: italic;
    }

    .review-text {
        font-size: 0.97rem;
        color: #4a3428;
        line-height: 1.65;
        flex: 1;
        font-style: italic;
        margin: 0;
    }

    .review-footer {
        border-top: 1px solid #e7dfd6;
        padding-top: 0.8rem;
    }

    .review-service {
        font-size: 0.85rem;
        font-weight: 600;
        color: #6b4423;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .review-service i {
            color: #8b6f47;
        }

    .pagination-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.5rem;
        padding: 1rem 2rem 2rem;
    }

    .page-btn {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        border: 2px solid #c1b2a5;
        background-color: white;
        color: #6b4423;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

        .page-btn:hover:not([disabled]) {
            background-color: #6b4423;
            border-color: #6b4423;
            color: white;
        }

        .page-btn[disabled] {
            opacity: 0.35;
            cursor: not-allowed;
        }

    .page-indicator {
        font-size: 1rem;
        font-weight: 600;
        color: #5d4037;
        min-width: 60px;
        text-align: center;
    }

    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        color: #b0907a;
    }

        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            display: block;
        }

        .empty-state p {
            font-size: 1.1rem;
            font-style: italic;
        }

    .lightbox-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(30,15,5,0.88);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .lightbox-card {
        position: relative;
        max-width: 700px;
        width: 100%;
        background-color: #f5f0eb;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }

    .lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        background-color: rgba(61,40,23,0.8);
        border: none;
        border-radius: 50%;
        width: 38px;
        height: 38px;
        color: white;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background-color 0.2s ease;
        z-index: 1;
    }

        .lightbox-close:hover {
            background-color: #3d2817;
        }

    .lightbox-img {
        width: 100%;
        max-height: 70vh;
        object-fit: contain;
        display: block;
    }

    .lightbox-caption {
        text-align: center;
        padding: 1rem;
        font-size: 0.95rem;
        color: #5d4037;
        font-weight: 600;
        margin: 0;
    }

    @@media (max-width: 1024px) {
        .gallery-grid, .reviews-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 640px) {
        .gallery-grid, .reviews-grid {
            grid-template-columns: 1fr;
        }

        .gallery-hero-title {
            font-size: 2.5rem;
        }

        .tab-btn {
            padding: 0.7rem 1.5rem;
            font-size: 0.9rem;
        }

        .avg-rating {
            flex-direction: column;
            text-align: center;
            gap: 0.5rem;
            padding: 1rem 2rem;
        }

        .reviews-filter-bar {
            flex-direction: column;
            align-items: flex-start;
        }

        .review-search-input {
            width: 100%;
            min-width: unset;
        }
    }
</style>