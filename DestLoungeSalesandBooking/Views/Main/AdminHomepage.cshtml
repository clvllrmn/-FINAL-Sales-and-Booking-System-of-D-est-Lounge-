@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<div ng-app="DestLoungeSalesandBookingModule" ng-controller="DestLoungeSalesandBookingController">
    @Html.AntiForgeryToken()

    <!-- Edit Modal -->
    <div class="edit-modal-overlay" id="editModal" style="display:none;">
        <div class="edit-modal">
            <div class="modal-header">
                <h3 id="modalTitle">Edit Text</h3>
                <button class="modal-close" onclick="closeEditModal()"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="modal-body">
                <textarea id="modalInput" class="modal-input" rows="4"></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn-cancel" onclick="closeEditModal()">Cancel</button>
                <button class="btn-save" onclick="saveEdit()"><i class="fa-solid fa-floppy-disk"></i> Save</button>
            </div>
        </div>
    </div>

    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="logo-container">
            <a href="@Url.Action("AdminHomepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminHomepage","Main")" class="nav-item active">HOME</a>
            <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
            <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
            <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
            <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item">FAQs</a>
            <a href="@Url.Action("AdminInboxPage","Main")" class="nav-item">INBOX</a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
            <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item">GALLERY</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="main-content">

        <!-- Banner Section -->
        <div class="banner-container">
            <div class="banner-text">
                <div class="editable-block">
                    <h1 class="hello">{{bannerText.hello}}</h1>
                    <div class="inline-controls">
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_hello', bannerText.hello, 'Banner — Hello')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
                <div class="editable-block">
                    <h2 class="youre-looking">{{bannerText.youre_looking}}</h2>
                    <div class="inline-controls">
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_looking', bannerText.youre_looking, 'Banner — You\'re Looking')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
                <div class="editable-block">
                    <h2 class="gorgeous">{{bannerText.gorgeous}}</h2>
                    <div class="inline-controls">
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_gorgeous', bannerText.gorgeous, 'Banner — Gorgeous')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
                <div class="editable-block">
                    <h2 class="today">{{bannerText.today}}</h2>
                    <div class="inline-controls">
                        <button class="inline-edit-btn" ng-click="openEditModal('banner_today', bannerText.today, 'Banner — Today')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Services Section -->
        <div class="services-intro">
            <div class="divider-line"></div>
            <div class="service-text">
                <div class="editable-block centered">
                    <h3 class="service-title">{{serviceInfo.title}}</h3>
                    <div class="inline-controls">
                        <button class="inline-edit-btn" ng-click="openEditModal('service_title', serviceInfo.title, 'Service — Title')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
                <div class="editable-block centered">
                    <p class="service-tagline">{{serviceInfo.tagline}}</p>
                    <div class="inline-controls">
                        <button class="inline-edit-btn" ng-click="openEditModal('service_tagline', serviceInfo.tagline, 'Service — Tagline')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Polaroid Images Section -->
        <div class="polaroid-section">
            <div class="polaroid-card">
                <div class="admin-controls">
                    <button class="edit-btn" onclick="editImage(1)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    <button class="delete-btn" onclick="deleteImage(1)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                </div>
                <div class="polaroid-image"><img src="~/Content/Pictures/nail1.jpg" alt="Nail Design 1"></div>
                <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
            </div>
            <div class="polaroid-card">
                <div class="admin-controls">
                    <button class="edit-btn" onclick="editImage(2)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    <button class="delete-btn" onclick="deleteImage(2)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                </div>
                <div class="polaroid-image"><img src="~/Content/Pictures/nail2.jpg" alt="Nail Design 2"></div>
                <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
            </div>
            <div class="polaroid-card">
                <div class="admin-controls">
                    <button class="edit-btn" onclick="editImage(3)" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    <button class="delete-btn" onclick="deleteImage(3)" title="Delete"><i class="fa-solid fa-trash"></i></button>
                </div>
                <div class="polaroid-image"><img src="~/Content/Pictures/nail3.jpg" alt="Nail Design 3"></div>
                <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
            </div>
        </div>

        <!-- Add Photo Button -->
        <div class="add-photo-container">
            <button class="add-photo-btn" onclick="openAddPhotoModal()">
                <i class="fa-solid fa-plus"></i> Add Photo
            </button>
        </div>

        <!-- D'est Description Box -->
        <div class="dest-description">
            <div class="description-header">
                <div class="editable-block centered">
                    <h3 class="dest-title">{{destInfo.title}}</h3>
                    <div class="inline-controls">
                        <button class="inline-edit-btn dark" ng-click="openEditModal('dest_title', destInfo.title, 'D\'est — Title')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                    </div>
                </div>
            </div>
            <div class="editable-block centered">
                <p class="dest-text">{{destInfo.text}}</p>
                <div class="inline-controls">
                    <button class="inline-edit-btn dark" ng-click="openEditModal('dest_text', destInfo.text, 'D\'est — Description')" title="Edit"><i class="fa-solid fa-pen"></i></button>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer>
            <div class="footer-container">
                <h2 class="footer-title">Follow our Socials!</h2>
                <div class="social-links">
                    <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                        <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
                    </a>
                    <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                        <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
                    </a>
                    <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                        <i class="fa-brands fa-instagram"></i><span>destlounge</span>
                    </a>
                </div>
            </div>
        </footer>
    </div>
</div>

<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

body { margin: 0; padding: 0; font-family: 'Georgia', serif; background-color: #d4c4b0; }

/* Sidebar */
.sidebar {
    position: fixed; left: 0; top: 0; width: 10%; min-width: 9rem;
    height: 100vh; background-color: #e7dfd6;
    display: flex; flex-direction: column; align-items: center;
    padding: 1.25rem 0; z-index: 1000;
}
.logo-container { margin-bottom: 2rem; }
.sidebar-logo { width: 3.5rem; height: auto; }
.sidebar-nav { flex: 1; display: flex; flex-direction: column; gap: 0.3rem; width: 100%; }
.nav-item {
    color: #5a4a3a; text-decoration: none; padding: 1rem 0.625rem;
    font-size: 1rem; font-weight: 500; text-align: center;
    transition: background-color 0.3s; letter-spacing: 0.0625rem; display: block;
}
.nav-item:hover { background-color: rgba(90,74,58,0.1); }
.nav-item.active { background-color: rgba(139,111,71,0.3); border-left: 0.25rem solid #8b6f47; }
.sidebar-footer { margin-top: auto; padding: 1.25rem 0; }
.admin-link {
    color: #5a4a3a; text-decoration: none; font-size: 0.75rem;
    display: flex; flex-direction: column; align-items: center; gap: 0.3125rem;
}
.admin-link i { font-size: 1.25rem; }

/* Main Content */
.main-content { margin-left: 10%; min-height: 100vh; background-color: #d4c4b0; }

/* Inline Editable Blocks */
    /* Editable Blocks - button floats, text stays untouched */
    .editable-block {
        position: relative;
        display: block;
        border-radius: 0.5rem;
        padding: 0.25rem 0.5rem;
        transition: background 0.2s;
    }

        .editable-block:hover {
            background: rgba(139, 111, 71, 0.12);
            outline: 2px dashed rgba(139, 111, 71, 0.5);
        }

    .inline-controls {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s;
        position: absolute;
        top: 50%;
        right: -2.75rem;
        transform: translateY(-50%);
        z-index: 10;
    }

    /* ADD THIS — extends the hover zone to cover the gap between text and button */
    .editable-block::after {
        content: '';
        position: absolute;
        top: 0;
        right: -2.75rem;
        width: 2.75rem;
        height: 100%;
    }

    .editable-block:hover .inline-controls {
        opacity: 1;
        pointer-events: all;
    }

    .inline-edit-btn {
        background: white;
        border: none;
        border-radius: 50%;
        width: 2rem;
        height: 2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #4a7c59;
        box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        transition: all 0.2s;
        font-size: 0.75rem;
        position: relative;
        z-index: 10;
    }

        .inline-edit-btn:hover {
            background: #4a7c59;
            color: white;
            transform: scale(1.1);
        }

        .inline-edit-btn.dark {
            background: rgba(255,255,255,0.85);
            color: #5a4a3a;
        }

            .inline-edit-btn.dark:hover {
                background: #5a4a3a;
                color: white;
            }

/* Edit Modal */
.edit-modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.45);
    z-index: 9999; display: flex; align-items: center; justify-content: center;
    backdrop-filter: blur(3px);
}
.edit-modal {
    background: white; border-radius: 0.75rem; width: 32rem; max-width: 90vw;
    box-shadow: 0 1.5rem 3rem rgba(0,0,0,0.25); overflow: hidden;
    animation: slideUp 0.25s ease;
}
@@keyframes slideUp {
    from { transform: translateY(1.5rem); opacity: 0; }
    to   { transform: translateY(0);      opacity: 1; }
}
.modal-header {
    background: #e8dfd5; padding: 1rem 1.5rem;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid #ddd;
}
.modal-header h3 { font-size: 1.1rem; color: #5a4a3a; font-weight: 700; }
.modal-close { background: none; border: none; font-size: 1.1rem; color: #888; cursor: pointer; transition: color 0.2s; }
.modal-close:hover { color: #c84b4b; }
.modal-body { padding: 1.5rem; }
.modal-input {
    width: 100%; border: 1.5px solid #ddd; border-radius: 0.375rem;
    padding: 0.75rem; font-family: 'Georgia', serif; font-size: 0.95rem;
    color: #333; resize: vertical; transition: border-color 0.2s;
}
.modal-input:focus { outline: none; border-color: #8b6f47; }
.modal-footer {
    padding: 1rem 1.5rem; display: flex; justify-content: flex-end;
    gap: 0.75rem; border-top: 1px solid #eee;
}
.btn-cancel {
    background: #f0f0f0; color: #555; border: none;
    padding: 0.625rem 1.25rem; border-radius: 0.375rem;
    font-size: 0.9rem; cursor: pointer; transition: background 0.2s;
}
.btn-cancel:hover { background: #ddd; }
.btn-save {
    background: #5a4a3a; color: white; border: none;
    padding: 0.625rem 1.5rem; border-radius: 0.375rem;
    font-size: 0.9rem; font-weight: 600; cursor: pointer;
    display: inline-flex; align-items: center; gap: 0.375rem; transition: all 0.2s;
}
.btn-save:hover { background: #3a2a1a; transform: translateY(-1px); box-shadow: 0 4px 10px rgba(0,0,0,0.2); }

/* Banner */
.banner-container {
    padding: 3.75rem 5rem; background-color: #e8dfd5;
    border: 0.1875rem solid #5a4a3a; margin: 2.5rem 3.75rem;
}
.banner-text { text-align: center; }
.hello { font-size: 5rem; font-weight: 900; color: #6b4423; margin: 0; letter-spacing: 0.1em; }
.youre-looking {
    font-size: 4.5rem; font-weight: 400; color: #6b4423; margin: 0.2rem 0;
    letter-spacing: 0.15em; text-transform: uppercase;
    -webkit-text-stroke: 0.09375rem #6b4423; -webkit-text-fill-color: transparent;
}
.gorgeous {
    font-size: 5.5rem; font-weight: 400; color: #6b4423; margin: 0.2rem 0;
    font-family: 'Brush Script MT', cursive; font-style: italic;
}
.today {
    font-size: 5rem; font-weight: 400; color: #6b4423; margin: 0;
    letter-spacing: 0.15em; text-transform: uppercase;
    -webkit-text-stroke: 0.09375rem #6b4423; -webkit-text-fill-color: transparent;
}

/* Services */
.services-intro { text-align: center; padding: 3.75rem 3.75rem 2.5rem; }
.divider-line { width: 80%; height: 0.25rem; background-color: #5a4a3a; margin: 0 auto 1.875rem; border-radius: 0.125rem; }
.service-title { font-size: 3.5rem; font-weight: bold; font-style: italic; color: #8b6f47; margin-bottom: 0.625rem; font-family: 'Brush Script MT', cursive; }
.service-tagline { font-size: 1rem; color: #5a4a3a; font-weight: 600; }

/* Polaroid */
.polaroid-section { display: flex; justify-content: center; gap: 2.5rem; padding: 2.5rem 3.75rem; flex-wrap: wrap; }
.polaroid-card {
    background: white; padding: 1.25rem; padding-bottom: 0.9375rem;
    box-shadow: 0 0.25rem 0.75rem rgba(0,0,0,0.15); width: 13.75rem;
    position: relative; transform: rotate(-2deg); transition: transform 0.3s;
}
.polaroid-card:nth-child(2) { transform: rotate(1deg); }
.polaroid-card:nth-child(3) { transform: rotate(-1deg); }
.polaroid-card:hover { transform: rotate(0deg) scale(1.05); }
.admin-controls {
    position: absolute; top: 0.5rem; right: 0.5rem;
    display: flex; gap: 0.3125rem; z-index: 10;
    opacity: 0; transition: opacity 0.2s;
}
.polaroid-card:hover .admin-controls { opacity: 1; }
.edit-btn, .delete-btn {
    background: rgba(255,255,255,0.95); border: none; border-radius: 50%;
    width: 2rem; height: 2rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.3s; box-shadow: 0 0.125rem 0.375rem rgba(0,0,0,0.2);
}
.edit-btn { color: #4a7c59; }
.edit-btn:hover { background: #4a7c59; color: white; transform: scale(1.1); }
.delete-btn { color: #c84b4b; }
.delete-btn:hover { background: #c84b4b; color: white; transform: scale(1.1); }
.polaroid-image { width: 100%; height: 13.75rem; overflow: hidden; margin-bottom: 0.9375rem; border: 0.0625rem solid #e0e0e0; }
.polaroid-image img { width: 100%; height: 100%; object-fit: cover; }
.polaroid-caption { text-align: center; padding: 0.3125rem 0; color: #c84b4b; font-size: 1.25rem; }

/* Add Photo */
.add-photo-container { text-align: center; padding: 1.875rem; }
.add-photo-btn {
    background-color: #5a4a3a; color: white; border: none;
    padding: 0.9375rem 2.5rem; border-radius: 1.875rem; font-size: 1rem;
    cursor: pointer; transition: all 0.3s; font-weight: 600;
    box-shadow: 0 0.25rem 0.5rem rgba(0,0,0,0.2);
    display: inline-flex; align-items: center; gap: 0.5rem;
}
.add-photo-btn:hover { background-color: #3a2a1a; transform: translateY(-0.125rem); box-shadow: 0 0.375rem 0.75rem rgba(0,0,0,0.3); }

/* D'est Description */
.dest-description {
    background-color: rgba(198,175,151,0.85); border-radius: 3.75rem;
    padding: 3.125rem 3.75rem; margin: 3.75rem auto; max-width: 37.5rem;
    text-align: center; box-shadow: 0 0.25rem 0.75rem rgba(0,0,0,0.1);
}
.description-header { display: flex; justify-content: center; margin-bottom: 1.25rem; }
.dest-title { font-size: 3.5rem; font-weight: bold; font-style: italic; color: #5a4a3a; font-family: 'Brush Script MT', cursive; }
.dest-text { font-size: 1rem; line-height: 1.8; color: #5a4a3a; }

/* Footer */
footer { background-color: #e7d7c8; border: 2px solid #d4c4b0; border-left: none; border-right: none; padding: 2.5rem 3rem; text-align: center; }
.footer-title { font-size: 2.5rem; font-weight: 700; color: #6b4423; margin: 0 0 2rem 0; font-style: italic; text-shadow: 2px 2px 4px rgba(0,0,0,0.3); }
.social-links { display: flex; justify-content: center; gap: 5rem; }
.social-item { display: flex; align-items: center; gap: 0.75rem; text-decoration: none; color: #5a4a3a; transition: transform 0.3s; }
.social-item:hover { transform: translateY(-0.1875rem); }
.social-item i { font-size: 2.25rem; }
.social-item span { font-size: 1rem; font-weight: 500; }

@@media (max-width: 48rem) {
    .sidebar { width: 6%; min-width: 5rem; }
    .main-content { margin-left: 6%; }
    .nav-item { font-size: 0.65rem; padding: 0.75rem 0.3125rem; }
    .polaroid-section { flex-direction: column; align-items: center; }
    .banner-container { padding: 2.5rem 1.875rem; margin: 1.25rem 1.875rem; }
    .hello { font-size: 3rem; }
    .youre-looking { font-size: 2.25rem; }
    .gorgeous { font-size: 3.5rem; }
    .today { font-size: 2.625rem; }
}
</style>

<script>
    var _currentContentType = null;

    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        _currentContentType = null;
    }

    function saveEdit() {
        var newValue = document.getElementById('modalInput').value.trim();
        if (!newValue) { alert('Value cannot be empty.'); return; }

        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;

        fetch('/HomePageContent/UpdateContent', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'contentType=' + encodeURIComponent(_currentContentType) +
                '&contentValue=' + encodeURIComponent(newValue) +
                '&__RequestVerificationToken=' + encodeURIComponent(token)
        })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data.success) {
                    closeEditModal();
                    var scope = angular.element(document.querySelector('[ng-controller]')).scope();
                    if (scope) { scope.loadHomepageContent(); scope.$apply(); }
                } else {
                    alert('Save failed: ' + data.message);
                }
            })
            .catch(function () { alert('Network error. Please try again.'); });
    }

    function editImage(imageId) { alert('Edit image ' + imageId); }
    function deleteImage(imageId) { if (confirm('Delete this photo?')) alert('Deleted image ' + imageId); }

    document.addEventListener('click', function (e) {
        if (e.target.id === 'editModal') closeEditModal();
    });
</script>