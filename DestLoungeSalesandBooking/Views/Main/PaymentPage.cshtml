@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header ng-controller="DestLoungeSalesandBookingController"
        ng-init="loadNotifications()">

    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <!-- MOBILE ACTIONS -->
            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }

                <!-- NOTIFICATION (MOBILE) -->
                <button type="button"
                        ng-click="toggleNotif($event)"
                        style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037;">
                    <i class="fa-solid fa-bell"></i>

                    <span ng-if="notifications.length > 0"
                          style="position:absolute; top:-8px; right:-10px; background:red; color:white; border-radius:50%; padding:2px 6px; font-size:11px;">
                        {{notifications.length}}
                    </span>
                </button>

                <div ng-show="showNotif"
                     style="position:absolute; right:0; top:35px; width:260px; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999;">
                    <div style="padding:10px; font-weight:bold; border-bottom:1px solid #eee;">
                        Notifications
                    </div>

                    <div ng-if="!notifications.length" style="padding:10px;">
                        No notifications
                    </div>

                    <div ng-repeat="n in notifications"
                         style="padding:10px; border-bottom:1px solid #eee; cursor:pointer;"
                         ng-click="goToBooking()">
                        {{n.Message || n.message}}
                    </div>
                </div>
            </div>
        </nav>

        <!-- DESKTOP ACTIONS -->
        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }

            <!-- NOTIFICATION (DESKTOP) -->
            <button type="button"
                    ng-click="toggleNotif($event)"
                    style="background:none; border:none; cursor:pointer; font-size:22px; position:relative; color:#5d4037;">
                <i class="fa-solid fa-bell"></i>

                <span ng-if="notifications.length > 0"
                      style="position:absolute; top:-8px; right:-10px; background:red; color:white; border-radius:50%; padding:2px 6px; font-size:11px;">
                    {{notifications.length}}
                </span>
            </button>

            <div ng-show="showNotif"
                 style="position:absolute; right:0; top:35px; width:260px; background:white; border:1px solid #ccc; border-radius:10px; z-index:99999;">
                <div style="padding:10px; font-weight:bold; border-bottom:1px solid #eee;">
                    Notifications
                </div>

                <div ng-if="!notifications.length" style="padding:10px;">
                    No notifications
                </div>

                <div ng-repeat="n in notifications"
                     style="padding:10px; border-bottom:1px solid #eee; cursor:pointer;"
                     ng-click="goToBooking()">
                    {{n.Message || n.message}}
                </div>
            </div>
        </div>

        <!-- HAMBURGER -->
        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div class="payment-page-wrapper"
     ng-controller="DestLoungeSalesandBookingController"
     ng-init="loadPaymentInfo(); loadPaymentSummary()">

    <div class="service-summary-card" ng-if="bookingSummary">
        <h2>Service Summary</h2>

        <div class="summary-box">
            <div class="summary-row">
                <span><i class="fa fa-user"></i> Nail Tech</span>
                <strong>{{bookingSummary.nailTech}}</strong>
            </div>

            <div class="summary-row">
                <span><i class="fa fa-calendar"></i> Date</span>
                <strong>{{bookingSummary.bookingDate}}</strong>
            </div>

            <div class="summary-row">
                <span><i class="fa fa-clock"></i> Time</span>
                <strong>{{bookingSummary.startTime}}</strong>
            </div>

            <hr />

            <div class="service-line">
                <span>{{bookingSummary.serviceName}}</span>
                <strong>₱{{bookingSummary.price | number:2}}</strong>
            </div>

            <div class="total-line">
                <span>Total</span>
                <strong>₱{{bookingSummary.total | number:2}}</strong>
            </div>

            <div class="downpayment-line">
                <span>Downpayment (40%)</span>
                <strong>₱{{bookingSummary.downpayment | number:2}}</strong>
            </div>
        </div>
    </div>

    <div class="payment-form-card">
        <h1>Complete Your Booking</h1>

        <div class="payment-box">
            <h2>Send Downpayment (40%)</h2>

            <div class="gcash-box">
                <strong>GCash</strong>
                <p>{{paymentInfo.gcash}}</p>
            </div>

            <div class="qr-section" ng-if="paymentInfo.qr">
                <label>Scan QR Code: </label>
                <img ng-src="{{paymentInfo.qr}}" alt="QR Code" class="qr-image" />
            </div>

            <div class="upload-section">
                <label>Upload Receipt</label>
                <input type="file" id="receiptUpload" file-model="bookingReceipt" />
            </div>

            <button type="button" class="submit-btn" ng-click="submitPayment()">
                Submit Booking
            </button>
        </div>
    </div>
</div>



<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i>
                <span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i>
                <span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i>
                <span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    *, *::before, *::after {
        box-sizing: border-box;
    }

    body {
        overflow-x: hidden;
        margin: 0;
        padding: 0;
    }

    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    /* ── Nav Overlay ── */
    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Payment Page ── */
    .payment-container {
        padding: 80px 40px;
        background: #f5f0eb;
        min-height: calc(100vh - 140px);
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .payment-title {
        font-size: 36px;
        color: #6b5544;
        margin-bottom: 30px;
        font-family: 'Georgia', serif;
        font-weight: 600;
    }

    .payment-card {
        background: #e8ddd1;
        padding: 40px;
        border-radius: 25px;
        width: 100%;
        max-width: 500px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .payment-subtitle {
        margin-bottom: 20px;
        color: #5a4a3a;
        font-size: 24px;
        font-family: 'Georgia', serif;
        font-weight: 600;
    }

    .payment-methods {
        display: flex;
        flex-direction: column;
        gap: 15px;
        margin-bottom: 25px;
    }

    .method-box {
        background: #c9b5a3;
        padding: 15px;
        border-radius: 10px;
    }

        .method-box h3 {
            margin: 0 0 8px 0;
            color: #5a4a3a;
            font-size: 16px;
            font-weight: 600;
        }

        .method-box p {
            margin: 0;
            color: #3d2a1c;
            font-size: 14px;
            font-weight: 500;
        }

    .qr-section {
        margin-bottom: 25px;
        text-align: center;
    }

        .qr-section h3 {
            margin: 0 0 10px 0;
            color: #5a4a3a;
            font-size: 16px;
            font-weight: 600;
        }

    .qr-image {
        width: 200px;
        height: auto;
        border: 2px solid #c9b5a3;
        border-radius: 10px;
        padding: 10px;
        background: white;
    }
    .qr-section label {
        display: block;
        margin-bottom: 10px;
        font-weight: 600;
        color: #6f4e37;
    }

    .upload-section {
        margin-bottom: 25px;
    }

        .upload-section label {
            display: block;
            margin-bottom: 8px;
            color: #5a4a3a;
            font-weight: 600;
            font-size: 14px;
        }

        .upload-section input {
            width: 100%;
            padding: 10px;
            border: 2px solid #c9b5a3;
            border-radius: 10px;
            background: white;
            cursor: pointer;
            box-sizing: border-box;
        }

            .upload-section input:hover {
                border-color: #6b5544;
            }

    .btn-submit {
        width: 100%;
        padding: 15px;
        background: #6b5544;
        color: white;
        border: none;
        border-radius: 20px;
        font-weight: 600;
        cursor: pointer;
        font-size: 16px;
        transition: all 0.3s ease;
    }

        .btn-submit:hover {
            background: #5a4635;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

    .payment-page-wrapper {
        display: flex;
        gap: 30px;
        justify-content: center;
        align-items: flex-start;
        flex-wrap: wrap;
        padding: 40px 20px;
    }

    .payment-form-card,
    .service-summary-card {
        background: #e8dfd6;
        border-radius: 24px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.12);
        padding: 30px;
    }

    .payment-form-card {
        width: 480px;
    }

        .payment-form-card h1,
        .service-summary-card h2 {
            text-align: center;
            color: #6f4e37;
            font-weight: bold;
            margin-bottom: 20px;
        }

    .payment-box h2 {
        color: #6f4e37;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .gcash-box {
        background: #ccb9a8;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 20px;
        color: #5b3d2e;
    }

    .qr-section {
        text-align: center;
        margin-bottom: 20px;
    }

    .qr-image {
        width: 190px;
        height: auto;
        border-radius: 10px;
        border: 1px solid #b89f8a;
    }

    .upload-section {
        margin-bottom: 20px;
    }

        .upload-section label {
            display: block;
            margin-bottom: 8px;
            color: #6f4e37;
            font-weight: 600;
        }

    .submit-btn {
        width: 100%;
        background: #7a5a44;
        color: white;
        border: none;
        border-radius: 30px;
        padding: 14px;
        font-size: 18px;
        font-weight: bold;
        cursor: pointer;
    }

        .submit-btn:hover {
            opacity: 0.9;
        }

    .service-summary-card {
        width: 350px;
    }

    .summary-box {
        background: #f8f8f8;
        border-radius: 18px;
        padding: 20px;
        border: 1px solid #dbcaba;
    }

    .summary-row,
    .service-line,
    .total-line,
    .downpayment-line {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 14px;
        color: #6f4e37;
    }

        .summary-row span,
        .service-line span,
        .total-line span,
        .downpayment-line span {
            font-size: 16px;
        }

    .total-line {
        font-size: 24px;
        font-weight: bold;
        margin-top: 18px;
    }

    .downpayment-line {
        border-top: 1px dashed #c9b5a4;
        padding-top: 14px;
        font-size: 20px;
        font-weight: bold;
    }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-container {
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* =============================================
       DESKTOP (above 1024px)
    ============================================= */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            top: auto !important;
            right: auto !important;
            left: auto !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            background-color: transparent !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            justify-content: flex-start !important;
            gap: 2.5rem !important;
            overflow: visible !important;
            transform: none !important;
            transition: none !important;
            z-index: auto !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                letter-spacing: 0.5px !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    /* =============================================
       TABLET + MOBILE (max-width: 1024px)
    ============================================= */
    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            justify-content: flex-start !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
            box-shadow: -4px 0 20px rgba(0,0,0,0.15) !important;
            transform: translateX(100%) !important;
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1) !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            margin: 0 !important;
        }

            .main-nav.open {
                transform: translateX(0) !important;
            }

            .main-nav a {
                width: 100% !important;
                padding: 0.9rem 0 !important;
                font-size: 1rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                letter-spacing: 0.05em !important;
                display: block !important;
                text-decoration: none !important;
                background: none !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 1px solid #e0d5c8 !important;
                }

        .mobile-nav-actions {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #d4c4b0;
            gap: 0;
        }

            .mobile-nav-actions a {
                display: flex !important;
                align-items: center;
                gap: 0.6rem;
                padding: 0.75rem 0 !important;
                font-size: 0.97rem !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                width: 100% !important;
                font-weight: 600 !important;
                text-decoration: none !important;
                background: none !important;
            }

                .mobile-nav-actions a:last-child {
                    border-bottom: none !important;
                }

        .payment-container {
            padding: 50px 24px;
        }

        .payment-title {
            font-size: 28px;
            text-align: center;
        }

        .payment-card {
            padding: 30px 24px;
        }

        .payment-subtitle {
            font-size: 20px;
        }

        .qr-image {
            width: 160px;
        }
    }

    /* =============================================
       MOBILE (max-width: 768px)
    ============================================= */
    @@media (max-width: 768px) {
        .payment-container {
            padding: 36px 16px;
            min-height: calc(100vh - 120px);
        }

        .payment-title {
            font-size: 24px;
            margin-bottom: 20px;
        }

        .payment-card {
            padding: 24px 18px;
            border-radius: 18px;
        }

        .payment-subtitle {
            font-size: 18px;
            margin-bottom: 16px;
        }

        .method-box {
            padding: 12px;
        }

            .method-box h3 {
                font-size: 14px;
            }

            .method-box p {
                font-size: 13px;
            }

        .qr-image {
            width: 140px;
        }

        .upload-section label {
            font-size: 13px;
        }

        .btn-submit {
            padding: 13px;
            font-size: 15px;
        }

        footer {
            padding: 1.5rem 1rem;
        }

        .footer-title {
            font-size: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .social-links {
            gap: 1.5rem;
        }

        .social-item i {
            font-size: 1.25rem;
        }

        .social-item span {
            font-size: 0.8rem;
        }
    }

    /* =============================================
       SMALL MOBILE (max-width: 480px)
    ============================================= */
    @@media (max-width: 480px) {
        .payment-container {
            padding: 28px 12px;
        }

        .payment-title {
            font-size: 22px;
        }

        .payment-card {
            padding: 20px 14px;
            border-radius: 14px;
        }

        .payment-subtitle {
            font-size: 16px;
        }

        .qr-image {
            width: 120px;
        }

        .btn-submit {
            padding: 12px;
            font-size: 14px;
            border-radius: 14px;
        }
    }
</style>

@section scripts {
    <script>
        (function () {
            var btn = document.getElementById('hamburgerBtn');
            var nav = document.getElementById('mainNav');
            var overlay = document.getElementById('navOverlay');

            function openMenu() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeMenu() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', function () {
                nav.classList.contains('open') ? closeMenu() : openMenu();
            });

            overlay.addEventListener('click', closeMenu);

            nav.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', closeMenu);
            });
        })();
    </script>
}