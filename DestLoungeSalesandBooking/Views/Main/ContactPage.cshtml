@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

@Html.AntiForgeryToken()

<div ng-app="DestLoungeSalesandBooking" ng-controller="DestLoungeSalesandBookingController">

    <header>
        <div class="header-container">
            <div class="logo">
                <a href="@Url.Action("Homepage","Main")">
                    <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
                </a>
            </div>

            <nav class="main-nav" id="mainNav">
                <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
                <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
                <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
                <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
                <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

                <div class="mobile-nav-actions">
                    @if (isLoggedIn)
                    {
                        <a href="@Url.Action("ProfilePage","Main")">
                            <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                        </a>
                    }
                    else
                    {
                        <a href="@Url.Action("LoginPage","Main")">
                            <i class="fa-regular fa-user"></i> LOGIN
                        </a>
                    }
                    <a href="#">
                        <i class="fa-solid fa-bell"></i> Notifications
                    </a>
                </div>
            </nav>

            <div class="header-actions desktop-only">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")" class="login-link">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <a href="#" class="bell-icon" title="Notifications">
                    <i class="fa-solid fa-bell"></i>
                </a>
            </div>

            <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
                <span></span>
                <span></span>
                <span></span>
            </button>
        </div>

        <div class="nav-overlay" id="navOverlay"></div>
    </header>

    <!-- Contact Section -->
    <div class="contact-container">

        <!-- Map Section -->
        <div class="map-section">
            <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d3860.395937262591!2d121.095273!3d14.633452000000002!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3397b9004a5de963%3A0x7fad844f4bae6342!2zROKAmWVzdCBMb3VuZ2U!5e0!3m2!1sen!2sph!4v1770789541301!5m2!1sen!2sph"
                    width="100%"
                    height="100%"
                    style="border:0;"
                    allowfullscreen=""
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>

        <!-- Contact Info Section -->
        <div class="contact-info">
            <h1 class="contact-title">D'est Lounge</h1>

            <!-- Loading state -->
            <div ng-if="contactInfo.length === 0" class="no-data-message">
                <p>Loading contact information...</p>
            </div>

            <!-- Contact items from database -->
            <div class="info-item" ng-repeat="contact in contactInfo">
                <i ng-class="contact.icon"></i>
                <div>
                    <h3>{{ contact.label }}</h3>
                    <p ng-if="contact.infoType === 'phone'">
                        <a href="tel:{{ contact.value }}">{{ contact.value }}</a>
                    </p>
                    <p ng-if="contact.infoType === 'email'">
                        <a href="mailto:{{ contact.value }}">{{ contact.value }}</a>
                    </p>
                    <div ng-if="contact.infoType !== 'phone' && contact.infoType !== 'email'"
                         ng-bind-html="contact.value"></div>
                </div>
            </div>
        </div>

    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <h2 class="footer-title">Follow our Socials!</h2>
            <div class="social-links">
                <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                    <i class="fa-brands fa-tiktok"></i>
                    <span>destlounge</span>
                </a>
                <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                    <i class="fa-brands fa-facebook"></i>
                    <span>D'est Lounge</span>
                </a>
                <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                    <i class="fa-brands fa-instagram"></i>
                    <span>destlounge</span>
                </a>
            </div>
        </div>
    </footer>

</div>

<style>
    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    /* ── Nav Overlay ── */
    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Contact Container ── */
    .contact-container {
        display: flex;
        min-height: calc(120vh - 400px);
        background-color: #f5f0eb;
        padding: 2rem;
        gap: 2rem;
    }

    .map-section {
        flex: 1;
        min-height: 500px;
        border: 3px solid #3d2817;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 4px 4px 12px rgba(0, 0, 0, 0.2);
    }

    .contact-info {
        flex: 1;
        background-color: white;
        padding: 3rem;
        border-radius: 10px;
        border: 3px solid #3d2817;
        box-shadow: 4px 4px 12px rgba(0, 0, 0, 0.2);
        overflow-y: auto;
    }

    .contact-title {
        font-size: 3rem;
        font-weight: 600;
        color: #5d4037;
        margin: 0 0 2rem 0;
        text-align: center;
        font-family: Georgia, 'Times New Roman', serif;
        font-style: italic;
    }

    .info-item {
        display: flex;
        align-items: flex-start;
        gap: 1.5rem;
        margin-bottom: 2rem;
        padding: 1.5rem;
        background-color: #f9f6f3;
        border-radius: 10px;
        transition: transform 0.3s ease;
    }

        .info-item:hover {
            transform: translateX(10px);
        }

        .info-item i {
            font-size: 2rem;
            color: #6b4423;
            min-width: 40px;
        }

        .info-item h3 {
            font-size: 1.2rem;
            font-weight: 600;
            color: #5d4037;
            margin: 0 0 0.5rem 0;
        }

        .info-item p {
            font-size: 1rem;
            color: #3d2817;
            margin: 0.2rem 0;
        }

        .info-item div {
            font-size: 1rem;
            color: #3d2817;
        }

        .info-item a {
            color: #6b4423;
            text-decoration: none;
            transition: color 0.3s ease;
        }

            .info-item a:hover {
                color: #8b6f47;
                text-decoration: underline;
            }

    .no-data-message {
        text-align: center;
        padding: 2rem;
        color: #8b6f47;
        font-style: italic;
    }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-container {
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* =============================================
       DESKTOP (above 1024px)
    ============================================= */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            top: auto !important;
            right: auto !important;
            left: auto !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            background-color: transparent !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            justify-content: flex-start !important;
            gap: 2.5rem !important;
            overflow: visible !important;
            transform: none !important;
            transition: none !important;
            z-index: auto !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                letter-spacing: 0.5px !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    /* =============================================
       TABLET + MOBILE (max-width: 1024px)
    ============================================= */
    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            justify-content: flex-start !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
            box-shadow: -4px 0 20px rgba(0,0,0,0.15) !important;
            transform: translateX(100%) !important;
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1) !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            margin: 0 !important;
        }

            .main-nav.open {
                transform: translateX(0) !important;
            }

            .main-nav a {
                width: 100% !important;
                padding: 0.9rem 0 !important;
                font-size: 1rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                letter-spacing: 0.05em !important;
                display: block !important;
                text-decoration: none !important;
                background: none !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 1px solid #e0d5c8 !important;
                }

        .mobile-nav-actions {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #d4c4b0;
            gap: 0;
        }

            .mobile-nav-actions a {
                display: flex !important;
                align-items: center;
                gap: 0.6rem;
                padding: 0.75rem 0 !important;
                font-size: 0.97rem !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                width: 100% !important;
                font-weight: 600 !important;
                text-decoration: none !important;
                background: none !important;
            }

                .mobile-nav-actions a:last-child {
                    border-bottom: none !important;
                }
        /* Contact layout */
        .contact-container {
            flex-direction: column;
            padding: 1.5rem;
            gap: 1.5rem;
            min-height: unset;
        }

        .map-section {
            min-height: 400px;
            flex: none;
            width: 100%;
        }

        .contact-info {
            flex: none;
            width: 100%;
            padding: 2rem;
            box-sizing: border-box;
        }

        .contact-title {
            font-size: 2.2rem;
            margin-bottom: 1.5rem;
        }

        .info-item {
            padding: 1.2rem;
            gap: 1.2rem;
            margin-bottom: 1.25rem;
        }

            .info-item:hover {
                transform: translateX(5px);
            }

            .info-item i {
                font-size: 1.6rem;
                min-width: 32px;
            }

            .info-item h3 {
                font-size: 1.1rem;
            }

            .info-item p,
            .info-item div {
                font-size: 0.95rem;
            }
    }

    /* =============================================
       MOBILE (max-width: 768px)
    ============================================= */
    @@media (max-width: 768px) {
        .contact-container {
            padding: 0.75rem;
            gap: 0.75rem;
        }

        .map-section {
            min-height: 280px;
            border-width: 2px;
            border-radius: 12px;
        }

        .contact-info {
            padding: 1.2rem;
            border-width: 2px;
            border-radius: 12px;
        }

        .contact-title {
            font-size: 1.8rem;
            margin-bottom: 1.2rem;
        }

        .info-item {
            padding: 1rem;
            gap: 1rem;
            margin-bottom: 1rem;
            border-radius: 8px;
        }

            .info-item:hover {
                transform: none;
            }

            .info-item i {
                font-size: 1.4rem;
                min-width: 28px;
            }

            .info-item h3 {
                font-size: 1rem;
                margin-bottom: 0.3rem;
            }

            .info-item p,
            .info-item div {
                font-size: 0.9rem;
            }
        /* Footer */
        footer {
            padding: 1.5rem 1rem;
        }

        .footer-title {
            font-size: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .social-links {
            gap: 1.5rem;
        }

        .social-item i {
            font-size: 1.25rem;
        }

        .social-item span {
            font-size: 0.8rem;
        }
    }

    /* =============================================
       SMALL MOBILE (max-width: 400px)
    ============================================= */
    @@media (max-width: 400px) {
        .contact-container {
            padding: 0.5rem;
        }

        .map-section {
            min-height: 240px;
        }

        .contact-info {
            padding: 1rem;
        }

        .contact-title {
            font-size: 1.5rem;
        }

        .info-item {
            padding: 0.85rem;
            gap: 0.75rem;
        }

            .info-item i {
                font-size: 1.2rem;
                min-width: 24px;
            }

            .info-item h3 {
                font-size: 0.95rem;
            }

            .info-item p,
            .info-item div {
                font-size: 0.85rem;
            }
    }
</style>

@section scripts {
    <script>
        window.loggedInUserId = @(Session["UserID"] != null ? Session["UserID"].ToString() : "null");

        (function () {
            var btn = document.getElementById('hamburgerBtn');
            var nav = document.getElementById('mainNav');
            var overlay = document.getElementById('navOverlay');

            function openMenu() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeMenu() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', function () {
                nav.classList.contains('open') ? closeMenu() : openMenu();
            });

            overlay.addEventListener('click', closeMenu);

            nav.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', closeMenu);
            });
        })();
    </script>
}