@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@Html.AntiForgeryToken()

<div ng-app="DestLoungeSalesandBooking" ng-controller="NailTechController">

    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="logo-container">
            <a href="@Url.Action("AdminHomepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminHomepage","Main")" class="nav-item">HOME</a>
            <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
            <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
            <a href="@Url.Action("AdminNailTechPage","Main")" class="nav-item active">NAIL TECHS</a>
            <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
            <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item">FAQs</a>
            <a href="@Url.Action("AdminInboxPage","Main")"
               class="nav-item active inbox-link"
               ng-controller="DestLoungeSalesandBookingController"
               ng-init="loadAdminInboxCount()">

                <span>INBOX</span>

                <span class="inbox-badge" ng-if="adminInboxCount > 0">
                    {{adminInboxCount}}
                </span>

            </a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
            <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item">GALLERY</a>
            <a href="@Url.Action("AdminPaymentSetting","Main")" class="nav-item">PAYMENT</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="main-content">
        <div class="nailtech-container">
            <div class="page-header">
                <h1 class="nailtech-title">Nail Techs</h1>
                <button class="add-nailtech-btn" ng-click="openModal()">
                    <i class="fa-solid fa-plus"></i> Add Nail Tech
                </button>
            </div>

            <!-- Stats Bar -->
            <div class="stats-bar">
                <div class="stat-pill">
                    <i class="fa-solid fa-users"></i>
                    <span><strong>{{activeTechs.length}}</strong> Active</span>
                </div>
                <div class="stat-pill stat-pill--inactive">
                    <i class="fa-solid fa-user-slash"></i>
                    <span><strong>{{inactiveTechs.length}}</strong> Inactive</span>
                </div>
            </div>

            <!-- Active Techs -->
            <div class="section-label" ng-if="activeTechs.length > 0">
                <i class="fa-solid fa-circle-check"></i> Active Staff
            </div>
            <div class="nailtech-grid">
                <div class="nailtech-card" ng-repeat="tech in activeTechs">
                    <div class="card-avatar">
                        <div class="avatar-initials">{{getInitials(tech.name)}}</div>
                        <div class="status-dot status-dot--active"></div>
                    </div>
                    <div class="card-info">
                        <h3 class="card-name">{{tech.name}}</h3>
                        <span class="card-role">{{tech.specialization || 'Nail Technician'}}</span>
                        <div class="card-meta" ng-if="tech.contact">
                            <i class="fa-solid fa-phone"></i> {{tech.contact}}
                        </div>
                    </div>
                    <div class="card-actions">
                        <button class="card-btn card-btn--edit" ng-click="openEditModal(tech); $event.stopPropagation();" title="Edit">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="card-btn card-btn--deactivate" ng-click="deactivateTech(tech); $event.stopPropagation();" title="Deactivate">
                            <i class="fa-solid fa-user-slash"></i>
                        </button>
                        <button class="card-btn card-btn--delete" ng-click="deleteTech(tech); $event.stopPropagation();" title="Delete">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>

                <div ng-if="activeTechs.length === 0" class="nailtech-empty">
                    <i class="fa-solid fa-scissors"></i>
                    <p>No active nail techs yet. Click "Add Nail Tech" to get started.</p>
                </div>
            </div>

            <!-- Inactive / Former Techs -->
            <div class="inactive-section" ng-if="inactiveTechs.length > 0">
                <button class="inactive-toggle-btn" ng-click="showInactive = !showInactive">
                    <i class="fa-solid fa-user-slash"></i>
                    {{ showInactive ? 'Hide Inactive Staff' : 'View Inactive Staff' }}
                    <span class="inactive-count">{{inactiveTechs.length}}</span>
                </button>
                <div class="inactive-panel" ng-show="showInactive">
                    <h2 class="inactive-panel-title">Inactive / Former Nail Techs</h2>
                    <div class="inactive-card" ng-repeat="tech in inactiveTechs">
                        <div class="inactive-avatar">
                            <div class="avatar-initials avatar-initials--sm">{{getInitials(tech.name)}}</div>
                            <div class="status-dot status-dot--inactive"></div>
                        </div>
                        <div class="inactive-info">
                            <h3>{{tech.name}}</h3>
                            <p>{{tech.specialization || 'Nail Technician'}} <span ng-if="tech.contact"> &bull; {{tech.contact}}</span></p>
                        </div>
                        <div class="inactive-actions">
                            <button class="restore-btn" ng-click="reactivateTech(tech)">
                                <i class="fa-solid fa-rotate-left"></i> Reactivate
                            </button>
                            <button class="perm-delete-btn" ng-click="permanentDeleteTech(tech)">
                                <i class="fa-solid fa-trash"></i> Remove
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer>
            <div class="footer-container">
                <h2 class="footer-title">Follow our Socials!</h2>
                <div class="social-links">
                    <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                        <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
                    </a>
                    <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                        <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
                    </a>
                    <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                        <i class="fa-brands fa-instagram"></i><span>destlounge</span>
                    </a>
                </div>
            </div>
        </footer>
    </div>

    <!-- ADD / EDIT MODAL -->
    <div class="modal-backdrop" ng-show="showModal" ng-click="closeModalBackdrop($event)">
        <div class="modal" ng-click="$event.stopPropagation()">
            <div class="modal-header">
                <div class="modal-header-left">
                    <div class="modal-icon"><i class="fa-solid fa-scissors"></i></div>
                    <div>
                        <span class="modal-title">{{ editingTech ? 'Edit Nail Tech' : 'Add New Nail Tech' }}</span>
                        <div class="modal-subtitle">Manage your nail technician roster</div>
                    </div>
                </div>
                <button class="modal-close" ng-click="closeModal()">&#10005;</button>
            </div>

            <div class="modal-body">
                <div class="field-row">
                    <div class="field-group field-group--full">
                        <label class="field-label">Full Name <span class="required">*</span></label>
                        <input class="field-input" type="text" ng-model="techForm.name"
                               placeholder="e.g. Maria Santos" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label">Specialization</label>
                        <input class="field-input" type="text" ng-model="techForm.specialization"
                               placeholder="e.g. Gel Nails, Nail Art" />
                    </div>
                    <div class="field-group">
                        <label class="field-label">Contact Number</label>
                        <input class="field-input" type="text" ng-model="techForm.contact"
                               placeholder="e.g. 09XX XXX XXXX" />
                    </div>
                </div>

                <div class="field-row">
                    <div class="field-group">
                        <label class="field-label">Status</label>
                        <select class="field-input field-select" ng-model="techForm.status">
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="field-group field-group--full">
                    <label class="field-label">Notes</label>
                    <textarea class="field-input field-textarea" ng-model="techForm.notes"
                              placeholder="Any additional notes about this nail tech..." rows="3"></textarea>
                </div>

                <!-- Live Preview -->
                <div class="modal-preview" ng-if="techForm.name">
                    <div class="preview-label">Preview</div>
                    <div class="preview-card">
                        <div class="preview-avatar">
                            <div class="avatar-initials">{{getInitials(techForm.name)}}</div>
                        </div>
                        <div class="preview-info">
                            <strong>{{techForm.name || 'Name here...'}}</strong>
                            <span>{{techForm.specialization || 'Nail Technician'}}</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-cancel" ng-click="closeModal()">Cancel</button>
                <button class="btn-save" ng-click="saveTech()" ng-disabled="!techForm.name">
                    {{ editingTech ? 'Save Changes' : 'Add Nail Tech' }}
                </button>
            </div>
        </div>
    </div>

    <!-- DELETE CONFIRM MODAL -->
    <div class="modal-backdrop modal-backdrop--confirm" ng-show="showConfirmModal" ng-click="closeConfirmModal()">
        <div class="confirm-modal" ng-click="$event.stopPropagation()">
            <div class="confirm-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <h3 class="confirm-title">{{confirmTitle}}</h3>
            <p class="confirm-message">{{confirmMessage}}</p>
            <div class="confirm-actions">
                <button class="btn-cancel" ng-click="closeConfirmModal()">Cancel</button>
                <button class="btn-confirm-delete" ng-click="confirmAction()">{{confirmBtnText}}</button>
            </div>
        </div>
    </div>

    <!-- Mobile Top Bar -->
    <div class="mobile-topbar">
        <a href="@Url.Action("AdminHomepage","Main")">
            <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
        </a>
        <button class="mobile-menu-btn" onclick="toggleMobileNav()">
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>

    <div class="mobile-nav-overlay" id="mobileOverlay" onclick="toggleMobileNav()"></div>

    <div class="mobile-nav-drawer" id="mobileDrawer">
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminHomepage","Main")" class="nav-item">HOME</a>
            <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
            <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
            <a href="@Url.Action("AdminNailTechPage","Main")" class="nav-item active">NAIL TECHS</a>
            <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
            <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item">FAQs</a>
            <a href="@Url.Action("AdminInboxPage","Main")" class="nav-item">INBOX</a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
            <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item">GALLERY</a>
            <a href="@Url.Action("AdminPaymentSetting","Main")" class="nav-item">PAYMENT</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', serif;
            background-color: #d4c4b0;
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: 10%;
            min-width: 9rem;
            height: 100vh;
            background-color: #e7dfd6;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.25rem 0;
            z-index: 1000;
        }

        .logo-container {
            margin-bottom: 2rem;
        }

        .sidebar-logo {
            width: 3.5rem;
            height: auto;
        }

        .sidebar-nav {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            width: 100%;
        }

        .nav-item {
            color: #5a4a3a;
            text-decoration: none;
            padding: 1rem 0.625rem;
            font-size: 1rem;
            font-weight: 500;
            text-align: center;
            transition: background-color 0.3s;
            letter-spacing: 0.0625rem;
            display: block;
        }

            .nav-item:hover {
                background-color: rgba(90,74,58,0.1);
            }

            .nav-item.active {
                background-color: rgba(139,111,71,0.3);
                border-left: 0.25rem solid #8b6f47;
            }

        .sidebar-footer {
            margin-top: auto;
            padding: 1.25rem 0;
        }

        .admin-link {
            color: #5a4a3a;
            text-decoration: none;
            font-size: 0.75rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.3125rem;
        }

            .admin-link i {
                font-size: 1.25rem;
            }

        .main-content {
            margin-left: 10%;
            background-color: #d4c4b0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .nailtech-container {
            background-color: #e7dfd6;
            padding: 3rem 2rem;
            flex: 1;
        }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .nailtech-title {
            font-size: 4rem;
            font-weight: 600;
            color: #6b4423;
            margin: 0;
            text-shadow: 0.125rem 0.125rem 0.25rem rgba(0,0,0,0.1);
        }

        .add-nailtech-btn {
            background-color: #4a7c59;
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Georgia', serif;
        }

            .add-nailtech-btn:hover {
                background-color: #3a6449;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }

        .stats-bar {
            display: flex;
            gap: 0.75rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .stat-pill {
            background-color: #4a7c59;
            color: white;
            padding: 0.4rem 1rem;
            border-radius: 2rem;
            font-size: 0.88rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .stat-pill--inactive {
            background-color: #9a7060;
        }

        .section-label {
            font-size: 0.85rem;
            font-weight: 700;
            color: #8b6f47;
            text-transform: uppercase;
            letter-spacing: 0.1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .nailtech-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 87.5rem;
            margin: 0 auto 2.5rem;
        }

        .nailtech-card {
            background-color: #6b4423;
            border-radius: 1.25rem;
            padding: 1.75rem 1.5rem 1.5rem;
            box-shadow: 0.25rem 0.25rem 0.75rem rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            position: relative;
            transition: all 0.3s ease;
        }

            .nailtech-card:hover {
                transform: translateY(-0.3125rem);
                box-shadow: 0.375rem 0.375rem 1rem rgba(0,0,0,0.3);
            }

        .card-avatar {
            position: relative;
            width: 5rem;
            height: 5rem;
            flex-shrink: 0;
        }

        .avatar-initials {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            border: 3px solid rgba(255,255,255,0.4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            font-weight: 700;
            color: white;
            letter-spacing: 0.05em;
        }

        .avatar-initials--sm {
            width: 2.8rem;
            height: 2.8rem;
            font-size: 0.9rem;
            background: rgba(107,68,35,0.15);
            border: 2px solid rgba(107,68,35,0.2);
            color: #6b4423;
        }

        .status-dot {
            position: absolute;
            bottom: 0.15rem;
            right: 0.15rem;
            width: 0.9rem;
            height: 0.9rem;
            border-radius: 50%;
            border: 2px solid #6b4423;
        }

        .status-dot--active {
            background: #4CAF50;
        }

        .status-dot--inactive {
            background: #9a9a9a;
            border-color: white;
        }

        .card-info {
            text-align: center;
            flex: 1;
            width: 100%;
        }

        .card-name {
            color: white;
            font-size: 1.15rem;
            font-weight: 700;
            margin: 0 0 0.25rem;
            line-height: 1.3;
        }

        .card-role {
            color: rgba(255,255,255,0.7);
            font-size: 0.82rem;
            display: block;
            margin-bottom: 0.5rem;
            font-style: italic;
        }

        .card-meta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.4rem;
            color: rgba(255,255,255,0.65);
            font-size: 0.78rem;
            margin-top: 0.25rem;
        }

            .card-meta i {
                font-size: 0.72rem;
            }

        .card-actions {
            display: flex;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }

        .card-btn {
            background: rgba(255,255,255,0.95);
            border: none;
            border-radius: 50%;
            width: 2rem;
            height: 2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            box-shadow: 0 0.125rem 0.375rem rgba(0,0,0,0.2);
        }

            .card-btn i {
                font-size: 0.8rem;
            }

        .card-btn--edit {
            color: #4a7c59;
        }

            .card-btn--edit:hover {
                background: #4a7c59;
                color: white;
                transform: scale(1.1);
            }

        .card-btn--deactivate {
            color: #c87a2a;
        }

            .card-btn--deactivate:hover {
                background: #c87a2a;
                color: white;
                transform: scale(1.1);
            }

        .card-btn--delete {
            color: #c84b4b;
        }

            .card-btn--delete:hover {
                background: #c84b4b;
                color: white;
                transform: scale(1.1);
            }

        .nailtech-empty {
            grid-column: 1 / -1;
            text-align: center;
            padding: 3rem;
            color: #8a7060;
        }

            .nailtech-empty i {
                font-size: 3rem;
                margin-bottom: 1rem;
                display: block;
                opacity: 0.4;
            }

        .inactive-section {
            max-width: 87.5rem;
            margin: 0 auto 2rem;
            padding-bottom: 1rem;
        }

        .inactive-toggle-btn {
            background: transparent;
            border: 2px solid #6b4423;
            color: #6b4423;
            padding: 0.6rem 1.5rem;
            border-radius: 1.875rem;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0 auto;
            font-family: 'Georgia', serif;
        }

            .inactive-toggle-btn:hover {
                background-color: #6b4423;
                color: white;
            }

        .inactive-count {
            background: #c84b4b;
            color: white;
            border-radius: 50%;
            padding: 0.1rem 0.5rem;
            font-size: 0.8rem;
        }

        .inactive-panel {
            margin-top: 1.5rem;
            background: rgba(107,68,35,0.08);
            border: 2px dashed #6b4423;
            border-radius: 1rem;
            padding: 1.5rem;
        }

        .inactive-panel-title {
            color: #6b4423;
            font-size: 1.5rem;
            margin-bottom: 1rem;
            text-align: center;
        }

        .inactive-card {
            background: white;
            border-radius: 0.75rem;
            padding: 0.875rem 1.25rem;
            margin-bottom: 0.75rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            opacity: 0.85;
        }

        .inactive-avatar {
            position: relative;
            flex-shrink: 0;
            width: 2.8rem;
            height: 2.8rem;
        }

        .inactive-info {
            flex: 1;
            min-width: 0;
        }

            .inactive-info h3 {
                color: #4a3020;
                font-size: 1rem;
                margin-bottom: 0.2rem;
            }

            .inactive-info p {
                color: #7a6050;
                font-size: 0.875rem;
                margin: 0;
            }

        .inactive-actions {
            display: flex;
            gap: 0.5rem;
            flex-shrink: 0;
        }

        .restore-btn {
            background: #4a7c59;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.3s;
            font-family: 'Georgia', serif;
        }

            .restore-btn:hover {
                background: #3a6048;
                transform: translateY(-1px);
            }

        .perm-delete-btn {
            background: #c84b4b;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.3s;
            font-family: 'Georgia', serif;
        }

            .perm-delete-btn:hover {
                background: #a83a3a;
                transform: translateY(-1px);
            }

        footer {
            background-color: #e7d7c8;
            border: 2px solid #d4c4b0;
            border-left: none;
            border-right: none;
            padding: 2.5rem 3rem;
            text-align: center;
        }

        .footer-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #6b4423;
            margin: 0 0 2rem 0;
            font-style: italic;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 3rem;
            flex-wrap: wrap;
        }

