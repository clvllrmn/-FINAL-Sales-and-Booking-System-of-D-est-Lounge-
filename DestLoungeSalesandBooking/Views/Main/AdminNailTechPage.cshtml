    function toggleMobileNav() {
        var drawer = document.getElementById('mobileDrawer');
        var overlay = document.getElementById('mobileOverlay');
        drawer.classList.toggle('open');
        overlay.classList.toggle('open');
    }
</script>

@section scripts {
    <script>
        angular.module('DestLoungeSalesandBooking')
            .controller('NailTechController', ['$scope', '$http', function ($scope, $http) {

                $scope.activeTechs = [];
                $scope.inactiveTechs = [];
                $scope.showModal = false;
                $scope.showConfirmModal = false;
                $scope.showInactive = false;
                $scope.editingTech = null;

                $scope.techForm = { name: '', specialization: '', contact: '', status: 'active', notes: '' };

                // ── Load ──
                $scope.loadTechs = function () {
                    $http.get('/Main/GetNailTechs').then(function (res) {
                        $scope.activeTechs = res.data.filter(function (t) { return t.status !== 'inactive'; });
                        $scope.inactiveTechs = res.data.filter(function (t) { return t.status === 'inactive'; });
                    });
                };
                $scope.loadTechs();

                // ── Helpers ──
                $scope.getInitials = function (name) {
                    if (!name) return '?';
                    return name.split(' ').map(function (w) { return w[0]; }).slice(0, 2).join('').toUpperCase();
                };

                // ── Modal ──
                $scope.openModal = function () {
                    $scope.editingTech = null;
                    $scope.techForm = { name: '', specialization: '', contact: '', status: 'active', notes: '' };
                    $scope.showModal = true;
                };

                $scope.openEditModal = function (tech) {
                    $scope.editingTech = tech;
                    $scope.techForm = {
                        name: tech.name || '',
                        specialization: tech.specialization || '',
                        contact: tech.contact || '',
                        status: tech.status || 'active',
                        notes: tech.notes || ''
                    };
                    $scope.showModal = true;
                };

                $scope.closeModal = function () {
                    $scope.showModal = false;
                    $scope.editingTech = null;
                };

                $scope.closeModalBackdrop = function ($event) {
                    if ($event.target === $event.currentTarget) $scope.closeModal();
                };

                // ── Save ──
                $scope.saveTech = function () {
                    if (!$scope.techForm.name) return;

                    var payload = angular.copy($scope.techForm);

                    if ($scope.editingTech) {
                        payload.nailTechId = $scope.editingTech.nailTechId;
                        $http.post('/Main/UpdateNailTech', payload).then(function () {
                            $scope.loadTechs();
                            $scope.closeModal();
                        });
                    } else {
                        $http.post('/Main/AddNailTech', payload).then(function () {
                            $scope.loadTechs();
                            $scope.closeModal();
                        });
                    }
                };

                // ── Deactivate ──
                $scope.deactivateTech = function (tech) {
                    $scope.pendingAction = function () {
                        $http.post('/Main/DeactivateNailTech', { nailTechId: tech.nailTechId }).then(function () {
                            $scope.loadTechs();
                        });
                    };
                    $scope.confirmTitle = 'Deactivate Nail Tech';
                    $scope.confirmMessage = 'Mark ' + tech.name + ' as inactive? They will be moved to the Inactive Staff list.';
                    $scope.confirmBtnText = 'Deactivate';
                    $scope.showConfirmModal = true;
                };

                // ── Reactivate ──
                $scope.reactivateTech = function (tech) {
                    $http.post('/Main/ReactivateNailTech', { nailTechId: tech.nailTechId }).then(function () {
                        $scope.loadTechs();
                    });
                };

                // ── Delete (moves to inactive) ──
                $scope.deleteTech = function (tech) {
                    $scope.pendingAction = function () {
                        $http.post('/Main/DeleteNailTech', { nailTechId: tech.nailTechId }).then(function () {
                            $scope.loadTechs();
                        });
                    };
                    $scope.confirmTitle = 'Remove Nail Tech';
                    $scope.confirmMessage = 'Remove ' + tech.name + '? They will be moved to the Inactive Staff list.';
                    $scope.confirmBtnText = 'Remove';
                    $scope.showConfirmModal = true;
                };

                // ── Permanent Delete ──
                $scope.permanentDeleteTech = function (tech) {
                    $scope.pendingAction = function () {
                        $http.post('/Main/PermanentDeleteNailTech', { nailTechId: tech.nailTechId }).then(function () {
                            $scope.loadTechs();
                        });
                    };
                    $scope.confirmTitle = 'Permanently Remove';
                    $scope.confirmMessage = 'This will completely remove ' + tech.name + ' from the system. Are you sure?';
                    $scope.confirmBtnText = 'Delete Forever';
                    $scope.showConfirmModal = true;
                };

                // ── Confirm modal ──
                $scope.confirmAction = function () {
                    if ($scope.pendingAction) $scope.pendingAction();
                    $scope.showConfirmModal = false;
                    $scope.pendingAction = null;
                };

                $scope.closeConfirmModal = function () {
                    $scope.showConfirmModal = false;
                    $scope.pendingAction = null;
                };
            }]);
    </script>
}