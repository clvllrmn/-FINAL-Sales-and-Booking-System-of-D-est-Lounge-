    }

    /* Totals */
    .summary-total-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.4rem 0;
    }

    .summary-total-label {
        font-size: 1rem;
        font-weight: 700;
        color: #5d4037;
    }

    .summary-total-value {
        font-size: 1.1rem;
        font-weight: 700;
        color: #6b4423;
    }

    .summary-downpayment-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.35rem 0 0;
        border-top: 1px dashed #d4c4b0;
        margin-top: 0.25rem;
    }

    .summary-dp-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: #8b6f47;
    }

    .summary-dp-value {
        font-size: 0.9rem;
        font-weight: 700;
        color: #6b4423;
    }

    .summary-empty {
        text-align: center;
        color: #999;
        padding: 1.5rem 0;
        font-style: italic;
    }

        .summary-empty i {
            font-size: 2rem;
            display: block;
            margin-bottom: 0.5rem;
            opacity: 0.3;
        }

        .summary-empty p {
            margin: 0;
            font-size: 0.9rem;
        }

    /* Mobile Summary Toggle */
    .summary-toggle-btn {
        display: none;
    }

    /* ── Booking Form ── */
    .booking-form {
        flex: 1;
        background-color: white;
        border-radius: 20px;
        padding: 3rem;
        border: 3px solid #d4c4b0;
        box-shadow: 4px 4px 12px rgba(0,0,0,0.15);
    }

    .form-group {
        margin-bottom: 2rem;
    }

        .form-group label {
            display: block;
            font-size: 1.1rem;
            font-weight: 600;
            color: #5d4037;
            margin-bottom: 0.8rem;
        }

    .form-select {
        width: 100%;
        padding: 1rem 3rem 1rem 1.2rem;
        font-size: 1rem;
        border: 2px solid #d4c4b0;
        border-radius: 25px;
        background-color: #f9f6f3;
        outline: none;
