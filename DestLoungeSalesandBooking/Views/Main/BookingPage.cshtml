        }

    .summary-meta-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: #8b6f47;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

        .summary-meta-label i {
            font-size: 0.72rem;
            width: 12px;
        }

    .summary-meta-value {
        font-size: 0.78rem;
        color: #5d4037;
        font-weight: 500;
        text-align: right;
    }

    /* Service items */
    .summary-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.4rem 0;
    }

    .summary-service-name {
        color: #5d4037;
        font-size: 0.9rem;
