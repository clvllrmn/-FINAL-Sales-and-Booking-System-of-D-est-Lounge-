@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <a href="#">
                    <i class="fa-solid fa-bell"></i> Notifications
                </a>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <a href="#" class="bell-icon" title="Notifications">
                <i class="fa-solid fa-bell"></i>
            </a>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div class="booking-container" ng-controller="DestLoungeSalesandBookingController">

    <!-- Mobile Summary Toggle Button -->
    <button class="summary-toggle-btn" ng-click="showMobileSummary = !showMobileSummary" ng-show="booking.selectedServices.length > 0">
        <span><i class="fa-solid fa-receipt"></i> View Summary ({{booking.selectedServices.length}} item{{booking.selectedServices.length !== 1 ? 's' : ''}})</span>
        <span class="summary-toggle-total">₱{{calculateTotal() | number:2}}</span>
        <i class="fa-solid" ng-class="showMobileSummary ? 'fa-chevron-up' : 'fa-chevron-down'"></i>
    </button>

    <!-- Service Summary -->
    <div class="service-summary" ng-class="{'mobile-summary-open': showMobileSummary}">
        <h2>Service Summary</h2>
        <div class="summary-content">
            <div class="summary-items" ng-show="booking.selectedServices.length > 0">

                <!-- Booking details strip -->
                <div class="summary-meta">
                    <div class="summary-meta-row" ng-show="booking.nailTech">
                        <span class="summary-meta-label"><i class="fa-solid fa-user"></i> Nail Tech</span>
                        <span class="summary-meta-value">{{getSelectedTechName()}}</span>
                    </div>
                    <div class="summary-meta-row" ng-show="booking.date">
                        <span class="summary-meta-label"><i class="fa-solid fa-calendar"></i> Date</span>
                        <span class="summary-meta-value">{{booking.date | date:'MMM d, yyyy'}}</span>
                    </div>
                    <div class="summary-meta-row" ng-show="booking.time">
                        <span class="summary-meta-label"><i class="fa-solid fa-clock"></i> Time</span>
                        <span class="summary-meta-value">{{booking.time}}</span>
                    </div>
                </div>

                <div class="summary-divider"></div>

                <!-- Services list -->
                <div class="summary-item" ng-repeat="service in booking.selectedServices">
                    <span class="summary-service-name">{{service.name}}</span>
                    <span class="summary-service-price">₱{{service.price}}</span>
                </div>

                <div class="summary-divider"></div>

                <!-- Totals -->
                <div class="summary-total-row">
                    <span class="summary-total-label">Total</span>
                    <span class="summary-total-value">₱{{calculateTotal() | number:2}}</span>
                </div>
                <div class="summary-downpayment-row">
                    <span class="summary-dp-label">Downpayment (40%)</span>
                    <span class="summary-dp-value">₱{{calculateTotal() * 0.4 | number:2}}</span>
                </div>
            </div>

            <div class="summary-empty" ng-show="booking.selectedServices.length === 0">
                <i class="fa-solid fa-receipt"></i>
                <p>No services selected yet</p>
            </div>
        </div>
    </div>

    

    <!-- Booking Form -->
    <div class="booking-form">
        <div class="form-group">
            <label>Choose Nail Tech</label>
            <select ng-model="booking.nailTech" class="form-select" ng-change="checkAvailability()" required>
                <option value="">Select Nail Tech</option>
                <option ng-repeat="tech in nailTechs" value="{{tech.name}}">{{tech.name}}</option>
            </select>
        </div>
        <div class="form-group">
            <label>Choose Date</label>
            <input type="date" ng-model="booking.date" class="form-select"
                   min="{{minDate}}" max="{{maxDate}}" ng-change="checkAvailability()" required>
            <span class="error-message" ng-show="dateFullyBooked">
                This date is fully booked. Please choose another date.
            </span>
        </div>
        <div class="form-group">
            <label>Choose Time</label>
            <select ng-model="booking.time" class="form-select" required>
                <option ng-repeat="t in availableTimes"
                        value="{{t}}"
                        ng-disabled="isTimeDisabled(t)">
                    {{
        isPast24HourCutoff(booking.date, t)
            ? (t + ' - Not Available (24-hour rule)')
            : (isTimeDisabled(t) ? (t + ' - Not Available') : t)
                    }}
                </option>
            </select>
        </div>
        <div class="form-group">
            <label>Choose Services</label>
            <div class="services-checklist">
                <div class="service-category">
                    <h4>Nail Care Services</h4>

                    <!-- ✅ SHOW THIS WHEN NO SERVICES -->
                    <div ng-if="bookingServices.length === 0" class="no-services-message">
                        No services found.
                    </div>

                    <!-- ✅ SHOW SERVICES WHEN AVAILABLE -->
                    <label class="service-checkbox" ng-repeat="service in bookingServices">
                        <input type="checkbox" ng-model="service.selected" ng-change="updateSelectedServices()">
                        <span class="service-label">
                            <span class="service-name-check">{{service.name}}</span>
                            <span class="service-price-check">₱{{service.price}}</span>
                        </span>
                    </label>
                </div>
            </div>
        </div>
        <button type="button" class="book-now-btn" ng-click="submitBooking()" ng-disabled="!isBookingValid()">
            Book Now
        </button>
    </div>
</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i><span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    /* ── Nav Overlay ── */
    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Booking Container ── */
    .booking-container {
