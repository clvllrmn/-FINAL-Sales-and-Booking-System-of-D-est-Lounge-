    }

        .service-summary h2 {
            font-size: 1.4rem;
            color: #5d4037;
            margin: 0 0 1rem 0;
            text-align: center;
            font-weight: 600;
            padding-bottom: 0.75rem;
            border-bottom: 2px solid #c1b2a5;
        }

    .summary-content {
        background-color: white;
        border-radius: 12px;
        padding: 1rem;
    }

    .summary-items {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    /* Meta rows (nail tech, date, time) */
    .summary-meta {
        background: #faf7f4;
