        padding: 0.5rem 0.75rem;
        margin-bottom: 0.75rem;
        border: 1px solid #e8ddd2;
    }

    .summary-meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.35rem 0;
        border-bottom: 1px solid #f0e8e0;
    }

        .summary-meta-row:last-child {
