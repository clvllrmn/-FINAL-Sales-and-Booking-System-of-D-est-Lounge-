@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>
        <nav class="main-nav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>
        </nav>
        <div class="header-actions">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN/SIGNUP
                </a>
            }
            <a href="#" class="bell-icon" title="Notifications">
                <i class="fa-solid fa-bell"></i>
            </a>
        </div>
    </div>
</header>

<div ng-controller="DestLoungeSalesandBookingController">
    <!-- Banner -->
    <div class="banner-container" ng-cloak>
        <div class="banner-text">
            <h1 class="hello">{{bannerText.hello}}</h1>
            <h2 class="youre-looking">{{bannerText.youre_looking}}</h2>
            <h2 class="gorgeous">{{bannerText.gorgeous}}</h2>
            <h2 class="today">{{bannerText.today}}</h2>
        </div>
        </div>

    </div>

    <!-- Services Intro -->
    <div class="services-intro" ng-cloak>
        <div class="divider-line"></div>
        <div class="service-text">
            <h3 class="service-title">{{serviceInfo.title}}</h3>
            <p class="service-tagline">{{serviceInfo.tagline}}</p>
        </div>
    </div>

    <!-- Polaroid Gallery -->
    <div class="polaroid-section">
        <div class="polaroid-card">
            <div class="polaroid-image">
                <img src="~/Content/Pictures/nail1.jpg" alt="Nail Design 1">
            </div>
            <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
        </div>
        <div class="polaroid-card">
            <div class="polaroid-image">
                <img src="~/Content/Pictures/nail2.jpg" alt="Nail Design 2">
            </div>
            <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
        </div>
        <div class="polaroid-card">
            <div class="polaroid-image">
                <img src="~/Content/Pictures/nail3.jpg" alt="Nail Design 3">
            </div>
            <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
        </div>
    </div>

    <!-- D'est Description -->
    <div class="dest-description" ng-cloak>
        <h3 class="dest-title">{{destInfo.title}}</h3>
        <p class="dest-text">{{destInfo.text}}</p>
    </div>
</div>



<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge"
               class="social-item"
               target="_blank">
                <i class="fa-brands fa-tiktok"></i>
                <span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i>
                <span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i>
                <span>destlounge</span>
            </a>
        </div>
    </div>


</footer>
