@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
    var userFirstName = Session["UserFirstName"] as string;
    var isLoggedIn = Session["UserID"] != null;
}

<header>
    <div class="header-container">
        <div class="logo">
            <a href="@Url.Action("Homepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
            </a>
        </div>

        <nav class="main-nav" id="mainNav">
            <a href="@Url.Action("Homepage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "Homepage" ? "nav-active" : "")">HOME</a>
            <a href="@Url.Action("ServicePage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ServicePage" ? "nav-active" : "")">SERVICES</a>
            <a href="@Url.Action("GalleryPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "GalleryPage" ? "nav-active" : "")">GALLERY</a>
            <a href="@Url.Action("ContactPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "ContactPage" ? "nav-active" : "")">CONTACT</a>
            <a href="@Url.Action("FAQsPage","Main")" class="@(ViewContext.RouteData.Values["action"].ToString() == "FAQsPage" ? "nav-active" : "")">FAQs</a>

            <div class="mobile-nav-actions">
                @if (isLoggedIn)
                {
                    <a href="@Url.Action("ProfilePage","Main")">
                        <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                    </a>
                }
                else
                {
                    <a href="@Url.Action("LoginPage","Main")">
                        <i class="fa-regular fa-user"></i> LOGIN
                    </a>
                }
                <a href="#">
                    <i class="fa-solid fa-bell"></i> Notifications
                </a>
            </div>
        </nav>

        <div class="header-actions desktop-only">
            @if (isLoggedIn)
            {
                <a href="@Url.Action("ProfilePage","Main")" class="welcome-text">
                    <i class="fa-solid fa-circle-user"></i> Welcome, @userFirstName!
                </a>
            }
            else
            {
                <a href="@Url.Action("LoginPage","Main")" class="login-link">
                    <i class="fa-regular fa-user"></i> LOGIN
                </a>
            }
            <a href="#" class="bell-icon" title="Notifications">
                <i class="fa-solid fa-bell"></i>
            </a>
        </div>

        <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="nav-overlay" id="navOverlay"></div>
</header>

<div ng-controller="DestLoungeSalesandBookingController">
    <!-- Banner -->
    <div class="banner-container" ng-cloak>
        <div class="banner-text">
            <h1 class="hello">{{bannerText.hello}}</h1>
            <h2 class="youre-looking">{{bannerText.youre_looking}}</h2>
            <h2 class="gorgeous">{{bannerText.gorgeous}}</h2>
            <h2 class="today">{{bannerText.today}}</h2>
        </div>
    </div>

    <!-- Services Intro -->
    <div class="services-intro" ng-cloak>
        <div class="divider-line"></div>
        <div class="service-text">
            <h3 class="service-title">{{serviceInfo.title}}</h3>
            <p class="service-tagline">{{serviceInfo.tagline}}</p>
        </div>
    </div>

    <!-- Polaroid Gallery -->
    <div class="polaroid-section">
        <div class="polaroid-card" ng-repeat="slot in [1,2,3]">
            <div class="polaroid-image">
                <img ng-src="{{polaroidImages[slot]}}" alt="Nail Design {{slot}}">
            </div>
            <div class="polaroid-caption"><i class="fa-regular fa-heart"></i></div>
        </div>
    </div>

    <!-- D'est Description -->
    <div class="dest-description" ng-cloak>
        <h3 class="dest-title">{{destInfo.title}}</h3>
        <p class="dest-text">{{destInfo.text}}</p>
    </div>
</div>

<footer>
    <div class="footer-container">
        <h2 class="footer-title">Follow our Socials!</h2>
        <div class="social-links">
            <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                <i class="fa-brands fa-tiktok"></i>
                <span>destlounge</span>
            </a>
            <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                <i class="fa-brands fa-facebook"></i>
                <span>D'est Lounge</span>
            </a>
            <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                <i class="fa-brands fa-instagram"></i>
                <span>destlounge</span>
            </a>
        </div>
    </div>
</footer>

<style>
    /* ── Hamburger ── */
    .hamburger-btn {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 5px;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        z-index: 1100;
        position: relative;
        flex-shrink: 0;
    }

        .hamburger-btn span {
            display: block;
            width: 26px;
            height: 3px;
            background-color: #5d4037;
            border-radius: 3px;
            transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
            transform-origin: center;
        }

        .hamburger-btn.open span:nth-child(1) {
            transform: translateY(8px) rotate(45deg);
        }

        .hamburger-btn.open span:nth-child(2) {
            opacity: 0;
            width: 0;
        }

        .hamburger-btn.open span:nth-child(3) {
            transform: translateY(-8px) rotate(-45deg);
        }

    /* ── Nav Overlay ── */
    .nav-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background-color: rgba(0,0,0,0.4);
        z-index: 900;
        opacity: 0;
        transition: opacity 0.3s ease;
        pointer-events: none;
    }

        .nav-overlay.active {
            opacity: 1;
            pointer-events: all;
        }

    .mobile-nav-actions {
        display: none;
    }

    /* ── Banner ── */
    .banner-container {
        display: flex !important;
        align-items: center !important;
        justify-content: flex-end !important;
        /* Override any fixed height from layout */
        height: auto !important;
        min-height: unset !important;
        padding: 3rem 4rem !important;
        box-sizing: border-box;
    }

    .banner-text {
        text-align: right;
        line-height: 1.1;
    }

    .hello {
        font-size: 5rem;
        font-weight: 900;
        color: #6b4423;
        margin: 0;
        letter-spacing: 0.1em;
    }

    .youre-looking {
        font-size: 4.5rem;
        font-weight: 400;
        color: #6b4423;
        margin: 0.2rem 0;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        -webkit-text-stroke: 1.5px #6b4423;
        -webkit-text-fill-color: transparent;
    }

    .gorgeous {
        font-size: 5.5rem;
        font-weight: 400;
        color: #6b4423;
        margin: 0.2rem 0;
        font-family: 'Brush Script MT', cursive;
        font-style: italic;
    }

    .today {
        font-size: 5rem;
        font-weight: 400;
        color: #6b4423;
        margin: 0;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        -webkit-text-stroke: 1.5px #6b4423;
        -webkit-text-fill-color: transparent;
    }

    /* ── Services Intro ── */
    .services-intro {
        padding: 2rem;
        margin: 0 2rem 2rem 2rem;
        text-align: center;
    }

    .divider-line {
        width: 80%;
        height: 1rem;
        background-color: #2d1810;
        margin: 0 auto 2rem auto;
        border-radius: 10rem;
    }

    .service-text {
        margin-top: 1rem;
    }

    .service-title {
        font-size: 4rem;
        font-weight: 400;
        color: #6b4423;
        margin: 0;
        font-family: 'Brush Script MT', cursive;
        font-style: italic;
    }

    .service-tagline {
        font-size: 1.3rem;
        font-weight: 600;
        color: #3d2817;
        margin: 0.5rem 0 0 0;
        letter-spacing: 0.05em;
    }

    /* ── Polaroid Section ── */
    .polaroid-section {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        gap: 2rem;
        padding: 2rem;
        margin: 0 2rem 3rem 2rem;
        flex-wrap: wrap;
    }

    .polaroid-card {
        background-color: #f5f0eb;
        padding: 1rem 1rem 1.5rem 1rem;
        border: 2px solid #3d2817;
        box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.2);
        transform: rotate(-2deg);
        transition: transform 0.3s ease;
        width: 260px; /* ADD THIS */
        max-width: 260px;
    }

        .polaroid-card:nth-child(2) {
            transform: rotate(1deg);
            margin-top: 1rem;
        }

        .polaroid-card:nth-child(3) {
            transform: rotate(-1deg);
        }

        .polaroid-card:hover {
            transform: rotate(0deg) scale(1.05);
            z-index: 10;
        }

    .polaroid-image {
        width: 100%;
        height: 260px; /* was 200px */
        overflow: hidden;
        border: 1px solid #3d2817;
        margin-bottom: 0.5rem;
    }

        .polaroid-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .polaroid-caption {
        text-align: center;
        font-size: 0.9rem;
        color: #3d2817;
        font-weight: 600;
        letter-spacing: 0.1em;
    }

    /* ── D'est Description ── */
    .dest-description {
        background-color: #d2af99;
        border-radius: 30px;
        padding: 2.5rem 3rem;
        margin: 0 auto 3rem auto;
        max-width: 500px;
        text-align: center;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
    }

    .dest-title {
        font-size: 3rem;
        font-weight: 400;
        color: #6b4423;
        margin: 0 0 1rem 0;
        font-family: 'Brush Script MT', cursive;
        font-style: italic;
    }

    .dest-text {
        font-size: 1rem;
        line-height: 1.6;
        color: #4a3428;
        margin: 0;
        font-weight: 500;
    }

    /* ── Footer ── */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        text-align: center;
    }

    .footer-container {
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: #5a4a3a;
        transition: color 0.3s;
    }

        .social-item:hover {
            color: #8b6f47;
        }

        .social-item i {
            font-size: 1.5rem;
        }

        .social-item span {
            font-size: 0.9rem;
            font-weight: 500;
        }

    /* =============================================
       DESKTOP (above 1024px)
    ============================================= */
    @@media (min-width: 1025px) {
        .hamburger-btn {
            display: none !important;
        }

        .desktop-only {
            display: flex !important;
        }

        .mobile-nav-actions {
            display: none !important;
        }

        .nav-overlay {
            display: none !important;
        }

        .main-nav {
            position: static !important;
            top: auto !important;
            right: auto !important;
            left: auto !important;
            width: auto !important;
            height: auto !important;
            background: none !important;
            background-color: transparent !important;
            box-shadow: none !important;
            padding: 0 !important;
            margin-left: 3rem !important;
            margin-right: auto !important;
            display: flex !important;
            flex-direction: row !important;
            align-items: center !important;
            justify-content: flex-start !important;
            gap: 2.5rem !important;
            overflow: visible !important;
            transform: none !important;
            transition: none !important;
            z-index: auto !important;
        }

            .main-nav a {
                width: auto !important;
                padding: 0 !important;
                border-bottom: none !important;
                font-size: 1.3rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                letter-spacing: 0.5px !important;
                display: inline !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 2.5px solid #6b4423 !important;
                    padding-bottom: 2px !important;
                }
    }

    /* =============================================
       TABLET + MOBILE (max-width: 1024px)
    ============================================= */
    @@media (max-width: 1024px) {
        .hamburger-btn {
            display: flex;
        }

        .desktop-only {
            display: none !important;
        }

        .nav-overlay {
            display: block;
        }

        .main-nav {
            position: fixed !important;
            top: 0 !important;
            right: 0 !important;
            left: auto !important;
            width: 280px !important;
            height: 100vh !important;
            background-color: #f5f0eb !important;
            z-index: 1000 !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: flex-start !important;
            justify-content: flex-start !important;
            padding: 5rem 2rem 2rem 2rem !important;
            gap: 0 !important;
            box-shadow: -4px 0 20px rgba(0,0,0,0.15) !important;
            transform: translateX(100%) !important;
            transition: transform 0.35s cubic-bezier(0.4,0,0.2,1) !important;
            overflow-y: auto !important;
            overflow-x: hidden !important;
            margin: 0 !important;
        }

            .main-nav.open {
                transform: translateX(0) !important;
            }

            .main-nav a {
                width: 100% !important;
                padding: 0.9rem 0 !important;
                font-size: 1rem !important;
                font-weight: 600 !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                letter-spacing: 0.05em !important;
                display: block !important;
                text-decoration: none !important;
                background: none !important;
            }

                .main-nav a.nav-active {
                    color: #6b4423 !important;
                    border-bottom: 1px solid #e0d5c8 !important;
                }

        .mobile-nav-actions {
            display: flex !important;
            flex-direction: column;
            width: 100%;
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 2px solid #d4c4b0;
            gap: 0;
        }

            .mobile-nav-actions a {
                display: flex !important;
                align-items: center;
                gap: 0.6rem;
                padding: 0.75rem 0 !important;
                font-size: 0.97rem !important;
                color: #5d4037 !important;
                border-bottom: 1px solid #e0d5c8 !important;
                width: 100% !important;
                font-weight: 600 !important;
                text-decoration: none !important;
                background: none !important;
            }

                .mobile-nav-actions a:last-child {
                    border-bottom: none !important;
                }
        /* Banner */
        .banner-container {
            height: auto !important;
            min-height: unset !important;
            padding: 2rem 2.5rem !important;
        }

        .hello {
            font-size: 3.5rem;
        }

        .youre-looking {
            font-size: 3rem;
        }

        .gorgeous {
            font-size: 4rem;
        }

        .today {
            font-size: 3.5rem;
        }
        /* Services Intro */
        .services-intro {
            margin: 0 1rem 1.5rem 1rem;
            padding: 1.5rem;
        }

        .service-title {
            font-size: 3rem;
        }

        .service-tagline {
            font-size: 1.1rem;
        }
        /* Polaroid */
        .polaroid-section {
            margin: 0 1rem 2rem 1rem;
            gap: 1.5rem;
        }
        /* D'est Description */
        .dest-description {
            max-width: 90%;
            padding: 2rem;
        }
    }

    /* =============================================
       MOBILE (max-width: 768px)
    ============================================= */
    @@media (max-width: 768px) {
        /* Banner — aggressively override height */
        .banner-container {
            height: auto !important;
            min-height: unset !important;
            max-height: none !important;
            padding: 1.5rem !important;
        }

        .hello {
            font-size: 2.5rem;
        }

        .youre-looking {
            font-size: 2.2rem;
        }

        .gorgeous {
            font-size: 3rem;
        }

        .today {
            font-size: 2.5rem;
        }
        /* Services Intro */
        .services-intro {
            margin: 0 0.5rem 1rem 0.5rem;
            padding: 1rem;
        }

        .divider-line {
            height: 0.6rem;
            margin-bottom: 1.5rem;
        }

        .service-title {
            font-size: 2.5rem;
        }

        .service-tagline {
            font-size: 1rem;
        }
        /* Polaroid */
        .polaroid-section {
            flex-direction: column;
            align-items: center;
            margin: 0 1rem 2rem 1rem;
            padding: 1rem;
            gap: 1.5rem;
        }

        .polaroid-card {
            max-width: 270px;
            width: 100%;
        }

            .polaroid-card:nth-child(2) {
                margin-top: 0;
            }

            .polaroid-card:hover {
                transform: rotate(0deg) scale(1.02);
            }
        /* D'est Description */
        .dest-description {
            max-width: 90%;
            padding: 1.5rem;
            border-radius: 20px;
            margin-bottom: 2rem;
        }

        .dest-title {
            font-size: 2.3rem;
        }

        .dest-text {
            font-size: 0.95rem;
        }
        /* Footer */
        footer {
            padding: 1.5rem 1rem;
        }

        .footer-title {
            font-size: 1.5rem;
            margin-bottom: 1.25rem;
        }

        .social-links {
            gap: 1.5rem;
        }

        .social-item i {
            font-size: 1.25rem;
        }

        .social-item span {
            font-size: 0.8rem;
        }
    }

    /* =============================================
       SMALL MOBILE (max-width: 400px)
    ============================================= */
    @@media (max-width: 400px) {
        .banner-container {
            height: auto !important;
            min-height: unset !important;
            padding: 1rem !important;
        }

        .hello {
            font-size: 2rem;
        }

        .youre-looking {
            font-size: 1.8rem;
        }

        .gorgeous {
            font-size: 2.5rem;
        }

        .today {
            font-size: 2rem;
        }

        .service-title {
            font-size: 2rem;
        }

        .polaroid-card {
            max-width: 220px;
        }

        .polaroid-image {
            height: 200px;
        }

        .dest-description {
            max-width: 95%;
            padding: 1.2rem 1rem;
        }

        .dest-title {
            font-size: 1.9rem;
        }

        .dest-text {
            font-size: 0.9rem;
        }
    }
</style>

@section scripts {
    <script>
        (function () {
            var btn = document.getElementById('hamburgerBtn');
            var nav = document.getElementById('mainNav');
            var overlay = document.getElementById('navOverlay');

            function openMenu() {
                btn.classList.add('open');
                nav.classList.add('open');
                overlay.classList.add('active');
                document.body.style.overflow = 'hidden';
            }

            function closeMenu() {
                btn.classList.remove('open');
                nav.classList.remove('open');
                overlay.classList.remove('active');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', function () {
                nav.classList.contains('open') ? closeMenu() : openMenu();
            });

            overlay.addEventListener('click', closeMenu);

            nav.querySelectorAll('a').forEach(function (link) {
                link.addEventListener('click', closeMenu);
            });
        })();
    </script>
}