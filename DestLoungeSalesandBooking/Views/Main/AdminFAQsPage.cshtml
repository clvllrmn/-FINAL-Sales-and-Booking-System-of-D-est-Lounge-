@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

@Html.AntiForgeryToken()

<div ng-app="DestLoungeSalesandBooking" ng-controller="DestLoungeSalesandBookingController">

    <!-- Sidebar Navigation -->
    <aside class="sidebar">
        <div class="logo-container">
            <a href="@Url.Action("AdminHomepage","Main")">
                <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminHomepage","Main")" class="nav-item">HOME</a>
            <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
            <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
            <a href="@Url.Action("AdminNailTechPage","Main")" class="nav-item ">NAIL TECHS</a>
            <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
            <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item">FAQs</a>
            <a href="@Url.Action("AdminInboxPage","Main")"
               class="nav-item active inbox-link"
               ng-controller="DestLoungeSalesandBookingController"
               ng-init="loadAdminInboxCount()">

                <span>INBOX</span>

                <span class="inbox-badge" ng-if="adminInboxCount > 0">
                    {{adminInboxCount}}
                </span>

            </a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
            <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item">GALLERY</a>
            <a href="@Url.Action("AdminPaymentSetting","Main")" class="nav-item">PAYMENT</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="main-content">
        <div class="faqs-container">
            <div class="page-header">
                <h1 class="faqs-title">FAQs</h1>
                <button class="add-faq-btn" ng-click="openFaqModal()">
                    <i class="fa-solid fa-plus"></i> Add FAQ
                </button>
            </div>

            <div class="faqs-grid">
                <div class="faq-card" ng-repeat="faq in faqs" ng-class="{'active': faq.isOpen}">
                    <div class="admin-controls">
                        <button class="edit-btn" ng-click="openEditFaqModal(faq, $index); $event.stopPropagation();">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="delete-btn" ng-click="deleteFaq($index); $event.stopPropagation();">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                    <div class="faq-question" ng-click="toggleFaq($index)">
                        <h3>{{faq.question}}</h3>
                        <i class="fa-solid" ng-class="faq.isOpen ? 'fa-chevron-up' : 'fa-chevron-down'"></i>
                    </div>
                    <div class="faq-answer" ng-show="faq.isOpen">
                        <p>{{faq.answer}}</p>
                    </div>
                </div>

                <div ng-if="faqs.length === 0" class="faqs-empty">
                    <i class="fa-solid fa-circle-question"></i>
                    <p>No FAQs yet. Click "Add FAQ" to create one.</p>
                </div>
            </div>

            <!-- Trash Panel -->
            <div class="trash-container">
                <button class="trash-toggle-btn" ng-click="toggleFaqTrash()">
                    <i class="fa-solid fa-trash-can-arrow-up"></i>
                    {{ showFaqTrash ? 'Hide Deleted FAQs' : 'View Deleted FAQs' }}
                    <span class="trash-count" ng-if="deletedFaqs.length > 0">{{deletedFaqs.length}}</span>
                </button>
                <div class="trash-panel" ng-show="showFaqTrash">
                    <h2 class="trash-title">Deleted FAQs</h2>
                    <p class="trash-empty" ng-if="deletedFaqs.length === 0">No deleted FAQs found.</p>
                    <div class="deleted-faq-card" ng-repeat="faq in deletedFaqs">
                        <div class="deleted-faq-info">
                            <h3>{{faq.question}}</h3>
                            <p>{{faq.answer}}</p>
                        </div>
                        <div class="deleted-faq-actions">
                            <button class="restore-btn" ng-click="restoreFaq(faq.faqId)">
                                <i class="fa-solid fa-rotate-left"></i> Restore
                            </button>
                            <button class="perm-delete-btn" ng-click="permanentDeleteFaq(faq.faqId)">
                                <i class="fa-solid fa-trash"></i> Delete Forever
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <footer>
            <div class="footer-container">
                <h2 class="footer-title">Follow our Socials!</h2>
                <div class="social-links">
                    <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                        <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
                    </a>
                    <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                        <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
                    </a>
                    <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                        <i class="fa-brands fa-instagram"></i><span>destlounge</span>
                    </a>
                </div>
            </div>
        </footer>
    </div>

    <!-- FAQ MODAL -->
    <div class="faq-modal-backdrop" ng-show="showFaqModal" ng-click="closeFaqModalBackdrop($event)">
        <div class="faq-modal" ng-click="$event.stopPropagation()">
            <div class="faq-modal-header">
                <div class="faq-modal-header-left">
                    <div class="faq-modal-icon"><i class="fa-solid fa-circle-question"></i></div>
                    <div>
                        <span class="faq-modal-title">{{ faqEditingIndex !== null ? 'Edit FAQ' : 'Add New FAQ' }}</span>
                        <div class="faq-modal-subtitle">This will appear on your public FAQ page</div>
                    </div>
                </div>
                <button class="faq-modal-close" ng-click="closeFaqModal()">&#10005;</button>
            </div>
            <div class="faq-modal-body">
                <div class="faq-field-group">
                    <label class="faq-field-label">Question</label>
                    <input class="faq-field-input" type="text" ng-model="faqForm.question"
                           placeholder="e.g. What services do you offer?" />
                    <span class="faq-field-hint">Write a clear, concise question your customers might ask</span>
                </div>
                <div class="faq-field-group">
                    <label class="faq-field-label">Answer</label>
                    <textarea class="faq-field-input faq-field-textarea" ng-model="faqForm.answer"
                              placeholder="Provide a helpful and detailed answer..." rows="4"></textarea>
                    <span class="faq-field-hint">Be specific and friendly in your response</span>
                </div>
                <div class="faq-modal-preview" ng-if="faqForm.question || faqForm.answer">
                    <div class="faq-preview-label">Preview</div>
                    <div class="faq-preview-card">
                        <div class="faq-preview-question">
                            <span>{{ faqForm.question || 'Your question here...' }}</span>
                            <i class="fa-solid fa-chevron-down"></i>
                        </div>
                        <div class="faq-preview-answer" ng-if="faqForm.answer">
                            <p>{{ faqForm.answer }}</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="faq-modal-footer">
                <button class="faq-btn-cancel" ng-click="closeFaqModal()">Cancel</button>
                <button class="faq-btn-save"
                        ng-click="saveFaqModal()"
                        ng-disabled="!faqForm.question || !faqForm.answer">
                    {{ faqEditingIndex !== null ? 'Save Changes' : 'Add FAQ' }}
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Top Bar -->
    <div class="mobile-topbar">
        <a href="@Url.Action("AdminHomepage","Main")">
            <img src="~/Content/Pictures/DestLogo.png" alt="D'est Lounge">
        </a>
        <button class="mobile-menu-btn" onclick="toggleMobileNav()">
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>

    <div class="mobile-nav-overlay" id="mobileOverlay" onclick="toggleMobileNav()"></div>

    <div class="mobile-nav-drawer" id="mobileDrawer">
        <nav class="sidebar-nav">
            <a href="@Url.Action("AdminHomepage","Main")" class="nav-item">HOME</a>
            <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
            <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
            <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
            <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item active">FAQs</a>
            <a href="@Url.Action("AdminInboxPage","Main")" class="nav-item">INBOX</a>
            <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
            <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item">GALLERY</a>
            <a href="@Url.Action("AdminPaymentSetting","Main")" class="nav-item">PAYMENT</a>
        </nav>
        <div class="sidebar-footer">
            <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </div>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Georgia', serif;
            background-color: #d4c4b0;
        }

        /* SIDEBAR */
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            width: 10%;
            min-width: 9rem;
            height: 100vh;
            background-color: #e7dfd6;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 1.25rem 0;
            z-index: 1000;
        }

        .logo-container {
            margin-bottom: 2rem;
        }

        .sidebar-logo {
            width: 3.5rem;
            height: auto;
        }

        .sidebar-nav {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            width: 100%;
        }

        .nav-item {
            color: #5a4a3a;
            text-decoration: none;
            padding: 1rem 0.625rem;
            font-size: 1rem;
            font-weight: 500;
            text-align: center;
            transition: background-color 0.3s;
            letter-spacing: 0.0625rem;
            display: block;
        }

            .nav-item:hover {
                background-color: rgba(90,74,58,0.1);
            }

            .nav-item.active {
                background-color: rgba(139,111,71,0.3);
                border-left: 0.25rem solid #8b6f47;
            }

        .sidebar-footer {
            margin-top: auto;
            padding: 1.25rem 0;
        }

        .admin-link {
            color: #5a4a3a;
            text-decoration: none;
            font-size: 0.75rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.3125rem;
        }

            .admin-link i {
                font-size: 1.25rem;
            }

        /* MAIN */
        .main-content {
            margin-left: 10%;
            background-color: #d4c4b0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* FAQS CONTAINER */
        .faqs-container {
            background-color: #e7dfd6;
            padding: 3rem 2rem;
            flex: 1;
        }

        /* PAGE HEADER */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
        }

        .faqs-title {
            font-size: 4rem;
            font-weight: 600;
            color: #6b4423;
            margin: 0;
            text-shadow: 0.125rem 0.125rem 0.25rem rgba(0,0,0,0.1);
        }

        .add-faq-btn {
            background-color: #4a7c59;
            color: white;
            border: none;
            padding: 0.75rem 1.5rem;
            border-radius: 0.5rem;
            cursor: pointer;
            font-size: 0.95rem;
            font-weight: 600;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .add-faq-btn:hover {
                background-color: #3a6449;
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            }

        /* GRID */
        .faqs-grid {
            display: grid;
            grid-template-columns: repeat(3,1fr);
            gap: 2rem;
            max-width: 87.5rem;
            margin: 0 auto;
        }

        /* CARD */
        .faq-card {
            background-color: #6b4423;
            border-radius: 1.25rem;
            padding: 2rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0.25rem 0.25rem 0.75rem rgba(0,0,0,0.2);
            min-height: 12.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
        }

            .faq-card:hover {
                transform: translateY(-0.3125rem);
                box-shadow: 0.375rem 0.375rem 1rem rgba(0,0,0,0.3);
            }

            .faq-card.active {
                background-color: #5d3a1f;
            }

        .admin-controls {
            position: absolute;
            top: 0.75rem;
            right: 0.75rem;
            display: flex;
            gap: 0.5rem;
            z-index: 10;
        }

        .edit-btn, .delete-btn {
            background: rgba(255,255,255,0.95);
            border: none;
            border-radius: 50%;
            width: 2rem;
            height: 2rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
            box-shadow: 0 0.125rem 0.375rem rgba(0,0,0,0.2);
        }

        .edit-btn {
            color: #4a7c59;
        }

            .edit-btn:hover {
                background: #4a7c59;
                color: white;
                transform: scale(1.1);
            }

        .delete-btn {
            color: #c84b4b;
        }

            .delete-btn:hover {
                background: #c84b4b;
                color: white;
                transform: scale(1.1);
            }

            .edit-btn i, .delete-btn i {
                font-size: 0.875rem;
            }

        .faq-question {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 1rem;
            padding-top: 2rem;
        }

            .faq-question h3 {
                color: white;
                font-size: 1.2rem;
                font-weight: 600;
                margin: 0;
                line-height: 1.4;
                flex: 1;
            }

            .faq-question i {
                color: white;
                font-size: 1.2rem;
            }

        .faq-answer {
            margin-top: 1.5rem;
            padding-top: 1.5rem;
            border-top: 0.125rem solid rgba(255,255,255,0.3);
            animation: fadeIn 0.3s ease;
        }

            .faq-answer p {
                color: white;
                font-size: 1rem;
                line-height: 1.6;
                margin: 0;
            }

        .faqs-empty {
            grid-column: 1/-1;
            text-align: center;
            padding: 3rem;
            color: #8a7060;
        }

            .faqs-empty i {
                font-size: 3rem;
                margin-bottom: 1rem;
                display: block;
                opacity: 0.4;
            }

        /* TRASH */
        .trash-container {
            max-width: 87.5rem;
            margin: 2rem auto 0;
            padding: 0 0 2rem 0;
        }

        .trash-toggle-btn {
            background: transparent;
            border: 2px solid #6b4423;
            color: #6b4423;
            padding: 0.6rem 1.5rem;
            border-radius: 1.875rem;
            font-size: 0.95rem;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 0 auto;
        }

            .trash-toggle-btn:hover {
                background-color: #6b4423;
                color: white;
            }

        .trash-count {
            background: #c84b4b;
            color: white;
            border-radius: 50%;
            padding: 0.1rem 0.5rem;
            font-size: 0.8rem;
        }

        .trash-panel {
            margin-top: 1.5rem;
            background: rgba(107,68,35,0.08);
            border: 2px dashed #6b4423;
            border-radius: 1rem;
            padding: 1.5rem;
        }

        .trash-title {
            color: #6b4423;
            font-size: 1.5rem;
            margin-bottom: 1rem;
            text-align: center;
        }

        .trash-empty {
            color: #8a7060;
            text-align: center;
            font-style: italic;
            padding: 1rem 0;
        }

        .deleted-faq-card {
            background: white;
            border-radius: 0.75rem;
            padding: 1rem 1.25rem;
            margin-bottom: 0.75rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            opacity: 0.85;
        }

        .deleted-faq-info {
            flex: 1;
            min-width: 0;
        }

            .deleted-faq-info h3 {
                color: #4a3020;
                font-size: 1rem;
                margin-bottom: 0.25rem;
            }

            .deleted-faq-info p {
                color: #7a6050;
                font-size: 0.875rem;
                margin: 0;
                line-height: 1.4;
            }

        .deleted-faq-actions {
            display: flex;
            gap: 0.5rem;
            flex-shrink: 0;
        }

        .restore-btn {
            background: #4a7c59;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.3s;
        }

            .restore-btn:hover {
                background: #3a6048;
                transform: translateY(-1px);
            }

        .perm-delete-btn {
            background: #c84b4b;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 1rem;
            cursor: pointer;
            font-size: 0.875rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            transition: all 0.3s;
        }

            .perm-delete-btn:hover {
                background: #a83a3a;
                transform: translateY(-1px);
            }

        /* FOOTER */
        footer {
            background-color: #e7d7c8;
            border: 2px solid #d4c4b0;
            border-left: none;
            border-right: none;
            padding: 2.5rem 3rem;
            text-align: center;
        }

        .footer-container {
            margin: 0 auto;
        }

        .footer-title {
            font-size: 2.5rem;
            font-weight: 700;
            color: #6b4423;
            margin: 0 0 2rem 0;
            font-style: italic;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .social-links {
            display: flex;
            justify-content: center;
            gap: 3rem;
            flex-wrap: wrap;
        }

        .social-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            text-decoration: none;
            color: #5a4a3a;
            transition: color 0.3s;
        }

            .social-item:hover {
                color: #8b6f47;
            }

            .social-item i {
                font-size: 1.5rem;
            }

            .social-item span {
                font-size: 0.9rem;
                font-weight: 500;
            }

        /* MODAL */
        .faq-modal-backdrop {
            position: fixed;
            inset: 0;
            z-index: 2000;
            backdrop-filter: blur(1px);
            -webkit-backdrop-filter: blur(1px);
            display: none;
            align-items: center;
            justify-content: center;
        }

            .faq-modal-backdrop.ng-hide {
                display: none !important;
            }

            .faq-modal-backdrop:not(.ng-hide) {
                display: flex !important;
            }

        .faq-modal {
            background: #faf7f4;
            border-radius: 20px;
            width: 100%;
            max-width: 520px;
            border: 1.5px solid #c9b89e;
            overflow: hidden;
        }

        .faq-modal-header {
            background: #6b4423;
            padding: 1.25rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .faq-modal-header-left {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .faq-modal-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(255,255,255,0.18);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fce8d5;
            font-size: 15px;
        }

        .faq-modal-title {
            font-size: 1.1rem;
            font-weight: 600;
            color: #fce8d5;
            display: block;
        }

        .faq-modal-subtitle {
            font-size: 0.72rem;
            color: rgba(252,232,213,0.65);
            margin-top: 2px;
        }

        .faq-modal-close {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(255,255,255,0.15);
            border: none;
            color: #fce8d5;
            font-size: 13px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.2s;
        }

            .faq-modal-close:hover {
                background: rgba(255,255,255,0.3);
            }

        .faq-modal-body {
            padding: 1.5rem 1.75rem;
            display: flex;
            flex-direction: column;
            gap: 1.1rem;
        }

        .faq-field-group {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
        }

        .faq-field-label {
            font-size: 0.78rem;
            font-weight: 600;
            color: #8b6030;
            text-transform: uppercase;
            letter-spacing: 0.7px;
        }

        .faq-field-input {
            background: #fff;
            border: 1.5px solid #d6c4ae;
            border-radius: 10px;
            padding: 0.65rem 0.9rem;
            font-size: 0.95rem;
            color: #4a3018;
            font-family: 'Georgia', serif;
            outline: none;
            width: 100%;
            transition: border-color 0.2s;
        }

            .faq-field-input:focus {
                border-color: #8b6030;
            }

        .faq-field-textarea {
            resize: vertical;
            min-height: 100px;
            line-height: 1.6;
        }

        .faq-field-hint {
            font-size: 0.75rem;
            color: #a08060;
        }

        .faq-modal-preview {
            background: #f5f0ea;
            border-radius: 10px;
            border: 1px dashed #c9b89e;
            padding: 0.85rem 1rem;
        }

        .faq-preview-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: #8b6030;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
        }

        .faq-preview-card {
