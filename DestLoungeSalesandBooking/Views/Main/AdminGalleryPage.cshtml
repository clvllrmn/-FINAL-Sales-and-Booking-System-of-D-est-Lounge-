@{
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}

<!-- Sidebar Navigation -->
<aside class="sidebar">
    <div class="logo-container">
        <a href="@Url.Action("AdminHomepage","Main")">
            <img src="~/Content/Pictures/DestLogo.png" class="sidebar-logo" alt="D'est Lounge">
        </a>
    </div>
    <nav class="sidebar-nav">
        <a href="@Url.Action("AdminHomepage","Main")" class="nav-item">HOME</a>
        <a href="@Url.Action("AdminBookingPage","Main")" class="nav-item">BOOKINGS</a>
        <a href="@Url.Action("AdminServicePage","Main")" class="nav-item">SERVICES</a>
        <a href="@Url.Action("AdminContactPage","Main")" class="nav-item">CONTACT</a>
        <a href="@Url.Action("AdminFAQsPage","Main")" class="nav-item">FAQs</a>
        <a href="@Url.Action("AdminInboxPage","Main")" class="nav-item">INBOX</a>
        <a href="@Url.Action("AdminSalesPage","Main")" class="nav-item">SALES</a>
        <a href="@Url.Action("AdminGalleryPage","Main")" class="nav-item active">GALLERY</a>
        <a href="@Url.Action("AdminPaymentSetting","Main")" class="nav-item">PAYMENT</a>

    </nav>
    <div class="sidebar-footer">
        <a href="@Url.Action("Logout","Account")" class="admin-link" title="Logout">
            <i class="fa-solid fa-right-from-bracket"></i>
            <span>Logout</span>
        </a>
    </div>
</aside>

<div class="main-content" ng-controller="DestLoungeSalesandBookingController">

    <!-- Hero -->
    <div class="gallery-hero">
        <div class="hero-left">
            <h1 class="gallery-hero-title">Gallery &amp; Reviews Manager</h1>
            <p class="gallery-hero-sub">Manage photos and moderate client reviews</p>
        </div>
        <a href="@Url.Action("GalleryPage","Main")" class="view-public-btn" target="_blank">
            <i class="fa-solid fa-arrow-up-right-from-square"></i> View Public Page
        </a>
    </div>

    <!-- Tabs -->
    <div class="tab-bar">
        <button class="tab-btn" ng-class="{'tab-active': adminTab === 'gallery'}" ng-click="adminTab = 'gallery'">
            <i class="fa-solid fa-images"></i> Gallery
            <span class="tab-count">{{galleryPhotos.length}}</span>
        </button>
        <button class="tab-btn" ng-class="{'tab-active': adminTab === 'reviews'}" ng-click="adminTab = 'reviews'">
            <i class="fa-solid fa-star"></i> Reviews
            <span class="tab-count">{{reviews.length}}</span>
        </button>
        <button class="tab-btn" ng-class="{'tab-active': adminTab === 'archived'}" ng-click="adminTab = 'archived'">
            <i class="fa-solid fa-box-archive"></i> Archived
            <span class="tab-count tab-count-warn">{{archivedReviews.length}}</span>
        </button>
    </div>

    <!-- GALLERY TAB -->
    <div ng-show="adminTab === 'gallery'" class="tab-content">

        <!-- Upload Card -->
        <div class="upload-card">
            <h3><i class="fa-solid fa-cloud-arrow-up"></i> Upload New Photo</h3>
            <div class="upload-form">
                <div class="upload-dropzone" onclick="document.getElementById('photoFileInput').click()">
                    <i class="fa-solid fa-image"></i>
                    <p>Click to select a photo</p>
                    <span>JPG, PNG, WEBP supported</span>
                    <input type="file" id="photoFileInput" accept="image/*"
                           onchange="angular.element(this).scope().onFileSelected(this)" style="display:none">
                </div>
                <div class="upload-fields">
                    <div class="field-group">
                        <label>Caption</label>
                        <input type="text" class="admin-input" ng-model="newPhoto.caption" placeholder="e.g. Gel Manicure - Nude Pink">
                    </div>
                    <div class="upload-preview-wrap" ng-show="newPhoto.previewUrl">
                        <img ng-src="{{newPhoto.previewUrl}}" class="upload-preview-img" alt="Preview">
                    </div>
                    <button class="admin-btn admin-btn-primary" ng-click="uploadPhoto()" ng-disabled="!newPhoto.file || !newPhoto.caption">
                        <i class="fa-solid fa-plus"></i> Add to Gallery
                    </button>
                </div>
            </div>
        </div>

        <!-- Gallery Grid Preview -->
        <div class="section-label"><i class="fa-solid fa-eye"></i> Public Preview</div>
        <div class="gallery-grid" ng-show="galleryPhotos.length > 0">
            <div class="gallery-item" ng-repeat="photo in galleryPhotos">
                <img ng-src="{{photo.imageUrl}}" alt="{{photo.caption}}">
                <div class="gallery-overlay">
                    <span class="gallery-caption">{{photo.caption}}</span>
                    <div class="gallery-item-actions">
                        <button class="item-action-btn item-edit" ng-click="startEditPhoto(photo); $event.stopPropagation()" title="Edit">
                            <i class="fa-solid fa-pen"></i>
                        </button>
                        <button class="item-action-btn item-delete" ng-click="confirmDeletePhoto(photo); $event.stopPropagation()" title="Delete">
                            <i class="fa-solid fa-trash"></i>
                        </button>
                    </div>
                </div>
                <!-- Inline edit overlay -->
                <div class="inline-edit-overlay" ng-show="photo.editing" ng-click="$event.stopPropagation()">
                    <input type="text" class="admin-input" ng-model="photo.editCaption" placeholder="Caption">
                    <div class="inline-edit-actions">
                        <button class="admin-btn admin-btn-primary" ng-click="saveEditPhoto(photo)"><i class="fa-solid fa-check"></i> Save</button>
                        <button class="admin-btn admin-btn-secondary" ng-click="cancelEditPhoto(photo)">Cancel</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="empty-state" ng-show="galleryPhotos.length === 0">
            <i class="fa-regular fa-image"></i>
            <p>No photos yet. Upload one above.</p>
        </div>
    </div>

    <!-- REVIEWS TAB -->
    <div ng-show="adminTab === 'reviews'" class="tab-content">
        <div class="stats-bar">
            <div class="stat-card"><span class="stat-num">{{reviews.length}}</span><span class="stat-label">Active</span></div>
            <div class="stat-card"><span class="stat-num">{{averageRating()}}</span><span class="stat-label">Avg. Rating</span></div>
            <div class="stat-card stat-warn"><span class="stat-num">{{flaggedCount()}}</span><span class="stat-label">Flagged</span></div>
            <div class="stat-card stat-muted"><span class="stat-num">{{archivedReviews.length}}</span><span class="stat-label">Archived</span></div>
        </div>

        <div class="filter-row">
            <select class="admin-select" ng-model="reviewStarFilter">
                <option value="">All Ratings</option>
                <option value="5">★★★★★ 5 Stars</option>
                <option value="4">★★★★☆ 4 Stars</option>
                <option value="3">★★★☆☆ 3 Stars</option>
                <option value="2">★★☆☆☆ 2 Stars</option>
                <option value="1">★☆☆☆☆ 1 Star</option>
            </select>
            <input type="text" class="admin-search" ng-model="reviewSearch" placeholder="Search reviews...">
        </div>

        <div class="reviews-list">
            <div class="review-admin-card" ng-repeat="review in reviews | filter:reviewSearchFilter" ng-class="{'flagged-card': review.flagged}">
                <div class="rac-top">
                    <div class="rac-stars">
                        <i ng-repeat="s in [1,2,3,4,5]" class="fa-star" ng-class="s <= review.rating ? 'fa-solid' : 'fa-regular'"></i>
                    </div>
                    <span class="rac-service"><i class="fa-solid fa-spa"></i> {{review.serviceAvailed}}</span>
                    <span class="rac-date">{{review.date | date:'MMM d, yyyy'}}</span>
                    <span class="flag-badge" ng-show="review.flagged"><i class="fa-solid fa-flag"></i> Flagged</span>
                </div>
                <p class="rac-text">&ldquo;{{review.reviewText}}&rdquo;</p>
                <div class="rac-actions">
                    <button class="admin-btn admin-btn-flag" ng-show="!review.flagged" ng-click="flagReview(review)"><i class="fa-solid fa-flag"></i> Flag</button>
                    <button class="admin-btn admin-btn-unflag" ng-show="review.flagged" ng-click="unflagReview(review)"><i class="fa-solid fa-flag-checkered"></i> Unflag</button>
                    <button class="admin-btn admin-btn-archive" ng-click="archiveReview(review)"><i class="fa-solid fa-box-archive"></i> Archive</button>
                </div>
            </div>
            <div class="empty-state" ng-show="(reviews | filter:reviewSearchFilter).length === 0">
                <i class="fa-regular fa-star"></i>
                <p>No reviews match your filter.</p>
            </div>
        </div>
    </div>

    <!-- ARCHIVED TAB -->
    <div ng-show="adminTab === 'archived'" class="tab-content">
        <div class="reviews-list">
            <div class="review-admin-card archived-card" ng-repeat="review in archivedReviews | filter:archivedSearch">
                <div class="rac-top">
                    <div class="rac-stars">
                        <i ng-repeat="s in [1,2,3,4,5]" class="fa-star" ng-class="s <= review.rating ? 'fa-solid' : 'fa-regular'"></i>
                    </div>
                    <span class="rac-service"><i class="fa-solid fa-spa"></i> {{review.serviceAvailed}}</span>
                    <span class="rac-date">{{review.date | date:'MMM d, yyyy'}}</span>
                    <span class="archived-badge"><i class="fa-solid fa-box-archive"></i> Archived</span>
                </div>
                <p class="rac-text">&ldquo;{{review.reviewText}}&rdquo;</p>
                <div class="rac-actions">
                    <button class="admin-btn admin-btn-restore" ng-click="restoreReview(review)"><i class="fa-solid fa-rotate-left"></i> Restore</button>
                </div>
            </div>
            <div class="empty-state" ng-show="archivedReviews.length === 0">
                <i class="fa-solid fa-box-archive"></i>
                <p>No archived reviews.</p>
            </div>
        </div>
    </div>

    <!-- DELETE MODAL -->
    <div class="modal-overlay" ng-show="deleteModal.show">
        <div class="modal-card">
            <div class="modal-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <h3>Delete Photo?</h3>
            <p>Are you sure you want to delete <strong>&ldquo;{{deleteModal.photo.caption}}&rdquo;</strong>? This cannot be undone.</p>
            <div class="modal-actions">
                <button class="admin-btn admin-btn-secondary" ng-click="deleteModal.show = false">Cancel</button>
                <button class="admin-btn admin-btn-danger" ng-click="deletePhoto()"><i class="fa-solid fa-trash"></i> Delete</button>
            </div>
        </div>
    </div>

    <!-- TOAST -->
    <div class="toast" ng-show="toast.show" ng-class="toast.type">
        <i class="fa-solid" ng-class="toast.type === 'toast-success' ? 'fa-circle-check' : 'fa-circle-exclamation'"></i>
        {{toast.message}}
    </div>

    <!-- Footer -->
    <footer>
        <div class="footer-container">
            <h2 class="footer-title">Follow our Socials!</h2>
            <div class="social-links">
                <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank"><i class="fa-brands fa-tiktok"></i><span>destlounge</span></a>
                <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank"><i class="fa-brands fa-facebook"></i><span>D'est Lounge</span></a>
                <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank"><i class="fa-brands fa-instagram"></i><span>destlounge</span></a>
            </div>
        </div>
    </footer>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Georgia', serif;
        background-color: #d4c4b0;
    }

    /* Sidebar */
    .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 10%;
        min-width: 9rem;
        height: 100vh;
        background-color: #e7dfd6;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.25rem 0;
        z-index: 1000;
    }

    .logo-container {
        margin-bottom: 2rem;
    }

    .sidebar-logo {
        width: 3.5rem;
        height: auto;
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        width: 100%;
    }

    .nav-item {
        color: #5a4a3a;
        text-decoration: none;
        padding: 1rem 0.625rem;
        font-size: 1rem;
        font-weight: 500;
        text-align: center;
        transition: background-color 0.3s;
        letter-spacing: 0.0625rem;
        display: block;
    }

        .nav-item:hover {
            background-color: rgba(90,74,58,0.1);
        }

        .nav-item.active {
            background-color: rgba(139,111,71,0.3);
            border-left: 0.25rem solid #8b6f47;
        }

    .sidebar-footer {
        margin-top: auto;
        padding: 1.25rem 0;
    }

    .admin-link {
        color: #5a4a3a;
        text-decoration: none;
        font-size: 0.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3125rem;
    }

        .admin-link i {
            font-size: 1.25rem;
        }

    /* Main */
    .main-content {
        margin-left: 10%;
        min-height: 100vh;
        background-color: #f5f0eb;
    }

    /* Hero */
    .gallery-hero {
        background-color: #f5f0eb;
        padding: 2rem 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .hero-left {
    }

    .gallery-hero-title {
        font-size: 1.8rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 0.3rem 0;
    }

    .gallery-hero-sub {
        font-size: 0.9rem;
        color: #c1a882;
        margin: 0;
    }

    .view-public-btn {
        padding: 0.7rem 1.5rem;
        background: transparent;
        border: 2px solid #c1a882;
        border-radius: 25px;
        color: #c1a882;
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.3s;
    }

        .view-public-btn:hover {
            background-color: #c1a882;
            color: #3d2817;
        }

    /* Tabs */
    .tab-bar {
        display: flex;
        background-color: #e7dfd6;
        border-bottom: 3px solid #c1b2a5;
        padding: 0 2rem;
        gap: 0;
    }

    .tab-btn {
        padding: 1rem 2rem;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        background: none;
        color: #8b6f47;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        border-bottom: 3px solid transparent;
        margin-bottom: -3px;
        transition: all 0.2s;
        font-family: 'Georgia', serif;
        border-radius: 0;
    }

        .tab-btn:hover {
            color: #6b4423;
            background-color: transparent;
            border-color: transparent;
            box-shadow: none;
        }

        .tab-btn.tab-active {
            color: #6b4423;
            border-bottom-color: #6b4423 !important;
            background-color: white;
            box-shadow: none;
        }

    .tab-count {
        background-color: #d4c4b0;
        color: #5d4037;
        border-radius: 12px;
        padding: 0.1rem 0.6rem;
        font-size: 0.78rem;
        font-weight: 700;
    }

    .tab-count-warn {
        background-color: #f4c6b0;
        color: #a03010;
    }

    /* Tab content */
    .tab-content {
        padding: 2rem 3rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    /* Upload */
    .upload-card {
        background-color: white;
        border-radius: 16px;
        border: 2px solid #d4c4b0;
        padding: 1.8rem;
        box-shadow: 2px 4px 12px rgba(0,0,0,0.08);
    }

        .upload-card h3 {
            font-size: 1.1rem;
            font-weight: 700;
            color: #3d2817;
            margin: 0 0 1.5rem 0;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

    .upload-form {
        display: flex;
        gap: 2rem;
        align-items: flex-start;
        flex-wrap: wrap;
    }

    .upload-dropzone {
        flex: 0 0 180px;
        height: 180px;
        border: 2.5px dashed #c1b2a5;
        border-radius: 12px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.3s;
        background-color: #faf8f5;
        gap: 0.5rem;
        color: #8b6f47;
    }

        .upload-dropzone:hover {
            border-color: #6b4423;
            background-color: #f5f0eb;
            color: #6b4423;
        }

        .upload-dropzone i {
            font-size: 2.5rem;
        }

        .upload-dropzone p {
            font-size: 0.9rem;
            font-weight: 600;
            margin: 0;
        }

        .upload-dropzone span {
            font-size: 0.75rem;
            color: #b0907a;
        }

    .upload-fields {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        min-width: 200px;
    }

    .upload-preview-wrap {
        border-radius: 10px;
        overflow: hidden;
        border: 2px solid #d4c4b0;
    }

    .upload-preview-img {
        width: 100%;
        max-height: 120px;
        object-fit: cover;
        display: block;
    }

    .field-group {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
    }

        .field-group label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #5d4037;
        }

    /* Section label */
    .section-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: #5d4037;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0 0 0.5rem 0;
        border-bottom: 2px solid #e7dfd6;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* Gallery grid (admin version) */
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .gallery-item {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        border: 3px solid #d4c4b0;
        box-shadow: 3px 3px 10px rgba(0,0,0,0.12);
        aspect-ratio: 1/1;
    }

        .gallery-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.4s ease;
        }

        .gallery-item:hover img {
            transform: scale(1.04);
        }

    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(transparent, rgba(61,40,23,0.9));
        padding: 1.2rem 1rem 0.8rem;
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .gallery-item:hover .gallery-overlay {
        opacity: 1;
    }

    .gallery-caption {
        color: white;
        font-size: 0.85rem;
        font-weight: 600;
        flex: 1;
        margin-right: 0.5rem;
    }

    .gallery-item-actions {
        display: flex;
        gap: 0.4rem;
    }

    .item-action-btn {
        width: 32px;
        height: 32px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        transition: all 0.2s;
    }

    .item-edit {
        background-color: rgba(255,255,255,0.9);
        color: #6b4423;
    }

        .item-edit:hover {
            background-color: #6b4423;
            color: white;
        }

    .item-delete {
        background-color: rgba(255,255,255,0.9);
        color: #c0392b;
    }

        .item-delete:hover {
            background-color: #c0392b;
            color: white;
        }

    .inline-edit-overlay {
        position: absolute;
        inset: 0;
        background-color: rgba(61,40,23,0.92);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
        gap: 1rem;
    }

    .inline-edit-actions {
        display: flex;
        gap: 0.6rem;
    }

    /* Inputs */
    .admin-input {
        padding: 0.7rem 1rem;
        border: 2px solid #d4c4b0;
        border-radius: 10px;
        font-size: 0.95rem;
        color: #3d2817;
        font-family: inherit;
        outline: none;
        width: 100%;
        box-sizing: border-box;
        transition: border-color 0.3s;
    }

        .admin-input:focus {
            border-color: #6b4423;
        }

    .admin-search {
        padding: 0.6rem 1rem;
        border: 2px solid #d4c4b0;
        border-radius: 20px;
        font-size: 0.9rem;
        color: #3d2817;
        font-family: inherit;
        outline: none;
        min-width: 200px;
        transition: border-color 0.3s;
    }

        .admin-search:focus {
            border-color: #6b4423;
        }

    .admin-select {
        padding: 0.6rem 1rem;
        border: 2px solid #d4c4b0;
        border-radius: 20px;
        font-size: 0.9rem;
        color: #3d2817;
        font-family: inherit;
        background-color: white;
        cursor: pointer;
        outline: none;
    }

    /* Buttons */
    .admin-btn {
        padding: 0.55rem 1.2rem;
        font-size: 0.88rem;
        font-weight: 600;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: all 0.2s;
        font-family: 'Georgia', serif;
    }

        .admin-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

    .admin-btn-primary {
        background-color: #6b4423;
        color: white;
    }

        .admin-btn-primary:hover:not(:disabled) {
            background-color: #5d3a1f;
        }

    .admin-btn-secondary {
        background-color: #e7dfd6;
        color: #5d4037;
    }

        .admin-btn-secondary:hover {
            background-color: #d4c4b0;
        }

    .admin-btn-danger {
        background-color: #c0392b;
        color: white;
    }

        .admin-btn-danger:hover {
            background-color: #a93226;
        }

    .admin-btn-flag {
        background-color: #f39c12;
        color: white;
    }

        .admin-btn-flag:hover {
            background-color: #d68910;
        }

    .admin-btn-unflag {
        background-color: #e7dfd6;
        color: #5d4037;
    }

    .admin-btn-archive {
        background-color: #7f8c8d;
        color: white;
    }

        .admin-btn-archive:hover {
            background-color: #6c7a7b;
        }

    .admin-btn-restore {
        background-color: #27ae60;
        color: white;
    }

        .admin-btn-restore:hover {
            background-color: #1e8449;
        }

    /* Stats */
    .stats-bar {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
