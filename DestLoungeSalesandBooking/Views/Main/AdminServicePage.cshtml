 Main Content Area 
<div class="main-content" ng-controller="DestLoungeSalesandBookingController">
    @Html.AntiForgeryToken()

     Services Section 
    <div class="services-page-container">
        <div class="services-sidebar">
            <h2 class="services-sidebar-title">Services</h2>
            <div class="service-category"
                 ng-class="{'active': selectedCategory === 'all'}"
                 ng-click="filterServices('all')">
                <h3>All Services</h3>
            </div>
            <div class="service-category"
                 ng-class="{'active': selectedCategory === 'manicure'}"
                 ng-click="filterServices('manicure')">
                <h3>Manicure</h3>
            </div>
            <div class="service-category"
                 ng-class="{'active': selectedCategory === 'pedicure'}"
                 ng-click="filterServices('pedicure')">
                <h3>Pedicure</h3>
            </div>
        </div>

        <div class="services-content" ng-show="!showServiceTrash">
            <div class="service-card" ng-repeat="service in services | filter:categoryFilter">
                <div class="admin-controls">
                    <button class="edit-btn" ng-click="editService(service)">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </button>
                    <button class="delete-btn" ng-click="deleteService(service)">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </div>
                <div class="service-image">
                    <img ng-src="{{service.image}}" alt="{{service.name}}">
                </div>
                <div class="service-name">{{service.name}}</div>
                <div class="service-description" ng-if="service.description">{{service.description}}</div>
                <div class="service-price">₱{{service.price}}</div>
            </div>
        </div>
    </div>

     Add Service Button 
    <div class="add-service-container">
        <button class="add-service-button" ng-click="openAddServiceModal()">
            <i class="fa-solid fa-plus"></i> Add Service
        </button>
    </div>

     Trash Toggle Button 
    <div style="text-align:center; padding: 0 0 1.5rem 0; background-color:#f5f0eb;">
        <button class="add-service-button"
                style="background-color:#8b4513;"
                ng-click="toggleServiceTrash()">
            <i class="fa-solid fa-trash-can"></i>
            {{showServiceTrash ? 'Hide Deleted Services' : 'View Deleted Services'}}
        </button>
    </div>

     Deleted Services Panel 
    <div ng-show="showServiceTrash">
        <div ng-repeat="s in deletedServices"
             style="display:flex; justify-content:space-between; align-items:center;
        padding:0.8rem 1rem; border-bottom:1px solid #e0d5cb;">

            <div>
                <strong style="color:#3d2817;">{{s.name}}</strong>
                <span style="color:#888; margin-left:1rem;">₱{{s.price}}</span>
                <p style="margin:0.2rem 0 0; font-size:0.85rem; color:#777;">{{s.description}}</p>
            </div>

            <div style="display:flex; gap:0.5rem;">
                <button class="edit-btn"
                        style="border-radius:6px; width:auto; padding:0.4rem 1rem;"
                        ng-click="restoreService(s.serviceId)">
                    <i class="fa-solid fa-rotate-left"></i> Restore
                </button>

                <button class="delete-btn"
                        style="border-radius:6px; width:auto; padding:0.4rem 1rem;"
                        ng-click="permanentDeleteService(s.serviceId)">
                    <i class="fa-solid fa-trash-can"></i> Delete
                </button>
            </div>

        </div>
    </div>



     Add/Edit Service Modal 
    <div class="modal-overlay" ng-show="showServiceModal" ng-click="closeServiceModal()">
        <div class="service-modal" ng-click="$event.stopPropagation()">
            <h2 class="modal-title">{{isEditMode ? 'Edit Service' : 'Add New Service'}}</h2>
            <form name="serviceForm" novalidate>
                <div class="form-group">
                    <label for="serviceName">Service Name</label>
                    <input type="text" id="serviceName" name="serviceName" class="form-input"
                           placeholder="Enter service name" ng-model="currentService.name" required>
                    <span class="error-message" ng-show="serviceForm.serviceName.$invalid && serviceForm.serviceName.$dirty">
                        Service name is required
                    </span>
                </div>
                <div class="form-group">
                    <label for="serviceCategory">Category</label>
                    <select id="serviceCategory" name="serviceCategory" class="form-input"
                            ng-model="currentService.category" required>
                        <option value="">Select Category</option>
                        <option value="manicure">Manicure</option>
                        <option value="pedicure">Pedicure</option>
                    </select>
                    <span class="error-message" ng-show="serviceForm.serviceCategory.$invalid && serviceForm.serviceCategory.$dirty">
                        Please select a category
                    </span>
                </div>
                <div class="form-group">
                    <label for="servicePrice">Price (₱)</label>
                    <input type="number" id="servicePrice" name="servicePrice" class="form-input"
                           placeholder="Enter price" ng-model="currentService.price" min="0" step="0.01" required
                           onkeydown="return event.key !== 'e' && event.key !== 'E' && event.key !== '+' && event.key !== '-'">
                    <span class="error-message" ng-show="serviceForm.servicePrice.$invalid && serviceForm.servicePrice.$dirty">
                        Price is required
                    </span>
                </div>

                 ── Description Field ── 
                <div class="form-group">
                    <label for="serviceDescription">Description</label>
                    <textarea id="serviceDescription" name="serviceDescription" class="form-input form-textarea"
                              placeholder="Enter a short description of the service..."
                              ng-model="currentService.description"
                              maxlength="300"
                              rows="3"
                              required></textarea>
                    <small style="color:#a89585;font-size:0.8rem;">Max 500 characters</small>
                    <span class="error-message" ng-show="serviceForm.serviceDescription.$invalid && serviceForm.serviceDescription.$dirty">
                        Description is required
                    </span>
                </div>

                <div class="form-group">
                    <label for="serviceImage">Service Image</label>
                    <input type="file" id="serviceImage" name="serviceImage" class="form-input-file"
                           accept="image/*" onchange="angular.element(this).scope().handleImageUpload(this.files[0])">
                    <div class="image-preview" ng-show="currentService.image">
                        <img ng-src="{{currentService.image}}" alt="Service Preview">
                    </div>
                </div>
                <div class="modal-actions">
                    <button type="button" class="cancel-btn" ng-click="closeServiceModal()">Cancel</button>
                    <button type="button" class="save-btn" ng-click="saveService()" ng-disabled="serviceForm.$invalid">
                        {{isEditMode ? 'Update Service' : 'Add Service'}}
                    </button>
                </div>
            </form>
        </div>
    </div>

     Footer 
    <footer>
        <div class="footer-container">
            <h2 class="footer-title">Follow our Socials!</h2>
            <div class="social-links">
                <a href="https://www.tiktok.com/&#64;destlounge" class="social-item" target="_blank">
                    <i class="fa-brands fa-tiktok"></i><span>destlounge</span>
                </a>
                <a href="https://www.facebook.com/profile.php?id=61578352581708" class="social-item" target="_blank">
                    <i class="fa-brands fa-facebook"></i><span>D'est Lounge</span>
                </a>
                <a href="https://www.instagram.com/destlounge/" class="social-item" target="_blank">
                    <i class="fa-brands fa-instagram"></i><span>destlounge</span>
                </a>
            </div>
        </div>
    </footer>
</div>

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        margin: 0;
        padding: 0;
        font-family: 'Georgia', serif;
        background-color: #d4c4b0;
    }

    /* Sidebar */
    .sidebar {
        position: fixed;
        left: 0;
        top: 0;
        width: 10%;
        min-width: 9rem;
        height: 100vh;
        background-color: #e7dfd6;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.25rem 0;
        z-index: 1000;
    }

    .logo-container {
        margin-bottom: 2rem;
    }

    .sidebar-logo {
        width: 3.5rem;
        height: auto;
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        width: 100%;
    }

    .nav-item {
        color: #5a4a3a;
        text-decoration: none;
        padding: 1rem 0.625rem;
        font-size: 1rem;
        font-weight: 500;
        text-align: center;
        transition: background-color 0.3s;
        letter-spacing: 0.0625rem;
        display: block;
    }

        .nav-item:hover {
            background-color: rgba(90,74,58,0.1);
        }

        .nav-item.active {
            background-color: rgba(139,111,71,0.3);
            border-left: 0.25rem solid #8b6f47;
        }

    .sidebar-footer {
        margin-top: auto;
        padding: 1.25rem 0;
    }

    .admin-link {
        color: #5a4a3a;
        text-decoration: none;
        font-size: 0.75rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3125rem;
    }

        .admin-link i {
            font-size: 1.25rem;
        }

    /* Main Content */
    .main-content {
        margin-left: 10%;
        min-height: 100vh;
        background-color: #d4c4b0;
        display: flex;
        flex-direction: column;
    }

    /* Services Page Layout */
    .services-page-container {
        display: flex;
        background-color: #f5f0eb;
        padding: 2rem;
        gap: 2rem;
        flex: 1;
    }

    /* Services Filter Sidebar */
    .services-sidebar {
        width: 200px;
        background-color: #e7dfd6;
        border: 3px solid #c1b2a5;
        padding: 2rem 1rem;
        height: fit-content;
        flex-shrink: 0;
    }

    .services-sidebar-title {
        font-size: 2rem;
        font-weight: 600;
        color: #5d4037;
        margin: 0 0 2rem 0;
        text-align: center;
    }

    .service-category {
        margin-bottom: 1.5rem;
        cursor: pointer;
        padding: 0.8rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

        .service-category:hover {
            background-color: #d4c4b0;
        }

        .service-category.active {
            background-color: #6b4423;
        }

            .service-category.active h3 {
                color: white;
            }

        .service-category h3 {
            font-size: 1rem;
            color: #5d4037;
            margin: 0;
            text-align: center;
            transition: color 0.3s ease;
        }

    /* Services Content Grid */
    .services-content {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 280px));
        gap: 2rem;
        align-content: start;
        justify-content: start;
    }

    /* Service Card */
    .service-card {
        background-color: white;
        border: 3px solid #3d2817;
        padding: 1rem;
        box-shadow: 4px 4px 8px rgba(0,0,0,0.2);
        transition: transform 0.3s ease;
        position: relative;
    }

        .service-card:hover {
            transform: scale(1.05);
        }

    .service-image {
        width: 100%;
        height: 250px;
        overflow: hidden;
        border: 2px solid #3d2817;
        margin-bottom: 1rem;
    }

        .service-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .service-name {
        text-align: center;
        font-size: 1rem;
        color: #3d2817;
        font-weight: 600;
        letter-spacing: 0.1em;
        padding: 0.5rem 0 0.25rem 0;
    }

    .service-description {
        text-align: center;
        font-size: 0.82rem;
        color: #7a6a5a;
        font-weight: 400;
        padding: 0 0.5rem 0.5rem 0.5rem;
        line-height: 1.5;
        max-height: 4.5rem;
        overflow-y: auto;
        overflow-x: hidden;
        word-break: break-word;
        scrollbar-width: thin;
        scrollbar-color: #c9b5a3 transparent;
    }

        .service-description::-webkit-scrollbar {
            width: 4px;
        }

        .service-description::-webkit-scrollbar-track {
            background: transparent;
        }

        .service-description::-webkit-scrollbar-thumb {
            background-color: #c9b5a3;
            border-radius: 4px;
        }

    .service-price {
        text-align: center;
        font-size: 1.2rem;
        color: #6b4423;
        font-weight: 700;
        padding: 0.3rem 0;
    }

    /* Admin Controls on Cards */
    .admin-controls {
        position: absolute;
        top: 0.5rem;
        right: 0.5rem;
        display: flex;
        gap: 0.3125rem;
        z-index: 10;
    }

    .edit-btn, .delete-btn {
        background: rgba(255,255,255,0.95);
        border: none;
        border-radius: 50%;
        width: 2rem;
        height: 2rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s;
        box-shadow: 0 0.125rem 0.375rem rgba(0,0,0,0.2);
    }

    .edit-btn {
        color: #4a7c59;
    }

        .edit-btn:hover {
            background: #4a7c59;
            color: white;
            transform: scale(1.1);
        }

    .delete-btn {
        color: #c84b4b;
    }

        .delete-btn:hover {
            background: #c84b4b;
            color: white;
            transform: scale(1.1);
        }

    /* Add Service Button */
    .add-service-container {
        text-align: center;
        padding: 3rem 0;
        background-color: #f5f0eb;
    }

    .add-service-button {
        padding: 1rem 3rem;
        font-size: 1.2rem;
        font-weight: 600;
        color: white;
        background-color: #6b4423;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Georgia', serif;
    }

        .add-service-button:hover {
            background-color: #5d3a1f;
            transform: scale(1.05);
        }

    /* Modal */
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.6);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
    }

    .service-modal {
        background-color: white;
        padding: 2.5rem;
        border-radius: 10px;
        max-width: 600px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .modal-title {
        color: #5d4037;
        margin: 0 0 2rem 0;
        font-size: 2rem;
        text-align: center;
    }

    .form-group {
        margin-bottom: 1.5rem;
        text-align: left;
    }

        .form-group label {
            display: block;
            color: #5d4037;
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

    .form-input, .form-textarea {
        width: 100%;
        padding: 0.9rem 1.2rem;
        font-size: 1rem;
        border: 2px solid #d4c4b0;
        border-radius: 8px;
        box-sizing: border-box;
        outline: none;
        transition: border-color 0.3s ease;
        font-family: 'Georgia', serif;
    }

        .form-input:focus, .form-textarea:focus {
            border-color: #8b6f47;
        }

        .form-input.ng-invalid.ng-dirty, .form-textarea.ng-invalid.ng-dirty {
            border-color: #dc3545;
        }

    select.form-input {
        cursor: pointer;
    }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    .form-input-file {
        width: 100%;
        padding: 0.5rem;
        font-size: 0.95rem;
        border: 2px dashed #d4c4b0;
        border-radius: 8px;
        cursor: pointer;
    }

    .image-preview {
        margin-top: 1rem;
        text-align: center;
    }

        .image-preview img {
            max-width: 100%;
            max-height: 200px;
            border: 2px solid #d4c4b0;
            border-radius: 8px;
        }

    .error-message {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 0.3rem;
        display: block;
    }

    .modal-actions {
        margin-top: 2rem;
        display: flex;
        gap: 1rem;
        justify-content: center;
    }

    .cancel-btn, .save-btn {
        padding: 0.9rem 2.5rem;
        font-size: 1rem;
        font-weight: 600;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        transition: all 0.3s ease;
        font-family: 'Georgia', serif;
    }

    .cancel-btn {
        color: #5d4037;
        background-color: #e7dfd6;
    }

        .cancel-btn:hover {
            background-color: #d4c4b0;
        }

    .save-btn {
        color: white;
        background-color: #6b4423;
    }

        .save-btn:hover:not(:disabled) {
            background-color: #5d3a1f;
            transform: scale(1.02);
        }

        .save-btn:disabled {
            background-color: #9a9a9a;
            cursor: not-allowed;
        }

    /* Footer */
    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        margin: 0;
        text-align: center;
    }

    .footer-container {
        padding: 0;
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
