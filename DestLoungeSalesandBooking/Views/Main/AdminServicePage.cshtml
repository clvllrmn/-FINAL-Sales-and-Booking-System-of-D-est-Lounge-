        align-items: center;
        justify-content: space-between;
        border-bottom: 2px solid #c1b2a5;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

        .mobile-topbar img {
            height: 2.5rem;
            width: auto;
        }

    .mobile-menu-btn {
        background: none;
        border: none;
        font-size: 1.5rem;
        color: #5a4a3a;
        cursor: pointer;
    }

    /* Mobile Nav Drawer */
    .mobile-nav-drawer {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 75%;
        max-width: 16rem;
        height: 100vh;
        background-color: #e7dfd6;
        z-index: 1200;
        flex-direction: column;
        padding: 1.5rem 0;
        box-shadow: 4px 0 12px rgba(0,0,0,0.15);
        transform: translateX(-100%);
        transition: transform 0.3s ease;
    }

        .mobile-nav-drawer.open {
            transform: translateX(0);
        }

        .mobile-nav-drawer .nav-item {
            font-size: 1rem;
            padding: 1rem 1.5rem;
            text-align: left;
            color: #5a4a3a;
        }

        .mobile-nav-drawer .sidebar-footer {
            margin-top: auto;
            padding: 1rem 1.5rem;
        }

    /* Mobile Nav Overlay */
    .mobile-nav-overlay {
        display: none;
