<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script>
        (function () {
            // Only run on protected pages, not on login/signup/public pages
            var publicPages = [
                '/Main/LoginPage',
                '/Main/SignupPage',
                '/Main/Homepage',
                '/Main/ContactPage',
                '/Main/FAQsPage',
                '/Main/ServicePage',
                '/Main/GalleryPage',
                '/Main/ForgotPasswordPage'
            ];

            var currentPath = window.location.pathname;

            // Check if current page is a public page
            var isPublic = publicPages.some(function (p) {
                return currentPath.toLowerCase() === p.toLowerCase();
            });

            if (isPublic) return; // Don't check session on public pages

            // On every pageshow event (fires on back button too, unlike load)
            window.addEventListener('pageshow', function (event) {
                // event.persisted = true means page was loaded from browser cache (back button)
                fetch('/Main/CheckSession', { method: 'GET', credentials: 'same-origin' })
                    .then(function (res) { return res.json(); })
                    .then(function (data) {
                        if (!data.loggedIn) {
                            // Replace history so back button can't return here
                            window.location.replace('/Main/LoginPage');
                        }
                    })
                    .catch(function () {
                        window.location.replace('/Main/LoginPage');
                    });
            });
        })();
    </script>
</head>
<body ng-app="DestLoungeSalesandBooking">

    <!-- 🔥 LOAD SCRIPTS FIRST -->
    <script src="/Scripts/angular.min.js"></script>
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular-sanitize.min.js"></script>

    <script src="/Scripts/HolyScripts/Module.js"></script>
    <script src="/Scripts/HolyScripts/Service.js"></script>
    <script src="/Scripts/HolyScripts/Controller.js"></script>

    <!-- THEN LOAD PAGE -->
    <div>
        @RenderBody()

    </div>


    @RenderSection("scripts", required: false)                 


</body>
</html>


<style>
    .nav-logout {
        margin-top: auto;
        color: #b8423e;
        border-top: 1px solid #c9b5a3;
    }

    .nav-logout:hover {
        background-color: #f0dbd9;
        border-left-color: #b8423e;
        color: #b8423e;
    }

    .contact-title {
        font-size: 3rem;
        font-weight: 600;
        color: #5d4037;
        margin: 0 0 2rem 0;
        text-align: center;
        font-family: Georgia, 'Times New Roman', serif;
        font-style: italic;
    }
    html, body {
        margin: 0;
        padding: 0;
        overflow-x:hidden;
    }
    body {
        overflow-x: hidden;
    }

    header {
        background-color: #e7dfd6;
        padding: 0rem 1rem;
        border: 3px solid #c1b2a5;
        position: sticky;
        top: 0;
        z-index: 1000;
    }

    .header-container {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo img {
        height: 5rem;
        width: auto;
    }
    
    .main-nav {
        margin-left: 3rem;
        margin-right: auto;
        display: flex;
        gap: 2.5rem;
    }

    .main-nav a {
        color: #5d4037;
        text-decoration: none;
        font-weight: 600;
        font-size: 1.3rem;
        letter-spacing: 0.5px;
        transition: color 0.3s ease;
    }

    .main-nav a:hover {
        color: #8b6f47;
    }

    /* Active nav indicator */
    .main-nav a.nav-active {
        color: #6b4423;
        border-bottom: 2.5px solid #6b4423;
        padding-bottom: 2px;
    }

    /* Bell icon (replaces email icon) */
    .bell-icon {
        font-size: 1.5rem;
        color: #5d4037;
        text-decoration: none;
        transition: color 0.3s ease, transform 0.2s ease;
        display: flex;
        align-items: center;
    }

    .bell-icon:hover {
        color: #8b6f47;
        transform: rotate(15deg);
    }

    .header-actions {
        display: flex;
        align-items: center;
        gap: 2rem;
    }

    .login-link {
        color: #5d4037;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        transition: color 0.3s ease;
    }

    .login-link:hover {
        color: #8b6f47;
    }

    .login-link i {
        font-size: 1.2rem;
    }

    .email-icon {
        font-size: 1.5rem;
        color: #5d4037;
        text-decoration: none;
        transition: color 0.3s ease;
        display: flex;
        align-items: center;
    }

    .email-icon:hover {
        color: #8b6f47;
    }

    .banner-container {
        background-color: #e7d7c8;
        border: 3px solid #3d2817;
        margin: 2rem;
        padding: 4rem;
        min-height: 400px;
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    footer {
        background-color: #e7d7c8;
        border: 2px solid #d4c4b0;
        border-left: none;
        border-right: none;
        padding: 2.5rem 3rem;
        margin: 0;
        text-align: center;
    }

    .footer-container {
        padding: 0;
        margin: 0 auto;
    }

    .footer-title {
        font-size: 2.5rem;
        font-weight: 700;
        color: #6b4423;
        margin: 0 0 2rem 0;
        font-style: italic;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .social-links {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 4rem;
        flex-wrap: wrap;
    }

    .social-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        text-decoration: none;
        color: #3d2817;
        transition: transform 0.3s ease, color 0.3s ease;
    }

    .social-item:hover {
        transform: scale(1.1);
        color: #6b4423;
    }

    .form-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .input-wrapper {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .form-input.half-width {
        width: 100%;
    }

    .form-input.ng-invalid.ng-dirty {
        border-color: #dc3545;
    }

    .error-message {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 0.3rem;
        display: block;
        min-height: 1.2rem;
    }

    .terms-group {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1.5rem;
        font-size: 0.95rem;
    }

    .terms-group input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .terms-group label {
        color: #5d4037;
        cursor: pointer;
    }

    .terms-link {
        color: #5d4037;
        text-decoration: underline;
        cursor: pointer;
        transition: color 0.3s ease;
        position: relative;
        z-index: 1;
    }

    .terms-link:hover {
        color: #8b6f47;
    }

    .already-account-container {
        text-align: center;
        margin-bottom: 0.8rem;
    }

    .already-account {
        color: #5d4037;
        text-decoration: underline;
        font-size: 0.95rem;
        transition: color 0.3s ease;
    }

    .already-account:hover {
        color: #8b6f47;
    }

    .signup-button {
        width: 50%;
        padding: 0.9rem;
        font-size: 1.1rem;
        font-weight: 600;
        color: white;
        background-color: #6b4423;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
        margin: 0 auto 1rem auto;
        display: block;
    }

    .signup-button:hover:not(:disabled) {
        background-color: #5d3a1f;
        transform: scale(1.02);
    }

    .signup-button:disabled {
        background-color: #9a9a9a;
        cursor: not-allowed;
    }

    .google-button {
        width: 50%;
        padding: 0.9rem;
        font-size: 1rem;
        font-weight: 600;
        color: white;
        background-color: #6b4423;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        margin: 0 auto;
    }

    .google-button:hover {
       background-color: #5d3a1f;
       transform: scale(1.02);
    }

    .google-button i {
        font-size: 1.2rem;
    }

    .toggle-password:hover {
        color: #8b6f47;
    }

    

    .services-page-container {
        display: flex;
        min-height: calc(100vh - 400px);
        background-color: #f5f0eb;
        padding: 2rem;
        gap: 2rem;
    }

    .services-sidebar {
        width: 200px;
        background-color: #e7dfd6;
        border: 3px solid #c1b2a5;
        padding: 2rem 1rem;
        height: fit-content;
    }

    .services-sidebar-title {
        font-size: 2rem;
        font-weight: 600;
        color: #5d4037;
        margin: 0 0 2rem 0;
        text-align: center;
    }

    .service-category {
        margin-bottom: 1.5rem;
        cursor: pointer;
        padding: 0.8rem;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

    .service-category:hover {
        background-color: #d4c4b0;
    }

    .service-category.active {
        background-color: #6b4423;
    }

    .service-category.active h3 {
         color: white;
    }

    .service-category h3 {
        font-size: 1rem;
        color: #5d4037;
        margin: 0;
        text-align: center;
        transition: color 0.3s ease;
    }

    .services-content {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2rem;
        align-content: start;
    }

    .service-price {
        text-align: center;
        font-size: 1.2rem;
        color: #6b4423;
        font-weight: 700;
        padding: 0.3rem 0;
    }
    .service-card {
        background-color: white;
        border: 3px solid #3d2817;
        padding: 1rem;
        box-shadow: 4px 4px 8px rgba(0, 0, 0, 0.2);
        transition: transform 0.3s ease;
        width: 100%;
    }

    .service-card:hover {
        transform: scale(1.05);
    }

    .service-image {
        width: 100%;
        height: 250px;
        overflow: hidden;
        border: 2px solid #3d2817;
        margin-bottom: 1rem;
    }

    .service-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .service-name {
        text-align: center;
        font-size: 1rem;
        color: #3d2817;
        font-weight: 600;
        letter-spacing: 0.1em;
        padding: 0.5rem 0;
    }

    .book-now-container {
        text-align: center;
        padding: 3rem 0 2rem 0 ;
        background-color: #f5f0eb;
    }

    .book-now-button {
        padding: 1rem 3rem;
        font-size: 1.2rem;
        font-weight: 600;
        color: white;
        background-color: #6b4423;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        transition: background-color 0.3s ease, transform 0.2s ease;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    }

    .book-now-button:hover {
        background-color: #5d3a1f;
        transform: scale(1.05);
    }

    /* Responsive Design */
    @@media (max-width: 1024px) {
        .services-content {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .services-page-container {
            flex-direction: column;
        }

        .services-sidebar {
            width: 100%;
        }

        .services-content {
            grid-template-columns: 1fr;
        }
    }
</style>
